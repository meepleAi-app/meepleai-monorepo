# Development environment for MeepleAI API.
# Copy to infra/env/api.env.dev and adjust for your local machine.
#
# SEC-708: Secrets are now managed via Docker Secrets (Phase 1)
# - Secrets stored in: infra/secrets/*.txt (gitignored)
# - Initialize secrets: tools/secrets/init-secrets.sh
# - List secrets: tools/secrets/list-secrets.sh
# - Rotate secrets: tools/secrets/rotate-secret.sh <name>
#
# Migration: See docs/security/docker-secrets-migration.md

# PostgreSQL Configuration
POSTGRES_USER=meeple
POSTGRES_DB=meepleai
# SEC-708: POSTGRES_PASSWORD is now in infra/secrets/postgres-password.txt (Docker Secret)

# Database Connection String
# SEC-708: ConnectionString is auto-built from Docker Secrets via SecretsHelper
# No need to set CONNECTIONSTRINGS__POSTGRES anymore (auto-built from POSTGRES_* vars)

# Embedding Provider Configuration
# Options: "ollama" (local, free) or "openai" (cloud, paid)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# OpenAI API Key (only required if EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here

# OpenRouter API Key (required for LLM chat completions)
# SEC-708: OPENROUTER_API_KEY is now in infra/secrets/openrouter-api-key.txt (Docker Secret)
# Get your key from: https://openrouter.ai/

JWT_ISSUER=http://localhost:5080
ALLOW_ORIGIN=http://localhost:3000
N8N_ENCRYPTION_KEY=generate-a-strong-32-byte-secret

# OPS-01: Seq log aggregation URL (default: http://seq:5341)
SEQ_URL=http://seq:5341

# Bootstrap: Initial admin user configuration
# These credentials will be used to create the first admin user on startup (if no admin exists)
# Password requirements: minimum 8 characters, at least one uppercase letter, one digit
INITIAL_ADMIN_EMAIL=admin@meepleai.dev
# SEC-708: INITIAL_ADMIN_PASSWORD is now in infra/secrets/initial-admin-password.txt (Docker Secret)
INITIAL_ADMIN_DISPLAY_NAME=System Administrator

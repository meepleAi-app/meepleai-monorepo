graph TB
    subgraph UL["📚 UserLibrary Context"]
        Entry[UserLibraryEntry Aggregate]
        Label[Label Aggregate]
        ShareLink[LibraryShareLink Aggregate]
    end

    subgraph GM["🎮 GameManagement Context"]
        Game[Game Catalog]
    end

    subgraph DocProc["📄 DocumentProcessing Context"]
        PdfPipeline[PDF Extraction Pipeline]
    end

    subgraph SGC["🌐 SharedGameCatalog Context"]
        SharedGame[Community Catalog]
    end

    subgraph UN["🔔 UserNotifications Context"]
        Notif[Notification System]
    end

    subgraph Admin["📊 Administration Context"]
        Analytics[Analytics & Audit]
        QuotaEnforce[Quota Enforcement]
    end

    %% Event-Driven Communication
    Entry -->|PrivatePdfUploadedEvent| PdfPipeline
    Entry -->|PlayRecordedEvent| Game
    Entry -->|GameAddedToLibraryEvent| Analytics
    ShareLink -->|ShareLinkAccessedEvent| Notif

    %% Direct Dependencies (Queries)
    Entry -.->|FK: GameId| Game
    Entry -.->|FK: PrivatePdfDocumentId| PdfPipeline
    Entry -.->|Check quota before add| QuotaEnforce

    %% SSE Progress
    PdfPipeline -.->|SSE Progress Updates| Entry

    %% Future Integration (Phase 2-5)
    Entry -.->|ProposePrivateGame Phase4| SharedGame

    %% Styling
    classDef ulStyle fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef gmStyle fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    classDef docStyle fill:#e3f2fd,stroke:#2196f3,stroke-width:2px
    classDef sgcStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef unStyle fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    classDef adminStyle fill:#fff4e6,stroke:#ff9800,stroke-width:2px

    class Entry,Label,ShareLink ulStyle
    class Game gmStyle
    class PdfPipeline docStyle
    class SharedGame sgcStyle
    class Notif unStyle
    class Analytics,QuotaEnforce adminStyle

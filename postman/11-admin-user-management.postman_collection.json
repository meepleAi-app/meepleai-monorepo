{
  "info": {
    "_postman_id": "admin-users-collection-011",
    "name": "11 - Admin: User Management",
    "description": "MeepleAI Admin API endpoints for managing users, roles, tiers, and bulk operations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "User CRUD",
      "item": [
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.items && jsonData.items.length > 0) {",
                  "        pm.collectionVariables.set('userId', jsonData.items[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "List all users with pagination"
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?search=john&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                {
                  "key": "search",
                  "value": "john"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Search users by name or email"
          }
        },
        {
          "name": "Filter by Role",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?role=Editor&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                {
                  "key": "role",
                  "value": "Editor",
                  "description": "Options: User, Editor, Admin"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Filter users by role"
          }
        },
        {
          "name": "Filter by Tier",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?tier=Premium&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                {
                  "key": "tier",
                  "value": "Premium",
                  "description": "Options: Free, Normal, Premium"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Filter users by tier"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"displayName\": \"New User\",\n  \"password\": \"SecureP@ss123\",\n  \"role\": \"User\",\n  \"tier\": \"Free\",\n  \"sendWelcomeEmail\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"]
            },
            "description": "Create a new user account"
          }
        },
        {
          "name": "Get User Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "{{userId}}"]
            },
            "description": "Get detailed user information"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Updated Name\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "{{userId}}"]
            },
            "description": "Update user details"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "{{userId}}"]
            },
            "description": "Delete a user account"
          }
        }
      ]
    },
    {
      "name": "Roles & Tiers",
      "item": [
        {
          "name": "Change User Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"Editor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/role",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "{{userId}}", "role"]
            },
            "description": "Change user role (User, Editor, Admin)"
          }
        },
        {
          "name": "Change User Tier",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tier\": \"Premium\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/tier",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "{{userId}}", "tier"]
            },
            "description": "Change user tier (Free, Normal, Premium)"
          }
        }
      ]
    },
    {
      "name": "Bulk Operations",
      "item": [
        {
          "name": "Bulk Password Reset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\n    \"user-id-1\",\n    \"user-id-2\",\n    \"user-id-3\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/bulk/password-reset",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "bulk", "password-reset"]
            },
            "description": "Send password reset emails to multiple users"
          }
        },
        {
          "name": "Bulk Role Change",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\n    \"user-id-1\",\n    \"user-id-2\"\n  ],\n  \"role\": \"Editor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/bulk/role-change",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "bulk", "role-change"]
            },
            "description": "Change role for multiple users at once"
          }
        },
        {
          "name": "Import Users (CSV)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/users.csv"
                },
                {
                  "key": "sendWelcomeEmails",
                  "value": "true",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/bulk/import",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "bulk", "import"]
            },
            "description": "Import users from CSV file"
          }
        },
        {
          "name": "Export Users (CSV)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Accept",
                "value": "text/csv"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/bulk/export?role=all&tier=all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "bulk", "export"],
              "query": [
                {
                  "key": "role",
                  "value": "all"
                },
                {
                  "key": "tier",
                  "value": "all"
                }
              ]
            },
            "description": "Export users to CSV file"
          }
        }
      ]
    },
    {
      "name": "User Activity",
      "item": [
        {
          "name": "Get User Activity",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/activity?page=1&pageSize=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "{{userId}}", "activity"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "50"
                }
              ]
            },
            "description": "Get activity timeline for a specific user"
          }
        },
        {
          "name": "Filter Activity by Type",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/activity?type=LOGIN&from=2026-01-01&to=2026-01-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users", "{{userId}}", "activity"],
              "query": [
                {
                  "key": "type",
                  "value": "LOGIN",
                  "description": "Options: LOGIN, CHAT_SESSION_STARTED, GAME_ADDED, PDF_UPLOADED, etc."
                },
                {
                  "key": "from",
                  "value": "2026-01-01"
                },
                {
                  "key": "to",
                  "value": "2026-01-31"
                }
              ]
            },
            "description": "Filter user activity by type and date range"
          }
        }
      ]
    },
    {
      "name": "User Search",
      "item": [
        {
          "name": "Autocomplete Search",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/search?q=joh&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "joh"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Autocomplete search for users"
          }
        }
      ]
    }
  ]
}

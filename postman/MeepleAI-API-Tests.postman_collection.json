    },
    {
      "name": "3. Game Management",
      "description": "Game CRUD operations - requires authentication",
      "item": [
        {
          "name": "Re-Login (Setup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Session established for game tests', function() {",
                  "    pm.expect(pm.cookies.has('meepleai_session')).to.be.true;",

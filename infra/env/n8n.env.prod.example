# n8n Workflow Automation - Production
# ⚠️  CRITICAL: Encryption key backup required
#
# USAGE:
#   cp n8n.env.prod.example n8n.env.prod
#   vim n8n.env.prod  # Replace <REPLACE_*>
#   ⚠️  Backup n8n-encryption-key.txt in secure vault!

# Server Configuration
GENERIC_TIMEZONE=Europe/Rome
N8N_HOST=<REPLACE_WITH_PROD_N8N_HOST>
# Example: workflows.meepleai.dev
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=<REPLACE_WITH_PROD_N8N_WEBHOOK_URL>
# Example: https://workflows.meepleai.dev/

# Execution Settings
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200

# Database (shared with main app)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=<REPLACE_WITH_PROD_DB_HOST>
# Example: prod-postgres.internal or RDS endpoint
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=meepleai_production
DB_POSTGRESDB_USER=<REPLACE_WITH_PROD_DB_USER>
# DB_POSTGRESDB_PASSWORD from Docker Secret

# MeepleAI API Integration
MEEPLEAI_API_URL=<REPLACE_WITH_PROD_API_URL>
# Example: https://api.meepleai.dev

# Service Account Session Token
# Generate with: pwsh tools/setup-n8n-service-account.ps1 --environment production
# ⚠️  Rotate every 90 days
N8N_SERVICE_SESSION=<REPLACE_WITH_SERVICE_SESSION_TOKEN>

# Basic Auth (STRONG password required)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=<REPLACE_WITH_N8N_USER>
# Example: admin_prod or company-specific username
# N8N_BASIC_AUTH_PASSWORD from Docker Secret (16+ characters)

# Encryption Key
# ⚠️  CRITICAL: NEVER lose this key - credentials will be irrecoverable
# ⚠️  Backup encrypted copy in multiple secure locations:
#     1. Company vault
#     2. Password manager
#     3. Encrypted USB in safe
# N8N_ENCRYPTION_KEY from Docker Secret

# Logging (less verbose in production)
N8N_LOG_LEVEL=warn
N8N_LOG_OUTPUT=file

# Editor
N8N_EDITOR_BASE_URL=<REPLACE_WITH_PROD_N8N_WEBHOOK_URL>

# Workers (for scaling)
# QUEUE_BULL_REDIS_HOST=redis
# QUEUE_BULL_REDIS_PORT=6379
# QUEUE_BULL_REDIS_PASSWORD from Docker Secret
# EXECUTIONS_MODE=queue

# ============================================================================
# SECRETS (MANDATORY - use Docker Secrets)
# ============================================================================
# DB_POSTGRESDB_PASSWORD_FILE=/run/secrets/postgres-password
# N8N_BASIC_AUTH_PASSWORD_FILE=/run/secrets/n8n-basic-auth-password
# N8N_ENCRYPTION_KEY_FILE=/run/secrets/n8n-encryption-key
#
# ⚠️  CRITICAL BACKUP CHECKLIST:
# [ ] n8n-encryption-key.txt backed up to vault
# [ ] Encrypted copy in password manager
# [ ] Physical backup in safe location
# [ ] Recovery procedure documented
# [ ] Test restore from backup quarterly
#
# Initialize: cd infra/secrets && ./init-secrets.sh --environment prod
# Backup: gpg --encrypt --recipient ops@meepleai.dev prod/n8n-encryption-key.txt
# Rotate: ./rotate-secret.sh n8n-basic-auth-password --environment prod (quarterly)
#
# See: infra/secrets/prod/

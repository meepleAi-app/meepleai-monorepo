{
  "info": {
    "_postman_id": "game-discovery-collection-002",
    "name": "02 - Game Discovery Flows",
    "description": "MeepleAI Game Catalog API endpoints for browsing, searching, filtering, and viewing game details.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "gameId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Catalog Browsing",
      "item": [
        {
          "name": "Get All Games (Paginated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.items && jsonData.items.length > 0) {",
                  "        pm.collectionVariables.set('gameId', jsonData.items[0].id);",
                  "    }",
                  "    pm.test('Has items array', function() {",
                  "        pm.expect(jsonData).to.have.property('items');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shared-games?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "shared-games"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Get paginated list of all published games"
          }
        },
        {
          "name": "Get Games with Sorting",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shared-games?sortBy=name&sortOrder=asc&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "shared-games"],
              "query": [
                {
                  "key": "sortBy",
                  "value": "name",
                  "description": "Options: name, rating, complexity, playerCount, playTime, createdAt"
                },
                {
                  "key": "sortOrder",
                  "value": "asc",
                  "description": "Options: asc, desc"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Get games sorted by specific field"
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search Games by Query",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shared-games?search=catan&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "shared-games"],
              "query": [
                {
                  "key": "search",
                  "value": "catan"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Full-text search across game names and descriptions"
          }
        },
        {
          "name": "Search with Autocomplete",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shared-games/autocomplete?q=cat&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "shared-games", "autocomplete"],
              "query": [
                {
                  "key": "q",
                  "value": "cat"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get autocomplete suggestions while typing"
          }
        }
      ]
    },
    {
      "name": "Filters",

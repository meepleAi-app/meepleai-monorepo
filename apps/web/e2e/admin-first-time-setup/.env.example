# Admin First-Time Setup - Test Environment Variables

# Admin Credentials (from infra/secrets/admin.secret)
ADMIN_EMAIL=admin@meepleai.dev
ADMIN_PASSWORD=pVKOMQNK0tFNgGlX

# Optional: Enable Testcontainers for isolated infrastructure
# Requires Docker running locally
E2E_USE_TESTCONTAINERS=false

# Optional: Enable real OAuth testing (requires provider credentials)
E2E_OAUTH_ENABLED=false

# Backend API base URL (default: http://localhost:8080)
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Test timeouts (milliseconds)
E2E_PDF_PROCESSING_TIMEOUT=60000
E2E_CHAT_CREATION_TIMEOUT=30000
E2E_TEST_TIMEOUT=120000

# Test data location
E2E_TEST_DATA_DIR=e2e/test-data

# Mock PDF generation
E2E_USE_MOCK_PDFS=true
E2E_MOCK_PDF_SIZE_KB=50

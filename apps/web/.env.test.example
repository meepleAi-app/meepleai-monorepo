# Test environment variables for E2E tests
# This file provides mock OAuth credentials and test configuration
# for Playwright E2E test suite execution

# API Base URL - points to backend (started separately or mocked)
# Issue #1951: Corrected port to 8080 (standard API port)
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Mock OAuth Credentials for Testing
# These are dummy values used for testing redirect URLs and OAuth flow
# They will NOT work with real OAuth providers - tests should mock the OAuth endpoints
GOOGLE_OAUTH_CLIENT_ID=mock-google-client-id-for-testing
GOOGLE_OAUTH_CLIENT_SECRET=mock-google-client-secret-for-testing

DISCORD_OAUTH_CLIENT_ID=mock-discord-client-id-for-testing
DISCORD_OAUTH_CLIENT_SECRET=mock-discord-client-secret-for-testing

GITHUB_OAUTH_CLIENT_ID=mock-github-client-id-for-testing
GITHUB_OAUTH_CLIENT_SECRET=mock-github-client-secret-for-testing

# Test Configuration
NODE_ENV=test
CI=false

# Docker E2E Infrastructure (Issue #2009)
# Grafana admin password for E2E monitoring dashboard
# Default: 'admin' (development only, change in production)
GRAFANA_E2E_PASSWORD=admin

# Prometheus remote write URL (set by docker-compose.e2e.yml)
# PROMETHEUS_REMOTE_WRITE_URL=http://prometheus:9090/api/v1/write

# Optional: Prometheus API key for authentication
# PROMETHEUS_API_KEY=your-api-key-here

# E2E Test User Credentials (Issue #4168)
# These are loaded from infra/secrets/admin.secret by setup-secrets.ps1
# Or use default Demo123! for E2E test users
ADMIN_EMAIL=admin@meepleai.dev
ADMIN_PASSWORD=your-admin-password-here
EDITOR_EMAIL=editor@meepleai.dev
EDITOR_PASSWORD=Demo123!

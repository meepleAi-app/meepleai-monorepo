            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/state-template/{{templateId}}/activate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "state-template", "{{templateId}}", "activate"]
            },
            "description": "Activate a specific template version for new sessions"

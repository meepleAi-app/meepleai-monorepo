                  "});",
                  "",
                  "pm.test('Search mode is vector', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.searchMode).to.equal('vector');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",

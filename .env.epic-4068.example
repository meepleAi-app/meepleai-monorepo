# Epic #4068: Environment Variables Template
# Copy to .env.development or .env.production and fill in values

# ============================================================================
# Backend Configuration
# ============================================================================

# Database
DATABASE_URL=postgres://user:password@localhost:5432/meepleai
DATABASE_MAX_POOL_SIZE=100
DATABASE_CONNECTION_TIMEOUT=30

# Redis (for permission caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.meepleai.com

# Epic #4068: Permission System
PERMISSION_CACHE_DURATION_MINUTES=5
PERMISSION_RATE_LIMIT_PER_MINUTE=100
PERMISSION_REGISTRY_CACHE_ENABLED=true

# Feature Flags (Epic #4068)
FEATURE_FLAG_EPIC_4068_ENABLED=true
FEATURE_FLAG_PERMISSION_SYSTEM_ENABLED=true
FEATURE_FLAG_TAG_SYSTEM_ENABLED=true
FEATURE_FLAG_AGENT_METADATA_ENABLED=true
FEATURE_FLAG_COLLECTION_LIMITS_ENABLED=true
FEATURE_FLAG_SMART_TOOLTIPS_ENABLED=true

# Gradual Rollout
EPIC_4068_ROLLOUT_PERCENTAGE=100 # 0-100 (10 = 10% of users)

# ============================================================================
# Frontend Configuration
# ============================================================================

# API Endpoints
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Environment
NEXT_PUBLIC_ENVIRONMENT=development

# Epic #4068: Permission System (Frontend)
NEXT_PUBLIC_PERMISSION_CACHE_TIME_MS=300000 # 5 minutes
NEXT_PUBLIC_PERMISSION_STALE_TIME_MS=300000
NEXT_PUBLIC_PERMISSION_WEBSOCKET_ENABLED=true

# Epic #4068: Feature Flags (Frontend)
NEXT_PUBLIC_EPIC_4068_ENABLED=true
NEXT_PUBLIC_TAGS_ENABLED=true
NEXT_PUBLIC_AGENT_METADATA_ENABLED=true
NEXT_PUBLIC_COLLECTION_LIMITS_ENABLED=true
NEXT_PUBLIC_SMART_TOOLTIPS_ENABLED=true

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Prometheus
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# Grafana
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=Information # Development: Debug, Production: Information
LOG_TO_CONSOLE=true
LOG_TO_FILE=false
LOG_FILE_PATH=/var/log/meepleai/app.log

# ============================================================================
# Stripe (for tier upgrades)
# ============================================================================

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (Epic #4068 tier products)
STRIPE_PRICE_ID_NORMAL=price_normal_xxx
STRIPE_PRICE_ID_PRO=price_pro_xxx
STRIPE_PRICE_ID_ENTERPRISE=price_enterprise_xxx

# ============================================================================
# Email (for tier upgrade notifications)
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@meepleai.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=MeepleAI <noreply@meepleai.com>

# ============================================================================
# Security
# ============================================================================

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PERMISSION_API=100 # requests per minute
RATE_LIMIT_GENERAL_API=1000

# Session Security
SESSION_SECRET=your-session-secret-key
SESSION_COOKIE_SECURE=true # HTTPS only in production
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# ============================================================================
# Performance
# ============================================================================

# Caching
ENABLE_HYBRID_CACHE=true
HYBRID_CACHE_MEMORY_LIMIT_MB=256
HYBRID_CACHE_REDIS_ENABLED=true

# Response Compression
RESPONSE_COMPRESSION_ENABLED=true
RESPONSE_COMPRESSION_LEVEL=6 # 1-9 (higher = more compression, slower)

# ============================================================================
# Development Only
# ============================================================================

# Hot Reload
CHOKIDAR_USEPOLLING=true # For Docker on Windows
WATCHPACK_POLLING=true

# Debugging
NEXT_PUBLIC_DEBUG_PERMISSIONS=false
NEXT_PUBLIC_DEBUG_TOOLTIPS=false
ASPNETCORE_DETAILEDERRORS=true

# ============================================================================
# Production Only (Comment out in development)
# ============================================================================

# # SSL/TLS
# HTTPS_CERT_PATH=/etc/ssl/certs/meepleai.crt
# HTTPS_KEY_PATH=/etc/ssl/private/meepleai.key

# # Production URLs
# NEXT_PUBLIC_API_URL=https://api.meepleai.com
# NEXT_PUBLIC_WS_URL=wss://api.meepleai.com

# # Logging
# LOG_LEVEL=Information
# LOG_TO_FILE=true

# # Security
# SESSION_COOKIE_SECURE=true
# CORS_ORIGINS=https://app.meepleai.com

# # Monitoring
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# ============================================================================
# Epic #4068 Specific Configuration
# ============================================================================

# Permission System
PERMISSION_UNKNOWN_FEATURE_POLICY=deny # deny | allow | log_and_deny
PERMISSION_SUSPENDED_USER_POLICY=deny_all # deny_all | allow_read
PERMISSION_BANNED_USER_POLICY=deny_all

# Tag System
TAG_MAX_VISIBLE_DEFAULT=3
TAG_STRIP_WIDTH_DESKTOP=32
TAG_STRIP_WIDTH_TABLET=28
TAG_STRIP_WIDTH_MOBILE=24

# Tooltip System
TOOLTIP_POSITIONING_DEBOUNCE_MS=100
TOOLTIP_VIEWPORT_PADDING_PX=8
TOOLTIP_DEFAULT_GAP_PX=8
TOOLTIP_COLLISION_DETECTION_ENABLED=false # Experimental

# Collection Limits
COLLECTION_LIMIT_WARNING_THRESHOLD=0.75 # 75%
COLLECTION_LIMIT_CRITICAL_THRESHOLD=0.90 # 90%
COLLECTION_LIMIT_CHECK_FREQUENCY_MS=30000 # Check every 30 seconds

# Agent Metadata
AGENT_STATUS_POLL_INTERVAL_MS=30000 # Poll agent status every 30 seconds
AGENT_STATS_UPDATE_INTERVAL_MS=60000 # Update stats every 60 seconds

# ============================================================================
# Testing
# ============================================================================

# Test Database
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/meepleai_test

# Test Users (for E2E tests)
TEST_USER_FREE_EMAIL=free@example.com
TEST_USER_FREE_PASSWORD=password

TEST_USER_PRO_EMAIL=pro@example.com
TEST_USER_PRO_PASSWORD=password

TEST_USER_ADMIN_EMAIL=admin@example.com
TEST_USER_ADMIN_PASSWORD=password

# Test Tokens (generated)
FREE_USER_TOKEN=
PRO_USER_TOKEN=
ADMIN_USER_TOKEN=
SUSPENDED_USER_TOKEN=

# ============================================================================
# Notes
# ============================================================================

# Security:
# - Never commit this file with real values
# - Add .env.development and .env.production to .gitignore
# - Use secret management service in production (AWS Secrets Manager, Azure Key Vault)

# Epic #4068 Documentation:
# - See docs/02-development/epic-4068-implementation-guide.md
# - See docs/13-deployment/epic-4068-deployment-guide.md

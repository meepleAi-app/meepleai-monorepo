{
  "info": {
    "_postman_id": "editor-content-collection-008",
    "name": "08 - Editor: Content Management",
    "description": "MeepleAI Editor API endpoints for managing quick questions, FAQ, errata, and state templates.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "gameId",
      "value": "",
      "type": "string"
    },
    {
      "key": "questionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "faqId",
      "value": "",
      "type": "string"
    },
    {
      "key": "errataId",
      "value": "",
      "type": "string"
    },
    {
      "key": "templateId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Quick Questions",
      "item": [
        {
          "name": "Generate Quick Questions (AI)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/quick-questions/generate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "quick-questions", "generate"]
            },
            "description": "Generate quick questions using AI from indexed PDFs"
          }
        },
        {
          "name": "List Quick Questions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.items && jsonData.items.length > 0) {",
                  "        pm.collectionVariables.set('questionId', jsonData.items[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/quick-questions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "quick-questions"]
            },
            "description": "List all quick questions for a game"
          }
        },
        {
          "name": "Add Quick Question",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"How do I set up the game for 4 players?\",\n  \"answer\": \"Place the board in the center. Each player takes one set of colored pieces...\",\n  \"category\": \"Setup\",\n  \"order\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/quick-questions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "quick-questions"]
            },
            "description": "Manually add a quick question"
          }
        },
        {
          "name": "Update Quick Question",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"How do I set up the game?\",\n  \"answer\": \"Updated answer with more details...\",\n  \"category\": \"Setup\",\n  \"order\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/quick-questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "quick-questions", "{{questionId}}"]
            },
            "description": "Update a quick question"
          }
        },
        {
          "name": "Delete Quick Question",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/quick-questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "quick-questions", "{{questionId}}"]
            },
            "description": "Delete a quick question"
          }
        }
      ]
    },
    {
      "name": "FAQ",

{
  "name": "@meepleai/web",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev -p 3000",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start -p 3000",
    "start:standalone": "node .next/standalone/server.js",
    "test": "jest --passWithNoTests",
    "posttest": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "posttest:coverage": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:performance": "playwright test e2e/performance.spec.ts",
    "test:performance:ui": "playwright test e2e/performance.spec.ts --ui",
    "test:a11y": "jest --testPathPatterns=\"(a11y|accessibility)\"",
    "audit:a11y": "tsx scripts/run-accessibility-audit.ts",
    "lighthouse:ci": "lhci autorun",
    "lighthouse:report": "lhci open",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },

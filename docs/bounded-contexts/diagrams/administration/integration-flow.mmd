graph TB
    subgraph Admin["📊 Administration Context"]
        UserMgmt[User Management]
        AuditLog[Audit Logging]
        TokenMgmt[Token Management]
        BatchJobs[Batch Job System]
        Alerts[Alert System]
        AiModelMgmt[AI Model Admin]
    end

    subgraph Auth["🔐 Authentication Context"]
        UserEntity[User Entity]
    end

    subgraph KB["🧠 KnowledgeBase Context"]
        AgentTypology[Agent Typology]
        AgentInvoke[Agent Invocation]
    end

    subgraph SGC["🌐 SharedGameCatalog Context"]
        ShareReq[Share Requests]
        BadgeSystem[Badge System]
    end

    subgraph UL["📚 UserLibrary Context"]
        Library[User Collections]
    end

    subgraph UN["🔔 UserNotifications Context"]
        Notif[Notification System]
    end

    subgraph SysConfig["⚙️ SystemConfiguration Context"]
        Config[Runtime Config]
    end

    %% Event-Driven Communication - Inbound
    UserEntity -->|UserCreatedEvent| AuditLog
    UserEntity -->|UserLoggedInEvent| AuditLog
    AgentInvoke -->|AgentInvokedEvent| TokenMgmt
    AgentTypology -->|TypologyProposedEvent| AiModelMgmt
    ShareReq -->|GamePublishedEvent| BadgeSystem
    BadgeSystem -->|BadgeEarnedEvent| AuditLog

    %% Event-Driven Communication - Outbound
    UserMgmt -->|UserSuspendedEvent| Notif
    UserMgmt -->|UserUnsuspendedEvent| Notif
    Alerts -->|AlertTriggeredEvent| Notif
    AiModelMgmt -->|TypologyApprovedEvent| Notif
    TokenMgmt -->|TierChangedEvent| Library

    %% Direct Dependencies
    UserMgmt -.->|Extend User entity| UserEntity
    AuditLog -.->|Log all admin actions| UserMgmt
    TokenMgmt -.->|Track AI usage| AgentInvoke
    Alerts -.->|Monitor metrics| Config

    %% Styling
    classDef adminStyle fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef authStyle fill:#e1f5ff,stroke:#0066cc,stroke-width:2px
    classDef kbStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef sgcStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef ulStyle fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef unStyle fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    classDef configStyle fill:#e0f2f1,stroke:#009688,stroke-width:2px

    class UserMgmt,AuditLog,TokenMgmt,BatchJobs,Alerts,AiModelMgmt adminStyle
    class UserEntity authStyle
    class AgentTypology,AgentInvoke kbStyle
    class ShareReq,BadgeSystem sgcStyle
    class Library ulStyle
    class Notif unStyle
    class Config configStyle

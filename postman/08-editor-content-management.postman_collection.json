              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/state-template/{{templateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "state-template", "{{templateId}}"]

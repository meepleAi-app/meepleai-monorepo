graph TB
    subgraph SysConfig["⚙️ SystemConfiguration Context"]
        Config[Configuration Store]
        AiModels[AI Model Registry]
        TierRouting[Tier Routing]
        FeatureFlags[Feature Flags]
        Quotas[Quota Limits]
    end

    subgraph AllServices["🔄 All Services"]
        Auth[Authentication]
        DocProc[DocumentProcessing]
        GM[GameManagement]
        KB[KnowledgeBase]
        UL[UserLibrary]
    end

    subgraph KB_Detail["🧠 KnowledgeBase Context"]
        LLMSelect[LLM Model Selection]
    end

    subgraph Cache["💾 Cache Layer"]
        Redis[Redis Cache]
    end

    subgraph UN["🔔 UserNotifications Context"]
        Notif[Notifications]
    end

    %% Event-Driven Communication
    Config -->|ConfigurationUpdatedEvent| AllServices
    FeatureFlags -->|FeatureFlagToggledEvent| AllServices
    AiModels -->|AiModelPriorityChangedEvent| LLMSelect
    TierRouting -->|TierRoutingUpdatedEvent| LLMSelect
    Quotas -->|QuotaLimitChangedEvent| UL
    Quotas -->|QuotaLimitChangedEvent| DocProc

    %% Direct Dependencies (Read Operations)
    Auth -.->|Query: SessionExpirationDays| Config
    DocProc -.->|Query: MaxFileSizeBytes| Quotas
    GM -.->|Query: MaxConcurrentSessions| Quotas
    KB -.->|Query: Model for tier| TierRouting
    UL -.->|Check: MaxGames per tier| Quotas

    %% Cache Interaction
    AllServices -.->|Read cached configs| Redis
    Config -.->|Invalidate on update| Redis

    %% Styling
    classDef configStyle fill:#e0f2f1,stroke:#009688,stroke-width:2px
    classDef servicesStyle fill:#f5f5f5,stroke:#9e9e9e,stroke-width:2px
    classDef kbStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef cacheStyle fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    classDef unStyle fill:#fce4ec,stroke:#e91e63,stroke-width:2px

    class Config,AiModels,TierRouting,FeatureFlags,Quotas configStyle
    class Auth,DocProc,GM,KB,UL servicesStyle
    class LLMSelect kbStyle
    class Redis cacheStyle
    class Notif unStyle

{
  "id": null,
  "uid": "cache-optimization",
  "title": "MeepleAI - Cache Optimization",
  "description": "Real-time cache efficiency and Redis resource monitoring",
  "tags": ["meepleai", "cache", "performance"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "liveNow": false,
  "style": "dark",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "hidden": false,
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(meepleai_cache_hits_total[5m]) / (rate(meepleai_cache_hits_total[5m]) + rate(meepleai_cache_misses_total[5m])) * 100",
          "legendFormat": "Hit Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 80, "color": "yellow"},
              {"value": 90, "color": "green"}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      }
    },
    {
      "id": 2,
      "title": "Cache Operations Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(meepleai_cache_hits_total[5m])",
          "legendFormat": "Hits/sec ({{operation}}, {{cache_type}})",
          "refId": "A"
        },
        {
          "expr": "rate(meepleai_cache_misses_total[5m])",
          "legendFormat": "Misses/sec ({{operation}}, {{cache_type}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "opm"}, "overrides": []},
      "options": {"legend": {"displayMode": "table"}}
    },
    {
      "id": 3,
      "title": "Cache Evictions Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(meepleai_cache_evictions_total[5m])",
          "legendFormat": "Evictions/sec ({{reason}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 4,
      "title": "Total Cache Operations",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(meepleai_cache_hits_total[5m]) + rate(meepleai_cache_misses_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "blue"},
              {"value": 10, "color": "green"},
              {"value": 50, "color": "yellow"}
            ]
          }
        }
      },
      "options": {"orientation": "auto", "graphMode": "area"}
    },
    {
      "id": 5,
      "title": "Cache Hits by Cache Type",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum by (cache_type) (rate(meepleai_cache_hits_total[5m]))",
          "legendFormat": "{{cache_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cache Misses by Cache Type",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum by (cache_type) (rate(meepleai_cache_misses_total[5m]))",
          "legendFormat": "{{cache_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cache Operations by Operation Type",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum by (operation) (rate(meepleai_cache_hits_total[5m]))",
          "legendFormat": "Hits: {{operation}}",
          "refId": "A"
        },
        {
          "expr": "sum by (operation) (rate(meepleai_cache_misses_total[5m]))",
          "legendFormat": "Misses: {{operation}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Cache Evictions by Reason",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (reason) (rate(meepleai_cache_evictions_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Top 10 Cache Types by Hit Count (Last Hour)",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum by (cache_type) (increase(meepleai_cache_hits_total[1h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "indexByName": {"cache_type": 0, "Value": 1},
            "renameByName": {"cache_type": "Cache Type", "Value": "Hit Count"}
          }
        }
      ]
    },
    {
      "id": 10,
      "title": "Redis Memory Usage (MB)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 32, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Used Memory (MB)",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes / 1024 / 1024",
          "legendFormat": "Max Memory (MB)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "mbytes"},
        "overrides": []
      },
      "alert": {
        "name": "Redis Memory High",
        "frequency": "60s",
        "handler": 1,
        "noDataState": "no_data",
        "executionErrorState": "alerting",
        "conditions": [
          {
            "type": "query",
            "query": {"params": ["A", "5m", "now"]},
            "reducer": {"type": "avg", "params": []},
            "evaluator": {"type": "gt", "params": [0.8]},
            "operator": {"type": "and"}
          }
        ],
        "notifications": []
      }
    }
  ]
}

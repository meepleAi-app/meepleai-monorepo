graph TB
    subgraph DocProc["📄 DocumentProcessing Context"]
        Upload[PDF Upload]
        Extract[3-Stage Extraction]
        Chunking[Text Chunking]
        Collections[Document Collections]
    end

    subgraph Storage["☁️ External Storage"]
        BlobStore[S3/R2/Local Blob]
        Qdrant[Qdrant Vector DB]
    end

    subgraph Python["🐍 Python Services"]
        Unstructured[Unstructured.py]
        SmolDocling[SmolDocling VLM]
        Embedding[Embedding Service]
    end

    subgraph UL["📚 UserLibrary Context"]
        PrivatePdf[Private PDF Upload]
    end

    subgraph KB["🧠 KnowledgeBase Context"]
        RAG[RAG System]
    end

    subgraph SGC["🌐 SharedGameCatalog Context"]
        BggExtract[BGG Game Extraction]
    end

    subgraph UN["🔔 UserNotifications Context"]
        Notif[Notifications]
    end

    %% Event-Driven Communication
    PrivatePdf -->|PrivatePdfUploadedEvent| Upload
    Extract -->|PdfExtractedEvent| RAG
    Extract -->|ProcessingFailedEvent| Notif
    Chunking -->|PdfIndexedEvent| RAG

    %% External Service Communication
    Upload -.->|Store file| BlobStore
    Extract -.->|Stage 1 extraction| Unstructured
    Extract -.->|Stage 2 fallback| SmolDocling
    Extract -.->|Stage 3 fallback| Docnet
    Chunking -.->|Generate embeddings| Embedding
    Chunking -.->|Store vectors| Qdrant

    %% Direct Dependencies
    Collections -.->|Reference PDFs| Upload
    BggExtract -.->|Extract BGG IDs from PDF| Extract
    RAG -.->|Query chunks| Qdrant

    %% Styling
    classDef docStyle fill:#e3f2fd,stroke:#2196f3,stroke-width:2px
    classDef storageStyle fill:#fafafa,stroke:#757575,stroke-width:2px
    classDef pythonStyle fill:#fff9c4,stroke:#fbc02d,stroke-width:2px
    classDef ulStyle fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef kbStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef sgcStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef unStyle fill:#fce4ec,stroke:#e91e63,stroke-width:2px

    class Upload,Extract,Chunking,Collections docStyle
    class BlobStore,Qdrant storageStyle
    class Unstructured,SmolDocling,Embedding,Docnet pythonStyle
    class PrivatePdf ulStyle
    class RAG kbStyle
    class BggExtract sgcStyle
    class Notif unStyle

              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"invalid-uuid\",\n  \"query\": \"test query\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/knowledge-base/search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "knowledge-base", "search"]

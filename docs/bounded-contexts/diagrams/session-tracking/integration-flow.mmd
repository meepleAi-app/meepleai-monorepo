graph TB
    subgraph ST["📈 SessionTracking Context"]
        SessionMgmt[Session Management]
        NoteSys[Note System]
        DeckMgmt[Deck Management]
        DiceRolls[Dice Rolling]
        Scoring[Score Tracking]
        SSE[SSE Streaming]
    end

    subgraph GM["🎮 GameManagement Context"]
        Game[Game Catalog]
        FullSession[Full Game Sessions]
    end

    subgraph UL["📚 UserLibrary Context"]
        PlayHistory[Play History]
    end

    subgraph Admin["📊 Administration Context"]
        Analytics[Session Analytics]
    end

    subgraph Cache["💾 Real-Time Infrastructure"]
        Redis[Redis Pub/Sub]
    end

    subgraph Clients["👥 Web Clients"]
        WebClient[Browser SSE Connections]
    end

    %% Event-Driven Communication
    SessionMgmt -->|SessionCreatedEvent| Analytics
    SessionMgmt -->|SessionFinalizedEvent| FullSession
    SessionMgmt -->|SessionFinalizedEvent| PlayHistory
    Scoring -->|ScoreUpdatedEvent| SSE
    DiceRolls -->|DiceRolledEvent| SSE
    DeckMgmt -->|CardDrawnEvent| SSE
    NoteSys -->|NoteRevealedEvent| SSE

    %% Direct Dependencies
    SessionMgmt -.->|FK: GameId| Game
    SessionMgmt -.->|FK: UserId| Admin

    %% Real-Time Communication
    SSE -.->|Publish events| Redis
    Redis -.->|Subscribe to channels| WebClient

    %% Cryptographic Services
    DiceRolls -.->|CSPRNG randomness| RNG[System.Security.Cryptography]
    DeckMgmt -.->|Fisher-Yates shuffle| RNG
    NoteSys -.->|AES-256 encryption| Crypto[Encryption Service]

    %% Styling
    classDef stStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef gmStyle fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    classDef ulStyle fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef adminStyle fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef cacheStyle fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    classDef clientStyle fill:#e3f2fd,stroke:#2196f3,stroke-width:2px

    class SessionMgmt,NoteSys,DeckMgmt,DiceRolls,Scoring,SSE stStyle
    class Game,FullSession gmStyle
    class PlayHistory ulStyle
    class Analytics adminStyle
    class Redis cacheStyle
    class WebClient clientStyle

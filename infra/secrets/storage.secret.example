# S3-Compatible Object Storage Credentials
# OPTIONAL - Info logged if missing (local file storage used as fallback)
# Copy this file to infra/secrets/storage.secret and fill in values
#
# RECOMMENDED: Cloudflare R2 (zero egress fees, EU jurisdiction, S3-compatible)
# Documentation: docs/04-deployment/r2-storage-configuration-guide.md
#
# Supported providers:
# - Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com (RECOMMENDED)
# - AWS S3: https://s3.amazonaws.com
# - MinIO: http://your-minio-server:9000
# - DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# - Backblaze B2: https://s3.us-west-004.backblazeb2.com

# ==============================================================================
# CLOUDFLARE R2 CONFIGURATION (Recommended for MeepleAI)
# ==============================================================================
# Get credentials from: https://dash.cloudflare.com/?to=/:account/r2/api-tokens
#
# 1. Log in to Cloudflare Dashboard
# 2. Go to R2 -> Manage R2 API Tokens
# 3. Create API Token with "Object Read & Write" permissions
# 4. Copy Access Key ID and Secret Access Key

# Your Cloudflare Account ID (found in dashboard URL or R2 overview)
S3_ACCOUNT_ID=your_cloudflare_account_id

# R2 API Token (from step 3 above - used for Cloudflare API management, not S3 access)
S3_TOKEN_KEY=change_me_r2_api_token

# R2 S3-compatible credentials (from step 4 above - used for S3 API access)
S3_ACCESS_KEY=change_me_r2_access_key
S3_SECRET_KEY=change_me_r2_secret_key

# Primary bucket for PDF uploads
# Create bucket in R2 dashboard with EU jurisdiction for GDPR compliance
S3_BUCKET_NAME=meepleai-uploads

# Region: Use "auto" for Cloudflare R2, or specific region for other providers
S3_REGION=auto

# Endpoint URL (replace {account_id} with your actual Cloudflare Account ID)
# Format for R2: https://{account_id}.r2.cloudflarestorage.com
S3_ENDPOINT=change_me_r2_endpoint

# ==============================================================================
# BACKUP STORAGE CONFIGURATION (for PostgreSQL backups via n8n)
# ==============================================================================
# Can use same credentials with different bucket, or separate backup-specific credentials

# Backup bucket (create separate bucket for database backups)
S3_BACKUP_ACCESS_KEY=your_backup_access_key
S3_BACKUP_SECRET_KEY=your_backup_secret_key
S3_BACKUP_BUCKET_NAME=meepleai-backups
S3_BACKUP_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com

# Retention policy (days to keep backups before auto-deletion)
S3_BACKUP_RETENTION_DAYS=30

# ==============================================================================
# LOCAL MINIO CONFIGURATION (for docker-compose MinIO service)
# ==============================================================================
# Used by minio and minio-init services in docker-compose.yml
# Only needed if running local MinIO (not when using Cloudflare R2 directly)

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

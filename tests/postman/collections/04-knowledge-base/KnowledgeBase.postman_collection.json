              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{game_id}}\",\n  \"query\": \"setup phase\",\n  \"topK\": 3,\n  \"minScore\": 0.6,\n  \"searchMode\": \"vector\",\n  \"language\": \"en\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/knowledge-base/search",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "knowledge-base", "search"]
            },
            "description": "Test pure vector search (semantic similarity only).\n\n**Uses**: VectorSearchDomainService with cosine similarity"
          },
          "response": []
        }
      ],
      "description": "Hybrid search endpoints (ADR-001: Hybrid RAG)"
    },
    {
      "name": "Q&A Agent",
      "item": [
        {
          "name": "Ask Question (Non-Streaming)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Answer is returned', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.answer).to.exist;",
                  "    pm.expect(jsonData.snippets).to.be.an('array');",
                  "    pm.expect(jsonData.confidence).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Confidence scores are present', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.searchConfidence).to.be.a('number');",
                  "    pm.expect(jsonData.llmConfidence).to.be.a('number');",
                  "    pm.expect(jsonData.overallConfidence).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Confidence scores in valid range (0-1)', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.searchConfidence).to.be.within(0, 1);",
                  "    pm.expect(jsonData.llmConfidence).to.be.within(0, 1);",
                  "    pm.expect(jsonData.overallConfidence).to.be.within(0, 1);",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{game_id}}\",\n  \"query\": \"How do you win the game?\",\n  \"searchMode\": \"Hybrid\",\n  \"chatId\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/agents/qa?generateFollowUps=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents", "qa"],
              "query": [
                {
                  "key": "generateFollowUps",
                  "value": "true"
                }
              ]
            },
            "description": "Ask a question about game rules using RAG (Retrieval-Augmented Generation).\n\n**Query**: QaAgentQuery\n**Handler**: QaAgentQueryHandler\n**Context**: KnowledgeBase\n**Pipeline**: Search → Build Prompt → LLM → Quality Tracking\n**Validation**: 5-layer (confidence ≥0.70, citation verify, forbidden keywords)"
          },
          "response": []
        },

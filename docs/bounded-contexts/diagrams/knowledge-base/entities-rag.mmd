erDiagram
    ChatThread ||--o{ ChatMessage : "contains"
    ChatMessage ||--o{ Source : "cites"
    EmbeddingChunk }o--|| Document : "from"

    ChatThread {
        Guid Id PK
        Guid UserId FK
        Guid GameId FK
        Guid AgentId FK
        string Title
        string Status
        DateTime CreatedAt
        DateTime LastMessageAt
    }

    ChatMessage {
        Guid Id PK
        Guid ChatThreadId FK
        string Content
        string Role
        double ConfidenceScore
        DateTime CreatedAt
    }

    Source {
        Guid Id PK
        Guid ChatMessageId FK
        string Content
        int PageNumber
        double Score
        string Document
    }

    EmbeddingChunk {
        Guid Id PK
        Guid DocumentId FK
        string Content
        int PageNumber
        int ChunkIndex
        float-array Embedding
        DateTime CreatedAt
    }

    Document {
        Guid Id PK
        Guid GameId FK
        string FileName
        string Status
    }

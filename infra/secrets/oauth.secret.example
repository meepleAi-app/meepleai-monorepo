# OAuth Provider Credentials (Google, GitHub, Discord)
# OPTIONAL - Info logged if missing (OAuth login disabled)
# Copy this file to infra/secrets/oauth.secret and fill in values

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_from_console
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

# Discord OAuth
# Get credentials from: https://discord.com/developers/applications
DISCORD_OAUTH_CLIENT_ID=your_discord_client_id
DISCORD_OAUTH_CLIENT_SECRET=your_discord_client_secret

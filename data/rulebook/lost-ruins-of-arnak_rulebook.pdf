:root {
	--primary-color: hsla(43.199999999999996, 98.43%, 75.10%, 1.00);
	--secondary-color: hsla(145.99999999999997, 46.88%, 25.10%, 1.00);
}

.color--primary {
	color: var(--primary-color) !important;
}

.color--secondary {
	color: var(--secondary-color)  !important;
}

.editor p,
.editor ul>li {
	font-size: clamp(1rem, 2vw, 1.125rem);
  letter-spacing: clamp(-0.03rem, 2vw, -0.03375rem);
  line-height: 1.8;
}

.editor ul>li {
	margin-bottom: 0;
}

.editor > * {
	margin-bottom: clamp(1.5rem, 2vw, 2rem);
}

@media screen and (min-width: 62rem) {
  .editor--components ul {
    columns: 2;
  }
}

.file {
transition: var(--global-transition);
text-transform: none;
}

/*.file .color--secondary {
	color: #000000 !important;
}*/

.file:hover {
	border-color: var(--secondary-color);
}

.header__nav {
	transition: var(--global-transition);
}

.file.radius.radius--small,
.file--primary {
    background-color: var(--secondary-color);
    border-color: var(--secondary-color); 
            .icon,    
    .text {

      color: #ffffff !important;
    }      
    
    &:hover {
    background-color: transparent;
                    .icon,
        .text {

          color: #000000 !important;
        }
    }    
}

.file.radius.radius--small:not(.file--primary) .icon {
	display: none;
}

.file--lang {
	
  
  &:not(.js-mission-lang) {
	  padding: 0.5rem 1.5rem !important;
    background-color: var(--secondary-color);
    border-color: var(--secondary-color);  
    
    .text {
      color: #ffffff !important;
    }   
    
    &:hover {

        .text {
          color: #000000 !important;
        }
    }
  }
 
  
  &:hover {
	  background-color: var(--primary-color);
    

  }
}

.file--lang .icon,
.file--lang img{
	display: none;
}

</style></div><header class="header"><div class="js-header w-embed w-script"><script>
document.addEventListener("DOMContentLoaded", () => {
    const menuHandlers = document.querySelectorAll(".js-menu-handler");
    const menu = document.getElementById("menu");
    const offcanvas = document.querySelector(".offcanvas");
    const submenuHandlers = document.querySelectorAll(".js-submenu-handler");
    const offcanvasDefault = document.querySelector(".js-offcanvas-default");
    const offcanvasBack = document.querySelector(".js-offcanvas-back");
    
    if (menuHandlers.length > 0 && menu) {
        menuHandlers.forEach((handler) => {
            handler.addEventListener("click", () => {
                menu.classList.toggle("is--open");
            });
        });

        menu.addEventListener("click", (event) => {
            if (!offcanvas.contains(event.target)) {
                menu.classList.remove("is--open");
            }
        });
    }
    if (submenuHandlers.length > 0) {
        submenuHandlers.forEach((handler) => {
            handler.addEventListener("click", (event) => {
                event.preventDefault();
                const submenu = handler.closest(".menu__item").querySelector(".js-subnav");
                if (submenu) {
                    const isOpen = submenu.classList.toggle("is--open");
                    if (isOpen) {
                        offcanvasDefault?.classList.add("hide");
                        offcanvasBack?.classList.remove("hide");
                    } else {
                        offcanvasDefault?.classList.remove("hide");
                        offcanvasBack?.classList.add("hide");
                    }
                }
                event.stopPropagation();
            });
        });
    }
    if (offcanvasBack) {
        offcanvasBack.addEventListener("click", () => {
            const openSubmenus = document.querySelectorAll(".js-subnav.is--open");
            openSubmenus.forEach((submenu) => {
                submenu.classList.remove("is--open");
            });
            offcanvasDefault?.classList.remove("hide");
            offcanvasBack?.classList.add("hide");
        });
    }
});
</script>

<script>
document.addEventListener('scroll', () => {
    const header = document.querySelector('.js-sticky-header');
    if (window.scrollY > 140) {
        header.classList.add('is--sticky');
    } else {
        header.classList.remove('is--sticky');
    }
});
</script>


<script>
document.addEventListener('DOMContentLoaded', function () {
  const header = document.querySelector('.header');
  const searchHandler = document.querySelector('.js-search-handler');
  const headerSearch = document.querySelector('.header__search');

  if (searchHandler && headerSearch) {
    searchHandler.addEventListener('click', function (e) {
      e.stopPropagation(); // zabrání bublině kliknutí nahoru
      header.classList.toggle('is--white');
      headerSearch.classList.toggle('is--open');
    });

    // Zavře, když klikneš mimo .header
    document.addEventListener('click', function (e) {
      if (!header.contains(e.target)) {
        header.classList.remove('is--white');
        headerSearch.classList.remove('is--open');
      }
    });

    // Pokud by se klikalo i uvnitř .header, zabráníme zavření
    header.addEventListener('click', function (e) {
      e.stopPropagation();
    });
  }
});
</script></div><div class="css-header w-embed"><style>
.header,
.header__search {
	transition: var(--global-transition);
}

.menu__link,
.button--search,
.button--search .icon,
.button--menu,
.button--menu .icon {
	color: var(--menu-color);
}

.menu__link.w--current {
	color: #7A7A7A;
}

.language__link {
	transition: var(--global-transition);
}

.language__link:hover,
.language__link:active {
	mix-blend-mode: unset;
  color: var(--base-color-brand--primary-800);
}

.offcanvas,
.offcanvas__wrapper {
	transition: var(--global-transition);
}

.offcanvas__wrapper,
.nav--sub {
	transform: translate(100%, 0);
}

.overlay.is--open .offcanvas__wrapper,
.nav--sub.is--open {
	transition: var(--global-transition);
	transform: translate(0, 0);
}

@media screen and (min-width: 62rem) {
  .icon--offcanvas {
    width: 2.25rem;
    height: 2.25rem;
  }
}

.header.is--sticky,
.header.is--white {
	box-shadow: 0px 16px 24px 0px rgba(0, 0, 0, 0.06);
}

.header.is--sticky {
  .logo__image {
  	display: none;
  }
  
  .logo__inline {
  	display: block;
  }
}

.header.is--white {
	  border-bottom-left-radius: var(--radius-4);
    border-bottom-right-radius: var(--radius-4);
}

.header.is--white .menu__link,
.header.is--white .button--search,
.header.is--white .button--search .icon,
.header.is--white .button--menu,
.header.is--white .button--menu .icon,
.header.is--sticky .menu__link,
.header.is--sticky .button--search,
.header.is--sticky .button--search .icon,
.header.is--sticky .button--menu,
.header.is--sticky .button--menu .icon {
	color: #000000;
}
</style></div><div class="w-layout-hflex navbar"><div class="w-layout-hflex navbar__left"><a href="/" class="logo w-inline-block"><img width="80" height="98" alt="" src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8869/67d17a45b4e1484b40ea8b47_CGE%20game%20logo.webp" loading="lazy" class="logo__image"/><img width="80" height="98" src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/67d17a45b4e1484b40ea8ae6_cge_logo.svg" loading="lazy" alt="Lost Ruins of Arnak" class="logo__image w-condition-invisible"/><div class="logo__inline w-embed"><svg xmlns="http://www.w3.org/2000/svg" xml:space="preserve" style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2" viewBox="0 0 228 83"><path d="M69.3 114.35c-11.11 0-21.23-4.53-28.5-11.81a40.15 40.15 0 0 1-11.75-28.43c0-11.09 4.51-21.18 11.78-28.44a40.097 40.097 0 0 1 28.46-11.79c11.06 0 21.14 4.49 28.4 11.73a6.494 6.494 0 0 1 .02 9.18 6.485 6.485 0 0 1-9.18.01c-4.95-4.92-11.71-7.94-19.24-7.95-7.55 0-14.32 3.05-19.28 7.99-4.94 4.95-7.97 11.72-7.98 19.26 0 7.54 3.03 14.3 7.96 19.25 4.95 4.95 11.74 8 19.29 8.01 7.56 0 14.34-3.05 19.29-8.01 2.53-2.54 6.64-2.54 9.18 0a6.488 6.488 0 0 1 0 9.19 40.181 40.181 0 0 1-28.47 11.81h.02ZM170.14 45.6a6.497 6.497 0 0 1-4.59 11.1 6.496 6.496 0 0 1-4.59-1.9c-4.95-4.92-11.7-7.94-19.23-7.95-7.55 0-14.32 3.05-19.28 7.99-4.94 4.95-7.97 11.72-7.98 19.26 0 7.54 3.03 14.3 7.96 19.25 4.95 4.95 11.74 8 19.3 8.01 7.56 0 14.34-3.05 19.29-8.01 3.46-3.48 5.98-7.85 7.18-12.75h-30.06c-3.566 0-6.5-2.934-6.5-6.5 0-3.59 2.91-6.49 6.5-6.49h37.34c1.71 0 3.38.69 4.59 1.9a6.556 6.556 0 0 1 1.91 4.59c0 11.08-4.51 21.17-11.76 28.43a40.202 40.202 0 0 1-28.48 11.81c-11.11 0-21.23-4.53-28.49-11.81a40.204 40.204 0 0 1-11.76-28.43c0-11.09 4.51-21.18 11.78-28.44a40.118 40.118 0 0 1 28.47-11.79c11.06 0 21.14 4.49 28.4 11.73ZM214.19 114.35c-11.11 0-21.23-4.53-28.49-11.81-2.513-2.524-2.513-6.666 0-9.19 2.54-2.53 6.65-2.53 9.18 0 4.95 4.95 11.73 8 19.29 8.01 7.56 0 14.34-3.05 19.
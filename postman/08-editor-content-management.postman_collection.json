        },
        {
          "name": "Add FAQ",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Can I trade on another player's turn?\",\n  \"answer\": \"No, trading is only allowed during your own turn. However, you can negotiate future trades.\",\n  \"category\": \"Trading\",\n  \"tags\": [\"trading\", \"turns\", \"rules\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/faq",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "faq"]
            },
            "description": "Add a new FAQ entry"
          }
        },
        {
          "name": "Update FAQ",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Can I trade on another player's turn?\",\n  \"answer\": \"Updated: Trading is only allowed during your own turn...\",\n  \"category\": \"Trading\",\n  \"tags\": [\"trading\", \"turns\", \"rules\", \"updated\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/faq/{{faqId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "faq", "{{faqId}}"]
            },
            "description": "Update an FAQ entry"
          }
        },
        {
          "name": "Delete FAQ",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/faq/{{faqId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "faq", "{{faqId}}"]
            },
            "description": "Delete an FAQ entry"
          }
        }
      ]
    },

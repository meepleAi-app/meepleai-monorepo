{
  "info": {
    "_postman_id": "meepleai-api-tests-v2",
    "name": "MeepleAI API Tests",
    "description": "Comprehensive API tests for MeepleAI backend.\n\n**Test Groups:**\n1. Health Checks - Basic API health verification\n2. Authentication - User registration, login, session management\n3. Game Management - Game CRUD operations\n4. KnowledgeBase - RAG search and Q&A (requires game data)\n\n**Note:** Tests are designed to be idempotent and CI-friendly.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "healthBaseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "testEmail",
      "value": "",
      "type": "string"
    },
    {
      "key": "testPassword",
      "value": "TestPassword123!",
      "type": "string"
    },
    {
      "key": "testUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testGameId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health Checks",
      "description": "Basic health verification endpoints - no authentication required",
      "item": [
        {
          "name": "Health - Ready",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response indicates healthy status', function() {",
                  "    // Health check returns plain text 'Healthy' not JSON",
                  "    pm.expect(pm.response.text()).to.include('Healthy');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{healthBaseUrl}}/health/ready",
              "host": ["{{healthBaseUrl}}"],
              "path": ["health", "ready"]
            }
          }
        },
        {
          "name": "Health - Live",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response indicates healthy status', function() {",
                  "    // Health check returns plain text 'Healthy' not JSON",
                  "    pm.expect(pm.response.text()).to.include('Healthy');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{healthBaseUrl}}/health/live",
              "host": ["{{healthBaseUrl}}"],
              "path": ["health", "live"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Authentication",
      "description": "User registration, login, and session management",
      "item": [
        {
          "name": "Register Test User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate unique email for this test run",
                  "const timestamp = Date.now();",
                  "const email = `test-${timestamp}@example.com`;",
                  "pm.collectionVariables.set('testEmail', email);",
                  "console.log('Generated test email:', email);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 (successful registration)', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User data is returned', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.exist;",
                  "    pm.expect(json.user.id).to.exist;",
                  "    pm.expect(json.user.email).to.exist;",
                  "    pm.collectionVariables.set('testUserId', json.user.id);",
                  "});",
                  "",
                  "pm.test('Session cookie is set', function() {",
                  "    pm.expect(pm.cookies.has('meepleai_session')).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"displayName\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User data matches registered user', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.exist;",
                  "    pm.expect(json.user.email).to.equal(pm.collectionVariables.get('testEmail'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Get Session Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Session info is returned', function() {",
                  "    const json = pm.response.json();",
                  "    // Note: API uses PascalCase (PropertyNamingPolicy = null)",
                  "    pm.expect(json.ExpiresAt).to.exist;",
                  "    pm.expect(json.RemainingMinutes).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/session/status",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "session", "status"]

@startuml
title Component Architecture (API + Services + Data)

package API {
  [AiEndpoints] --> (IRagService)
  [AiEndpoints] --> (IStreamingRagService)
  [AiEndpoints] --> (IStreamingQaService)
  [AiEndpoints] --> (ChatService)
  [AiEndpoints] --> (AiRequestLogService)
  [AiEndpoints] --> (IResponseQualityService)
  [AiEndpoints] --> (IFollowUpQuestionService)
  [AiEndpoints] --> (IFeatureFlagService)
  [AiEndpoints] --> (IBggApiService)
  [AiEndpoints] --> (IChessAgentService)
  [AiEndpoints] --> (IChessKnowledgeService)
}

database "PostgreSQL" as PG
cloud "Qdrant (Vector DB)" as VDB
queue "SSE Stream" as SSE

(IRagService) --> VDB
(IStreamingQaService) ..> SSE
(ChatService) --> PG
(AiRequestLogService) --> PG
(IChessKnowledgeService) --> PG
(IBggApiService) ..> "BoardGameGeek API"

' Entities persisted in PG
[EF Core Entities] --> PG

' MCP servers (Python)
package MCP {
  [playwright server] ..> API : automation/testing
}

@enduml

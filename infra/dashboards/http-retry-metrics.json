{
  "dashboard": {
    "title": "HTTP Retry & Circuit Breaker Metrics",
    "tags": ["http", "retry", "circuit-breaker", "resilience"],
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 1,
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Total Retry Attempts",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "http_client_retries_total",
            "legendFormat": "Total Retries"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 2,
        "title": "Success Rate After Retry",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "http_client_success_after_retry_total / http_client_retries_total * 100",
            "legendFormat": "Success %"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "percent"
        }
      },
      {
        "id": 3,
        "title": "Failed After All Retries",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "http_client_failed_after_retry_total",
            "legendFormat": "Failed"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      },
      {
        "id": 4,
        "title": "Average Retry Delay",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "http_client_retry_delay_avg_ms",
            "legendFormat": "Avg Delay"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "ms"
        }
      },
      {
        "id": 5,
        "title": "Retry Attempts Over Time",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(http_client_retries_total[5m])",
            "legendFormat": "Retry Rate"
          },
          {
            "expr": "rate(http_client_success_after_retry_total[5m])",
            "legendFormat": "Success Rate"
          },
          {
            "expr": "rate(http_client_failed_after_retry_total[5m])",
            "legendFormat": "Failure Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 6,
        "title": "Retries by Status Code",
        "type": "piechart",
        "gridPos": { "x": 12, "y": 4, "w": 6, "h": 8 },
        "targets": [
          {
            "expr": "http_client_retries_by_status",
            "legendFormat": "{{status_code}}"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 7,
        "title": "Top 10 Endpoints by Retry Count",
        "type": "table",
        "gridPos": { "x": 18, "y": 4, "w": 6, "h": 8 },
        "targets": [
          {
            "expr": "topk(10, http_client_retries_by_endpoint)",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "indexByName": {
                "endpoint": 0,
                "Value": 1
              },
              "renameByName": {
                "endpoint": "Endpoint",
                "Value": "Retry Count"
              }
            }
          }
        ]
      },
      {
        "id": 8,
        "title": "Circuit Breaker States",
        "type": "stat",
        "gridPos": { "x": 0, "y": 12, "w": 8, "h": 4 },
        "targets": [
          {
            "expr": "count(http_circuit_breaker_state == 0)",
            "legendFormat": "CLOSED"
          },
          {
            "expr": "count(http_circuit_breaker_state == 1)",
            "legendFormat": "HALF_OPEN"
          },
          {
            "expr": "count(http_circuit_breaker_state == 2)",
            "legendFormat": "OPEN"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "background",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      },
      {
        "id": 9,
        "title": "Circuit Breaker Requests & Failures",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
        "targets": [
          {
            "expr": "rate(http_circuit_breaker_requests_total[5m])",
            "legendFormat": "{{endpoint}} - Requests"
          },
          {
            "expr": "rate(http_circuit_breaker_failures_total[5m])",
            "legendFormat": "{{endpoint}} - Failures"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 10,
        "title": "Circuit Breaker State Timeline",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
        "targets": [
          {
            "expr": "http_circuit_breaker_state",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "stepAfter",
              "fillOpacity": 0
            },
            "mappings": [
              { "value": 0, "text": "CLOSED", "color": "green" },
              { "value": 1, "text": "HALF_OPEN", "color": "yellow" },
              { "value": 2, "text": "OPEN", "color": "red" }
            ]
          }
        }
      }
    ],
    "schemaVersion": 36,
    "version": 1,
    "description": "Dashboard for monitoring HTTP retry logic, exponential backoff, and circuit breaker pattern. Tracks retry attempts, success/failure rates, delays, and circuit breaker states across endpoints."
  }
}

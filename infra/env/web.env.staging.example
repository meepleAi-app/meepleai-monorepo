# Web (Next.js) Environment - Staging
# Production-like configuration for QA testing
#
# USAGE:
#   cp web.env.staging.example web.env.staging
#   vim web.env.staging  # Replace <REPLACE_*>

# API Backend URL (visible to client browser)
NEXT_PUBLIC_API_BASE=<REPLACE_WITH_STAGING_API_URL>
# Example: https://staging-api.meepleai.dev

# Tenant ID
NEXT_PUBLIC_TENANT_ID=staging

# Sentry Error Tracking (recommended for staging)
NEXT_PUBLIC_SENTRY_DSN=<REPLACE_WITH_SENTRY_DSN>
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
SENTRY_ORG=<REPLACE_WITH_SENTRY_ORG>
SENTRY_PROJECT=<REPLACE_WITH_SENTRY_PROJECT>
# SENTRY_AUTH_TOKEN in Docker Secret or CI variable

# Resilience Configuration (production-like)
NEXT_PUBLIC_RETRY_ENABLED=true
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=3
NEXT_PUBLIC_RETRY_BASE_DELAY=1000
NEXT_PUBLIC_RETRY_MAX_DELAY=10000

NEXT_PUBLIC_CIRCUIT_BREAKER_ENABLED=true
NEXT_PUBLIC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
NEXT_PUBLIC_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
NEXT_PUBLIC_CIRCUIT_BREAKER_TIMEOUT=60000

# Request Deduplication
NEXT_PUBLIC_REQUEST_DEDUP_ENABLED=true
NEXT_PUBLIC_REQUEST_DEDUP_TTL=100

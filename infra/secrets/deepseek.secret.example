# DeepSeek API Credentials
# IMPORTANT - Warning logged if missing (reduced LLM functionality)
# Copy this file to infra/secrets/deepseek.secret and fill in values
# Get API key from: https://platform.deepseek.com/api_keys

DEEPSEEK_API_KEY=sk-change_me_get_from_platform_deepseek_com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

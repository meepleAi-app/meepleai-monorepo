{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Authentication": {
    "SessionCookie": {
      "Secure": true,
      "SameSite": "Strict",
      "HttpOnly": true
    },
    "SessionManagement": {
      "InactivityTimeoutDays": 30,
      "AutoRevocationIntervalHours": 1
    }
  },
  "HybridCache": {
    "EnableL2Cache": true,
    "MaximumPayloadBytes": 10485760,
    "DefaultExpiration": "24:00:00",
    "L2Timeout": "00:00:02",
    "MaxConcurrentFactories": 1,
    "EnableTags": true,
    "MaxTagsPerEntry": 10
  }
}

    [Fact]
    public void Constructor_WhenNoProviderConfigured_ShouldDefaultToOllama()
    {
        // Arrange
        var configMock = new Mock<IConfiguration>();
        configMock.Setup(c => c["EMBEDDING_PROVIDER"]).Returns((string?)null);

        // Act
        var service = new QdrantService(
            _collectionManagerMock.Object,
            _vectorIndexerMock.Object,
            _vectorSearcherMock.Object,
            configMock.Object,
            _mockLogger.Object);

        // Assert - Service should be created successfully with default
        Assert.NotNull(service);
    }

    #endregion

    #region CollectionExistsAsync Tests

    [Fact]
    public async Task CollectionExistsAsync_WhenCollectionExists_ShouldReturnTrue()
    {
        // Arrange
        _collectionManagerMock
            .Setup(x => x.CollectionExistsAsync("meepleai_documents", It.IsAny<CancellationToken>()))
            .ReturnsAsync(true);

        // Act
        var result = await _service.CollectionExistsAsync();

        // Assert
        Assert.True(result);
        _collectionManagerMock.Verify(x => x.CollectionExistsAsync("meepleai_documents", It.IsAny<CancellationToken>()), Times.Once);
    }

    [Fact]
    public async Task CollectionExistsAsync_WhenCollectionDoesNotExist_ShouldReturnFalse()
    {
        // Arrange
        _mockClient
            .Setup(x => x.ListCollectionsAsync(It.IsAny<CancellationToken>()))
            .ReturnsAsync(new[] { "other_collection" });

        // Act
        var result = await _service.CollectionExistsAsync();

        // Assert
        Assert.False(result);
    }

    [Fact]
    public async Task CollectionExistsAsync_WhenCancellationRequested_ShouldPropagateCancellation()
    {
        // Arrange
        var cts = new CancellationTokenSource();
        cts.Cancel();

        _mockClient
            .Setup(x => x.ListCollectionsAsync(It.IsAny<CancellationToken>()))
            .ThrowsAsync(new OperationCanceledException());

        // Act & Assert
        await Assert.ThrowsAsync<OperationCanceledException>(
            () => _service.CollectionExistsAsync(cts.Token));
    }

    [Fact]
    public async Task CollectionExistsAsync_WhenQdrantFails_ShouldPropagateException()
    {
        // Arrange
        _mockClient
            .Setup(x => x.ListCollectionsAsync(It.IsAny<CancellationToken>()))
            .ThrowsAsync(new InvalidOperationException("Qdrant connection failed"));

        // Act & Assert
        await Assert.ThrowsAsync<InvalidOperationException>(
            () => _service.CollectionExistsAsync());
    }

    #endregion

    #region EnsureCollectionExistsAsync Tests

    [Fact]
    public async Task EnsureCollectionExistsAsync_WhenCollectionExists_ShouldNotCreateCollection()
    {
        // Arrange
        _mockClient
            .Setup(x => x.ListCollectionsAsync(It.IsAny<CancellationToken>()))
            .ReturnsAsync(new[] { "meepleai_documents" });

        // Act
        await _service.EnsureCollectionExistsAsync();

        // Assert
        _mockClient.Verify(x => x.ListCollectionsAsync(It.IsAny<CancellationToken>()), Times.Once);
        _mockClient.Verify(x => x.CreateCollectionAsync(
            It.IsAny<string>(),
            It.IsAny<VectorParams>(),
            It.IsAny<CancellationToken>()), Times.Never);
    }

    [Fact]
    public async Task EnsureCollectionExistsAsync_WhenCollectionDoesNotExist_ShouldCreateCollection()
    {
        // Arrange
        _mockClient
            .Setup(x => x.ListCollectionsAsync(It.IsAny<CancellationToken>()))
            .ReturnsAsync(Array.Empty<string>());

        _mockClient
            .Setup(x => x.CreateCollectionAsync(
                "meepleai_documents",
                It.Is<VectorParams>(v => v.Size == 768 && v.Distance == Distance.Cosine),
                It.IsAny<CancellationToken>()))
            .Returns(Task.CompletedTask);

        _mockClient
            .Setup(x => x.CreatePayloadIndexAsync(
                It.IsAny<string>(),
                It.IsAny<string>(),
                It.IsAny<PayloadSchemaType>(),
                It.IsAny<CancellationToken>()))
            .Returns(Task.CompletedTask);

        // Act
        await _service.EnsureCollectionExistsAsync();

        // Assert
        _mockClient.Verify(x => x.CreateCollectionAsync(
            "meepleai_documents",
            It.Is<VectorParams>(v => v.Size == 768 && v.Distance == Distance.Cosine),
            It.IsAny<CancellationToken>()), Times.Once);

        // Verify payload indexes are created
        _mockClient.Verify(x => x.CreatePayloadIndexAsync(
            "meepleai_documents",
            "game_id",
            PayloadSchemaType.Keyword,
            It.IsAny<CancellationToken>()), Times.Once);

        _mockClient.Verify(x => x.CreatePayloadIndexAsync(
            "meepleai_documents",
            "pdf_id",
            PayloadSchemaType.Keyword,
            It.IsAny<CancellationToken>()), Times.Once);

        _mockClient.Verify(x => x.CreatePayloadIndexAsync(
            "meepleai_documents",
            "category",
            PayloadSchemaType.Keyword,
            It.IsAny<CancellationToken>()), Times.Once);
    }

    [Fact]
    public async Task EnsureCollectionExistsAsync_WhenCalledMultipleTimes_ShouldBeIdempotent()
    {
        // Arrange
        var callCount = 0;
        _mockClient
            .Setup(x => x.ListCollectionsAsync(It.IsAny<CancellationToken>()))
            .ReturnsAsync(() =>
            {
                callCount++;
                return callCount == 1 ? Array.Empty<string>() : new[] { "meepleai_documents" };
            });

        _mockClient
            .Setup(x => x.CreateCollectionAsync(
                It.IsAny<string>(),
                It.IsAny<VectorParams>(),
                It.IsAny<CancellationToken>()))
            .Returns(Task.CompletedTask);

        _mockClient
            .Setup(x => x.CreatePayloadIndexAsync(
                It.IsAny<string>(),
                It.IsAny<string>(),
                It.IsAny<PayloadSchemaType>(),
                It.IsAny<CancellationToken>()))
            .Returns(Task.CompletedTask);

        // Act
        await _service.EnsureCollectionExistsAsync();
        await _service.EnsureCollectionExistsAsync();
        await _service.EnsureCollectionExistsAsync();

        // Assert
        _mockClient.Verify(x => x.CreateCollectionAsync(
            It.IsAny<string>(),
            It.IsAny<VectorParams>(),
            It.IsAny<CancellationToken>()), Times.Once); // Only created once
    }

    #endregion

    #region IndexDocumentChunksAsync Tests

    [Fact]
    public async Task IndexDocumentChunksAsync_WhenValidChunks_ShouldIndexSuccessfully()
    {
        // Arrange
        var gameId = "test-game";
        var pdfId = "test-pdf";
        var chunks = new List<DocumentChunk>
        {
            new() { Text = "Test chunk 1", Embedding = new float[768], Page = 1, CharStart = 0, CharEnd = 12 },
            new() { Text = "Test chunk 2", Embedding = new float[768], Page = 2, CharStart = 0, CharEnd = 12 }
        };

        _mockClient
            .Setup(x => x.UpsertAsync(
                "meepleai_documents",
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()))
            .Returns(Task.CompletedTask);

        // Act
        var result = await _service.IndexDocumentChunksAsync(gameId, pdfId, chunks);

        // Assert
        Assert.True(result.Success);
        Assert.Null(result.ErrorMessage);
        Assert.Equal(2, result.IndexedCount);
        _mockClient.Verify(x => x.UpsertAsync(
            "meepleai_documents",
            It.Is<IReadOnlyList<PointStruct>>(points => points.Count == 2),
            It.IsAny<CancellationToken>()), Times.Once);
    }

    [Fact]
    public async Task IndexDocumentChunksAsync_WhenEmptyChunks_ShouldReturnFailure()
    {
        // Arrange
        var gameId = "test-game";
        var pdfId = "test-pdf";
        var chunks = new List<DocumentChunk>();

        // Act
        var result = await _service.IndexDocumentChunksAsync(gameId, pdfId, chunks);

        // Assert
        Assert.False(result.Success);
        Assert.Equal("No chunks to index", result.ErrorMessage);
        _mockClient.Verify(x => x.UpsertAsync(
            It.IsAny<string>(),
            It.IsAny<IReadOnlyList<PointStruct>>(),
            It.IsAny<CancellationToken>()), Times.Never);
    }

    [Fact]
    public async Task IndexDocumentChunksAsync_WhenNullChunks_ShouldReturnFailure()
    {
        // Arrange
        var gameId = "test-game";
        var pdfId = "test-pdf";
        List<DocumentChunk>? chunks = null;

        // Act
        var result = await _service.IndexDocumentChunksAsync(gameId, pdfId, chunks!);

        // Assert
        Assert.False(result.Success);
        Assert.Equal("No chunks to index", result.ErrorMessage);
    }

    [Fact]
    public async Task IndexDocumentChunksAsync_WhenLargeChunkBatch_ShouldIndexAllChunks()
    {
        // Arrange
        var gameId = "test-game";
        var pdfId = "test-pdf";
        var chunks = Enumerable.Range(1, 500)
            .Select(i => new DocumentChunk
            {
                Text = $"Chunk {i}",
                Embedding = new float[768],
                Page = i % 10 + 1,
                CharStart = 0,
                CharEnd = 10
            })
            .ToList();

        _mockClient
            .Setup(x => x.UpsertAsync(
                "meepleai_documents",
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()))
            .Returns(Task.CompletedTask);

        // Act
        var result = await _service.IndexDocumentChunksAsync(gameId, pdfId, chunks);

        // Assert
        Assert.True(result.Success);
        Assert.Equal(500, result.IndexedCount);
        _mockClient.Verify(x => x.UpsertAsync(
            "meepleai_documents",
            It.Is<IReadOnlyList<PointStruct>>(points => points.Count == 500),
            It.IsAny<CancellationToken>()), Times.Once);
    }

    [Fact]
    public async Task IndexDocumentChunksAsync_WhenQdrantFails_ShouldReturnFailure()
    {
        // Arrange
        var gameId = "test-game";
        var pdfId = "test-pdf";
        var chunks = new List<DocumentChunk>
        {
            new() { Text = "Test chunk", Embedding = new float[768], Page = 1, CharStart = 0, CharEnd = 10 }
        };

        _mockClient
            .Setup(x => x.UpsertAsync(
                "meepleai_documents",
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()))
            .ThrowsAsync(new InvalidOperationException("Qdrant connection failed"));

        // Act
        var result = await _service.IndexDocumentChunksAsync(gameId, pdfId, chunks);

        // Assert
        Assert.False(result.Success);
        Assert.Contains("Qdrant connection failed", result.ErrorMessage);
    }


{
  "version": "2.0.0",
  "tasks": [
    // .NET API Tasks
    {
      "label": "build-api",
      "type": "shell",
      "command": "dotnet",
      "args": ["build", "--configuration", "Debug"],
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean-api",
      "type": "shell",
      "command": "dotnet",
      "args": ["clean"],
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test-api",
      "type": "shell",
      "command": "dotnet",
      "args": ["test"],
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch-api",
      "type": "shell",
      "command": "dotnet",
      "args": ["watch", "run"],
      "options": {
        "cwd": "${workspaceFolder}/apps/api/src/Api"
      },
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    
    // Frontend Tasks
    {
      "label": "dev",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm build",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm test",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "problemMatcher": "$eslint-stylish"
    },
    
    // Database Tasks
    {
      "label": "ef-migrations-add",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "ef", "migrations", "add",
        "${input:migrationName}",
        "--project", "src/Api"
      ],
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "ef-database-update",
      "type": "shell",
      "command": "dotnet",
      "args": ["ef", "database", "update", "--project", "src/Api"],
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "problemMatcher": "$msCompile"
    },

    // Docker Tasks
    {
      "label": "docker-up",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "up", "-d"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "docker-up-dev",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "--profile", "dev", "up", "-d"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "docker-down",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "down"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "docker-down-volumes",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "down", "-v"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "docker-build-no-cache",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "build", "--no-cache", "--pull"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "docker-rebuild-all",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "up", "-d", "--build", "--force-recreate", "--no-cache"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "docker-logs",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "logs", "-f"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "docker-logs-api",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "logs", "-f", "api"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "docker-ps",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "ps"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "docker-restart-service",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-Command",
        "docker compose stop ${input:serviceName}; docker compose rm -f ${input:serviceName}; docker compose up -d ${input:serviceName}"
      ],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": []
    },
    {
      "label": "setup-secrets",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "setup-secrets.ps1", "-SaveGenerated"],
      "options": {
        "cwd": "${workspaceFolder}/infra/secrets"
      },
      "problemMatcher": []
    },

    // Infrastructure Tasks (Development)
    // Default: infra-start → infra-start-dev (recommended)
    {
      "label": "infra-start",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "start-dev.ps1"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "infra-start-minimal",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "start-minimal.ps1"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "infra-start-dev",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "start-dev.ps1"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "infra-start-full",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "start-full.ps1"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "infra-stop",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "stop.ps1"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "infra-status",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "ps"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "infra-logs",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "logs", "-f"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "infra-restart",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "restart"],
      "options": {
        "cwd": "${workspaceFolder}/infra"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },

    // Compound Tasks
    {
      "label": "build-all",
      "dependsOn": ["build-api", "build"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "test-all",
      "dependsOn": ["test-api", "test"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "start-all-dev",
      "dependsOn": ["docker-up", "watch-api", "dev"],
      "problemMatcher": []
    },
    {
      "label": "docker-fresh-start",
      "dependsOrder": "sequence",
      "dependsOn": ["docker-down-volumes", "setup-secrets", "docker-build-no-cache", "docker-up-dev"],
      "problemMatcher": []
    },
    {
      "label": "docker-quick-rebuild",
      "dependsOrder": "sequence",
      "dependsOn": ["docker-down", "docker-rebuild-all"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Migration name (e.g., AddUserTable)"
    },
    {
      "id": "serviceName",
      "type": "promptString",
      "description": "Service name (e.g., api, postgres, redis)"
    }
  ]
}
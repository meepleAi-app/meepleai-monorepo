# Continuous integration environment for MeepleAI API.
# Store the real values in your CI secret manager and expose them at runtime.
POSTGRES_USER=meeple
POSTGRES_PASSWORD=__SET_BY_CI_SECRET__
POSTGRES_DB=meepleai_ci

# REQUIRED: Database connection string (application will fail to start if not configured)
CONNECTIONSTRINGS__POSTGRES=Host=postgres;Port=5432;Database=meepleai_ci;Username=meeple;Password=__SET_BY_CI_SECRET__
OPENROUTER_API_KEY=__SET_BY_CI_SECRET__
JWT_ISSUER=https://api-ci.example.com
ALLOW_ORIGIN=https://web-ci.example.com
N8N_ENCRYPTION_KEY=__SET_BY_CI_SECRET__

# Bootstrap: Initial admin user configuration
# IMPORTANT: Set these via CI secret manager (GitHub Secrets, Azure Key Vault, etc.)
# Password requirements: minimum 8 characters, at least one uppercase letter, one digit
INITIAL_ADMIN_EMAIL=__SET_BY_CI_SECRET__
INITIAL_ADMIN_PASSWORD=__SET_BY_CI_SECRET__
INITIAL_ADMIN_DISPLAY_NAME=CI Administrator

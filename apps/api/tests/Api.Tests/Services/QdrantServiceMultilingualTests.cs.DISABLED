using Api.Services;
using Api.Services.Qdrant;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.Logging.Abstractions;
using Moq;
using Qdrant.Client;
using Qdrant.Client.Grpc;
using Xunit;

namespace Api.Tests.Services;

/// <summary>
/// AI-09: Multilingual tests for QdrantService language filtering
/// Tests language metadata storage and language-filtered searches
/// </summary>
public class QdrantServiceMultilingualTests
{
    private readonly Mock<IQdrantCollectionManager> _collectionManagerMock;
    private readonly Mock<IQdrantVectorIndexer> _vectorIndexerMock;
    private readonly Mock<IQdrantVectorSearcher> _vectorSearcherMock;
    private readonly Mock<IConfiguration> _configMock;
    private readonly QdrantService _service;

    public QdrantServiceMultilingualTests()
    {
        _collectionManagerMock = new Mock<IQdrantCollectionManager>();
        _vectorIndexerMock = new Mock<IQdrantVectorIndexer>();
        _vectorSearcherMock = new Mock<IQdrantVectorSearcher>();
        _configMock = new Mock<IConfiguration>();
        _configMock.Setup(c => c["EMBEDDING_PROVIDER"]).Returns("ollama");

        _service = new QdrantService(
            _collectionManagerMock.Object,
            _vectorIndexerMock.Object,
            _vectorSearcherMock.Object,
            _configMock.Object,
            NullLogger<QdrantService>.Instance
        );
    }

    #region Indexing with Language Metadata

    /// <summary>
    /// BDD Scenario: Index chunks with Italian language metadata
    /// Given: 2 document chunks in Italian
    /// When: IndexDocumentChunksAsync is called with language "it"
    /// Then: Each point's payload contains language field set to "it"
    /// </summary>
    [Fact]
    public async Task IndexDocumentChunksAsync_WithItalianLanguage_StoresLanguageMetadata()
    {
        // Arrange
        var chunks = CreateTestChunks(2);
        IReadOnlyList<PointStruct>? capturedPoints = null;

        // TODO: This test needs refactoring due to facade pattern changes
        // The QdrantService now delegates to specialized services
        _vectorIndexerMock
            .Setup(i => i.BuildPoints(
                It.IsAny<List<DocumentChunk>>(),
                It.IsAny<Dictionary<string, Value>>()))
            .Returns<List<DocumentChunk>, Dictionary<string, Value>>((chunks, payload) =>
            {
                capturedPoints = chunks.Select((chunk, i) => new PointStruct
                {
                    Payload = { payload }
                }).ToList();
                return capturedPoints;
            });

        _vectorIndexerMock
            .Setup(i => i.UpsertPointsAsync(
                "meepleai_documents",
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()))
            .Returns(Task.CompletedTask);

        // Act
        var result = await _service.IndexDocumentChunksAsync("chess", "pdf-001", chunks, "it");

        // Assert
        Assert.True(result.Success);
        Assert.NotNull(capturedPoints);
        Assert.Equal(2, capturedPoints.Count);
        Assert.All(capturedPoints, point =>
        {
            Assert.True(point.Payload.ContainsKey("language"));
            Assert.Equal("it", point.Payload["language"].StringValue);
        });
    }

    /// <summary>
    /// BDD Scenario: Index chunks for different languages in same game
    /// Given: Multiple PDFs in different languages for same game
    /// When: IndexDocumentChunksAsync is called with different language codes
    /// Then: Each PDF's chunks are tagged with correct language
    /// </summary>
    [Theory]
    [InlineData("en", "pdf-en")]
    [InlineData("it", "pdf-it")]
    [InlineData("de", "pdf-de")]
    [InlineData("fr", "pdf-fr")]
    [InlineData("es", "pdf-es")]
    public async Task IndexDocumentChunksAsync_MultipleLanguages_StoresCorrectMetadata(string language, string pdfId)
    {
        // Arrange
        var chunks = CreateTestChunks(1);
        string? capturedLanguage = null;

        _clientAdapterMock
            .Setup(c => c.UpsertAsync(
                It.IsAny<string>(),
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()))
            .Callback<string, IReadOnlyList<PointStruct>, CancellationToken>((_, points, _) =>
            {
                capturedLanguage = points[0].Payload["language"].StringValue;
            })
            .Returns(Task.CompletedTask);

        // Act
        var result = await _service.IndexDocumentChunksAsync("tic-tac-toe", pdfId, chunks, language);

        // Assert
        Assert.True(result.Success);
        Assert.Equal(language, capturedLanguage);
    }

    /// <summary>
    /// BDD Scenario: Index operation includes all required metadata fields
    /// Given: Document chunks with language "es"
    /// When: IndexDocumentChunksAsync is called
    /// Then: Payload includes game_id, pdf_id, language, text, page, chunk_index, char_start, char_end, indexed_at
    /// </summary>
    [Fact]
    public async Task IndexDocumentChunksAsync_WithLanguage_IncludesAllMetadataFields()
    {
        // Arrange
        var chunks = CreateTestChunks(1);
        IReadOnlyList<PointStruct>? capturedPoints = null;

        _clientAdapterMock
            .Setup(c => c.UpsertAsync(
                It.IsAny<string>(),
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()))
            .Callback<string, IReadOnlyList<PointStruct>, CancellationToken>((_, points, _) =>
            {
                capturedPoints = points;
            })
            .Returns(Task.CompletedTask);

        // Act
        await _service.IndexDocumentChunksAsync("chess", "pdf-es", chunks, "es");

        // Assert
        var payload = capturedPoints![0].Payload;
        Assert.True(payload.ContainsKey("game_id"));
        Assert.True(payload.ContainsKey("pdf_id"));
        Assert.True(payload.ContainsKey("language"));
        Assert.True(payload.ContainsKey("text"));
        Assert.True(payload.ContainsKey("page"));
        Assert.True(payload.ContainsKey("chunk_index"));
        Assert.True(payload.ContainsKey("char_start"));
        Assert.True(payload.ContainsKey("char_end"));
        Assert.True(payload.ContainsKey("indexed_at"));

        Assert.Equal("chess", payload["game_id"].StringValue);
        Assert.Equal("pdf-es", payload["pdf_id"].StringValue);
        Assert.Equal("es", payload["language"].StringValue);
    }

    #endregion

    #region Language-Filtered Search

    /// <summary>
    /// BDD Scenario: Search filters results by language
    /// Given: Qdrant contains documents in multiple languages
    /// When: SearchAsync is called with language "de"
    /// Then: Filter condition includes language match for "de"
    /// </summary>
    [Fact]
    public async Task SearchAsync_WithLanguage_AddsLanguageFilterCondition()
    {
        // Arrange
        var queryEmbedding = CreateTestEmbedding();
        Filter? capturedFilter = null;

        _clientAdapterMock
            .Setup(c => c.SearchAsync(
                "test_documents",
                It.IsAny<float[]>(),
                It.IsAny<Filter>(),
                It.IsAny<ulong>(),
                It.IsAny<CancellationToken>()))
            .Callback<string, float[], Filter, ulong, CancellationToken>((_, _, filter, _, _) =>
            {
                capturedFilter = filter;
            })
            .ReturnsAsync(new List<ScoredPoint>());

        // Act
        await _service.SearchAsync("chess", queryEmbedding, "de", limit: 5);

        // Assert
        Assert.NotNull(capturedFilter);
        Assert.Equal(2, capturedFilter.Must.Count); // game_id + language

        var gameIdCondition = capturedFilter.Must[0].Field;
        Assert.Equal("game_id", gameIdCondition.Key);
        Assert.Equal("chess", gameIdCondition.Match.Keyword);

        var languageCondition = capturedFilter.Must[1].Field;
        Assert.Equal("language", languageCondition.Key);
        Assert.Equal("de", languageCondition.Match.Keyword);
    }

    /// <summary>
    /// BDD Scenario: Search with different languages creates different filters
    /// Given: Same game with multilingual content
    /// When: SearchAsync is called with different language codes
    /// Then: Each search filters by corresponding language
    /// </summary>
    [Theory]
    [InlineData("en")]
    [InlineData("it")]
    [InlineData("de")]
    [InlineData("fr")]
    [InlineData("es")]
    public async Task SearchAsync_DifferentLanguages_CreatesCorrespondingFilters(string language)
    {
        // Arrange
        var queryEmbedding = CreateTestEmbedding();
        string? capturedLanguage = null;

        _clientAdapterMock
            .Setup(c => c.SearchAsync(
                It.IsAny<string>(),
                It.IsAny<float[]>(),
                It.IsAny<Filter>(),
                It.IsAny<ulong>(),
                It.IsAny<CancellationToken>()))
            .Callback<string, float[], Filter, ulong, CancellationToken>((_, _, filter, _, _) =>
            {
                var languageCondition = filter.Must[1].Field;
                capturedLanguage = languageCondition.Match.Keyword;
            })
            .ReturnsAsync(new List<ScoredPoint>());

        // Act
        await _service.SearchAsync("tic-tac-toe", queryEmbedding, language, limit: 10);

        // Assert
        Assert.Equal(language, capturedLanguage);
    }

    /// <summary>
    /// BDD Scenario: Search returns results with language metadata
    /// Given: Qdrant returns search results
    /// When: SearchAsync is called with language "it"
    /// Then: Results are successfully parsed and returned
    /// </summary>
    [Fact]
    public async Task SearchAsync_WithLanguage_ReturnsSearchResults()
    {
        // Arrange
        var queryEmbedding = CreateTestEmbedding();
        var scoredPoints = new List<ScoredPoint>
        {
            CreateScoredPoint("pdf-it-001", "Testo italiano", 1, 0, 0.95f),
            CreateScoredPoint("pdf-it-001", "Altro testo italiano", 1, 1, 0.88f)
        };

        _clientAdapterMock
            .Setup(c => c.SearchAsync(
                It.IsAny<string>(),
                It.IsAny<float[]>(),
                It.IsAny<Filter>(),
                It.IsAny<ulong>(),
                It.IsAny<CancellationToken>()))
            .ReturnsAsync(scoredPoints);

        // Act
        var result = await _service.SearchAsync("chess", queryEmbedding, "it", limit: 5);

        // Assert
        Assert.True(result.Success);
        Assert.Equal(2, result.Results.Count);
        Assert.Equal("Testo italiano", result.Results[0].Text);
        Assert.Equal(0.95f, result.Results[0].Score);
        Assert.Equal("pdf-it-001", result.Results[0].PdfId);
    }

    #endregion

    #region Edge Cases

    /// <summary>
    /// BDD Scenario: Index empty chunks list with language
    /// Given: Empty chunks list
    /// When: IndexDocumentChunksAsync is called with language
    /// Then: Returns failure without calling Qdrant
    /// </summary>
    [Fact]
    public async Task IndexDocumentChunksAsync_EmptyChunksWithLanguage_ReturnsFailure()
    {
        // Arrange
        var emptyChunks = new List<DocumentChunk>();

        // Act
        var result = await _service.IndexDocumentChunksAsync("game-1", "pdf-1", emptyChunks, "en");

        // Assert
        Assert.False(result.Success);
        Assert.Equal("No chunks to index", result.ErrorMessage);

        // Verify Qdrant was not called
        _clientAdapterMock.Verify(
            c => c.UpsertAsync(
                It.IsAny<string>(),
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()),
            Times.Never);
    }

    /// <summary>
    /// BDD Scenario: Index null chunks list with language
    /// Given: Null chunks list
    /// When: IndexDocumentChunksAsync is called
    /// Then: Returns failure without calling Qdrant
    /// </summary>
    [Fact]
    public async Task IndexDocumentChunksAsync_NullChunksWithLanguage_ReturnsFailure()
    {
        // Arrange & Act
        var result = await _service.IndexDocumentChunksAsync("game-1", "pdf-1", null!, "fr");

        // Assert
        Assert.False(result.Success);
        Assert.Equal("No chunks to index", result.ErrorMessage);

        _clientAdapterMock.Verify(
            c => c.UpsertAsync(
                It.IsAny<string>(),
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()),
            Times.Never);
    }

    /// <summary>
    /// BDD Scenario: Search with empty query embedding and language
    /// Given: Empty embedding vector
    /// When: SearchAsync is called with language
    /// Then: Still attempts search (Qdrant will handle invalid embedding)
    /// </summary>
    [Fact]
    public async Task SearchAsync_EmptyEmbeddingWithLanguage_AttemptsSearch()
    {
        // Arrange
        var emptyEmbedding = Array.Empty<float>();

        _clientAdapterMock
            .Setup(c => c.SearchAsync(
                It.IsAny<string>(),
                It.IsAny<float[]>(),
                It.IsAny<Filter>(),
                It.IsAny<ulong>(),
                It.IsAny<CancellationToken>()))
            .ReturnsAsync(new List<ScoredPoint>());

        // Act
        var result = await _service.SearchAsync("chess", emptyEmbedding, "es", limit: 3);

        // Assert
        Assert.True(result.Success);
        Assert.Empty(result.Results);

        // Verify search was attempted with language filter
        _clientAdapterMock.Verify(
            c => c.SearchAsync(
                "test_documents",
                emptyEmbedding,
                It.Is<Filter>(f => f.Must.Count == 2 && f.Must[1].Field.Match.Keyword == "es"),
                3,
                It.IsAny<CancellationToken>()),
            Times.Once);
    }

    #endregion

    #region Helper Methods

    private List<DocumentChunk> CreateTestChunks(int count)
    {
        var chunks = new List<DocumentChunk>();
        for (int i = 0; i < count; i++)
        {
            chunks.Add(new DocumentChunk
            {
                Text = $"Test chunk {i}",
                Embedding = CreateTestEmbedding(),
                Page = 1,
                CharStart = i * 100,
                CharEnd = (i + 1) * 100 - 1
            });
        }
        return chunks;
    }

    private float[] CreateTestEmbedding()
    {
        return Enumerable.Repeat(0.1f, 768).ToArray();
    }

    private ScoredPoint CreateScoredPoint(string pdfId, string text, int page, int chunkIndex, float score)
    {
        var payload = new Dictionary<string, Value>
        {
            ["pdf_id"] = pdfId,
            ["text"] = text,
            ["page"] = page,
            ["chunk_index"] = chunkIndex,
            ["game_id"] = "test-game",
            ["language"] = "it"
        };

        var point = new ScoredPoint
        {
            Score = score,
            Payload = { payload }
        };

        return point;
    }

    #endregion
}

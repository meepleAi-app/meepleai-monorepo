using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading;
using System.Threading.Tasks;
using Api.Services;
using Api.Services.Qdrant;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.Logging;
using Moq;
using Qdrant.Client;
using Qdrant.Client.Grpc;
using Xunit;

namespace Api.Tests;

/// <summary>
/// Comprehensive unit tests for QdrantService following BDD naming conventions.
/// Target: ≥90% code coverage for TEST-02-P3.
/// Uses Moq for specialized Qdrant interfaces to ensure fast, deterministic tests.
/// </summary>
public class QdrantServiceComprehensiveTests
{
    private readonly Mock<IQdrantCollectionManager> _collectionManagerMock;
    private readonly Mock<IQdrantVectorIndexer> _vectorIndexerMock;
    private readonly Mock<IQdrantVectorSearcher> _vectorSearcherMock;
    private readonly Mock<IConfiguration> _configurationMock;
    private readonly Mock<ILogger<QdrantService>> _mockLogger;
    private readonly QdrantService _service;

    public QdrantServiceComprehensiveTests()
    {
        _collectionManagerMock = new Mock<IQdrantCollectionManager>();
        _vectorIndexerMock = new Mock<IQdrantVectorIndexer>();
        _vectorSearcherMock = new Mock<IQdrantVectorSearcher>();
        _configurationMock = new Mock<IConfiguration>();
        _mockLogger = new Mock<ILogger<QdrantService>>();

        // Default configuration: Ollama provider (768 dimensions)
        _configurationMock.Setup(c => c["EMBEDDING_PROVIDER"]).Returns("ollama");
        _configurationMock.Setup(c => c["QDRANT_URL"]).Returns("http://localhost:6333");

        _service = new QdrantService(
            _collectionManagerMock.Object,
            _vectorIndexerMock.Object,
            _vectorSearcherMock.Object,
            _configurationMock.Object,
            _mockLogger.Object);
    }

    #region Constructor and Configuration Tests

    [Fact]
    public void Constructor_WhenOllamaProvider_ShouldUse768Dimensions()
    {
        // Arrange
        var configMock = new Mock<IConfiguration>();
        configMock.Setup(c => c["EMBEDDING_PROVIDER"]).Returns("ollama");

        // Act
        var service = new QdrantService(
            _collectionManagerMock.Object,
            _vectorIndexerMock.Object,
            _vectorSearcherMock.Object,
            configMock.Object,
            _mockLogger.Object);

        // Assert - Service should be created successfully
        Assert.NotNull(service);
        // Note: We can't directly assert _vectorSize as it's private,
        // but collection creation will use the correct dimensions
    }

    [Fact]
    public void Constructor_WhenOpenAIProvider_ShouldUse1536Dimensions()
    {
        // Arrange
        var configMock = new Mock<IConfiguration>();
        configMock.Setup(c => c["EMBEDDING_PROVIDER"]).Returns("openai");

        // Act
        var service = new QdrantService(
            _collectionManagerMock.Object,
            _vectorIndexerMock.Object,
            _vectorSearcherMock.Object,
            configMock.Object,
            _mockLogger.Object);

        // Assert - Service should be created successfully
        Assert.NotNull(service);
    }

    [Fact]
    public void Constructor_WhenOpenRouterProvider_ShouldUse1536Dimensions()
    {
        // Arrange
        var configMock = new Mock<IConfiguration>();
        configMock.Setup(c => c["EMBEDDING_PROVIDER"]).Returns("openrouter");

        // Act
        var service = new QdrantService(
            _collectionManagerMock.Object,
            _vectorIndexerMock.Object,
            _vectorSearcherMock.Object,
            configMock.Object,
            _mockLogger.Object);

        // Assert - Service should be created successfully

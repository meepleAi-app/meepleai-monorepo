# S3-Compatible Object Storage Credentials
# OPTIONAL - Info logged if missing (local file storage used)
# Copy this file to infra/secrets/storage.secret and fill in values
#
# Supported providers:
# - AWS S3: s3.amazonaws.com
# - MinIO: your-minio-server:9000
# - DigitalOcean Spaces: nyc3.digitaloceanspaces.com
# - Backblaze B2: s3.us-west-004.backblazeb2.com
# - Cloudflare R2: <account-id>.r2.cloudflarestorage.com

# Primary storage credentials (for uploads and general storage)
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET_NAME=meepleai-uploads
S3_REGION=us-east-1
S3_ENDPOINT=s3.amazonaws.com

# Backup storage credentials (for database backups via n8n)
# Can use same credentials or separate backup-specific bucket
S3_BACKUP_ACCESS_KEY=your_backup_access_key
S3_BACKUP_SECRET_KEY=your_backup_secret_key
S3_BACKUP_BUCKET_NAME=meepleai-backups
S3_BACKUP_ENDPOINT=s3.amazonaws.com
S3_BACKUP_RETENTION_DAYS=30

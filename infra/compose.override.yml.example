# Docker Compose Override Example
#
# Copy this file to compose.override.yml and customize for local development:
#   cp compose.override.yml.example compose.override.yml
#
# Docker Compose automatically uses compose.override.yml when present.
# Override files take precedence over docker-compose.yml for matching services.
#
# Common Use Cases:
# 1. Port Customization - Avoid port conflicts with other local services
# 2. Debug Logging - Enable verbose logging for troubleshooting
# 3. Resource Adjustments - Increase limits for resource-intensive development
# 4. Service Disabling - Comment out services not needed for current work
#
# NOTE: compose.override.yml is gitignored to prevent local configs from being committed.

# Uncomment and customize the sections below for local development needs.
# Docker Compose requires at least one service definition when using override files.
# If you don't need any overrides, simply don't create compose.override.yml.

services:
  # ====================
  # 1. PORT CUSTOMIZATION
  # ====================
  # Override ports to avoid conflicts with other local services

  # Example: Change Postgres port to avoid conflict with local PostgreSQL
  postgres:
    ports:
      - "127.0.0.1:5432:5432"  # Default - change to 5433 if port 5432 is in use

  # Example: Change API port
  # api:
  #   ports:
  #     - "127.0.0.1:8081:8080"  # Use 8081 instead of 8080

  # Example: Change Web port
  # web:
  #   ports:
  #     - "127.0.0.1:3001:3000"  # Use 3001 instead of 3000

  # Example: Change Grafana port
  # grafana:
  #   ports:
  #     - "127.0.0.1:3002:3000"  # Use 3002 instead of 3001

  # ====================
  # 2. DEBUG LOGGING
  # ====================
  # Enable verbose logging for troubleshooting

  # Example: API debug logging
  # api:
  #   environment:
  #     - ASPNETCORE_ENVIRONMENT=Development
  #     - Logging__LogLevel__Default=Debug
  #     - Logging__LogLevel__Microsoft.AspNetCore=Debug
  #     - Logging__LogLevel__Microsoft.EntityFrameworkCore=Information

  # Example: PostgreSQL query logging (WARNING: Very verbose)
  # postgres:
  #   command:
  #     - "postgres"
  #     - "-c"
  #     - "log_statement=all"
  #     - "-c"
  #     - "log_min_duration_statement=0"

  # Example: Redis verbose logging
  # redis:
  #   command: ["sh", "-c", "redis-server --appendonly yes --requirepass $$(cat /run/secrets/redis-password) --maxmemory 768mb --maxmemory-policy allkeys-lru --loglevel verbose"]

  # ====================
  # 3. RESOURCE ADJUSTMENTS
  # ====================
  # Increase resource limits for resource-intensive development tasks

  # Example: Increase API resources for heavy load testing
  # api:
  #   deploy:
  #     resources:
  #       limits:
  #         cpus: '4.0'
  #         memory: 4G
  #       reservations:
  #         cpus: '2.0'
  #         memory: 2G

  # Example: Increase PostgreSQL resources for large dataset imports
  # postgres:
  #   deploy:
  #     resources:
  #       limits:
  #         cpus: '4.0'
  #         memory: 4G
  #       reservations:
  #         cpus: '2.0'
  #         memory: 2G
  #   environment:
  #     POSTGRES_SHARED_BUFFERS: 1024MB
  #     POSTGRES_EFFECTIVE_CACHE_SIZE: 3GB
  #     POSTGRES_WORK_MEM: 32MB
  #     POSTGRES_MAINTENANCE_WORK_MEM: 512MB

  # Example: Increase Qdrant resources for vector-heavy operations
  # qdrant:
  #   deploy:
  #     resources:
  #       limits:
  #         cpus: '4.0'
  #         memory: 8G
  #       reservations:
  #         cpus: '2.0'
  #         memory: 4G

  # ====================
  # 4. SERVICE DISABLING
  # ====================
  # Disable services not needed for current development task
  # NOTE: Use Docker Compose profiles for cleaner service selection
  #       See README.md for profile usage (minimal, dev, observability, ai, automation, full)

  # Example: Disable Ollama when using OpenRouter exclusively
  # ollama:
  #   profiles:
  #     - disabled

  # Example: Disable monitoring stack for faster startup during quick iterations
  # prometheus:
  #   profiles:
  #     - disabled
  # grafana:
  #   profiles:
  #     - disabled
  # alertmanager:
  #   profiles:
  #     - disabled

  # Example: Disable n8n when not working on workflow automation
  # n8n:
  #   profiles:
  #     - disabled

# ====================
# USAGE TIPS
# ====================
#
# 1. Validate your override file before starting services:
#    docker compose config
#
# 2. Check which services will start with your overrides:
#    docker compose --profile <profile> config --services
#
# 3. Apply changes to running services (recreates modified containers):
#    docker compose up -d
#
# 4. Override precedence (later files override earlier):
#    docker-compose.yml < compose.override.yml
#
# 5. Use multiple override files for complex scenarios:
#    docker compose -f docker-compose.yml -f compose.override.yml -f docker-compose.custom.yml up
#
# 6. Troubleshooting:
#    - If services won't start, validate config: docker compose config
#    - Check logs for errors: docker compose logs -f <service>
#    - Reset to defaults: rm compose.override.yml && docker compose up -d

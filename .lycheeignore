# Patterns of links lychee should ignore.
# One regex per line. Empty lines and lines starting with # are ignored.

# Local dev URLs (not reachable from CI)
^https?://localhost(:\d+)?(/.*)?$
^https?://127\.0\.0\.1(:\d+)?(/.*)?$
^https?://0\.0\.0\.0(:\d+)?(/.*)?$
^https?://meepleai-api(:\d+)?(/.*)?$
^https?://[^/]*\.internal(/.*)?$

# GitHub anchors that lychee can't always resolve
^https?://github\.com/.*#L\d+

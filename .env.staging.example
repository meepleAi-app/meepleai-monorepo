# ============================================================================
# MeepleAI - Staging Environment Configuration
# ============================================================================
#
# ENVIRONMENT: Staging (Pre-Production)
# PURPOSE: Production-like testing, QA, demo environment
# LAST UPDATED: 2025-11-22
#
# USAGE:
#   1. Copy this file to .env.staging
#   2. Replace all <REPLACE_*> placeholders with actual values
#   3. Store secrets in Docker Secrets or environment-specific vault
#   4. Use with: docker compose -f compose.staging.yml up
#
# SECURITY: Staging credentials - keep secure, rotate regularly
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT IDENTIFICATION
# ----------------------------------------------------------------------------
ENVIRONMENT=staging
DEPLOY_ENVIRONMENT=stg

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# ----------------------------------------------------------------------------
# Staging: Separate database, moderate security
POSTGRES_USER=meepleai_stg
POSTGRES_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>
POSTGRES_DB=meepleai_staging
POSTGRES_HOST=<REPLACE_WITH_DB_HOST>
POSTGRES_PORT=5432

# Connection String
# STAGING: SSL preferred, moderate pooling
ConnectionStrings__Postgres=Host=<REPLACE_WITH_DB_HOST>;Database=meepleai_staging;Username=meepleai_stg;Password=<REPLACE_WITH_STRONG_PASSWORD>;SSL Mode=Prefer;Pooling=true;Minimum Pool Size=5;Maximum Pool Size=50;Connection Idle Lifetime=300;Command Timeout=30

# Alternative: Use Docker Secret
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres-password-staging
# ConnectionStrings__Postgres=Host=<HOST>;Database=meepleai_staging;Username=meepleai_stg;Password_File=/run/secrets/postgres-password-staging;SSL Mode=Prefer;Pooling=true;Minimum Pool Size=5;Maximum Pool Size=50

# ----------------------------------------------------------------------------
# CACHE CONFIGURATION (Redis)
# ----------------------------------------------------------------------------
# Staging: Redis with password, L2 cache enabled
REDIS_URL=<REPLACE_WITH_REDIS_HOST>:6379
REDIS_PASSWORD=<REPLACE_WITH_REDIS_PASSWORD>
REDIS_CONFIGURATION=<REPLACE_WITH_REDIS_HOST>:6379,password=<REPLACE_WITH_REDIS_PASSWORD>,connectTimeout=5000,connectRetry=3,abortConnect=false

# Enable L2 cache (production-like)
HYBRIDCACHE_ENABLE_L2=true
HYBRIDCACHE_DEFAULT_EXPIRATION=24:00:00
HYBRIDCACHE_MAX_PAYLOAD_BYTES=10485760

# ----------------------------------------------------------------------------
# VECTOR DATABASE (Qdrant)
# ----------------------------------------------------------------------------
# Staging: Dedicated Qdrant instance or Qdrant Cloud
QDRANT_URL=<REPLACE_WITH_QDRANT_URL>
# If using Qdrant Cloud:
# QDRANT_URL=https://<cluster-id>.eu-central.aws.cloud.qdrant.io
# QDRANT_API_KEY=<REPLACE_WITH_QDRANT_API_KEY>

# Collection name (staging-specific to avoid conflicts)
QDRANT_COLLECTION_NAME=meepleai_rules_staging

# ----------------------------------------------------------------------------
# API BACKEND (ASP.NET Core)
# ----------------------------------------------------------------------------
# Staging: HTTPS recommended, production-like settings
ASPNETCORE_ENVIRONMENT=Staging
# Default: HTTP-only (use load balancer/reverse proxy for SSL termination)
ASPNETCORE_URLS=http://+:8080
# Staging: Less verbose error messages (but more than prod)
ASPNETCORE_DETAILEDERRORS=false

# SSL Certificate (ONLY if using HTTPS directly without load balancer)
# ⚠️  IMPORTANT: If you enable HTTPS below, you MUST configure certificate settings
# Recommended: Use load balancer/reverse proxy for SSL termination instead
# To enable HTTPS:
#   1. Uncomment ASPNETCORE_URLS line below (and comment out the HTTP-only line above)
#   2. Uncomment and configure certificate settings
#   3. Mount certificate file in Docker volume or use Docker Secret
# ASPNETCORE_URLS=https://+:8080;http://+:8081
# ASPNETCORE_Kestrel__Certificates__Default__Path=/etc/ssl/certs/staging.meepleai.pfx
# ASPNETCORE_Kestrel__Certificates__Default__Password_File=/run/secrets/ssl-cert-password

# JWT Configuration
JWT_ISSUER=<REPLACE_WITH_STAGING_API_URL>
JWT_AUDIENCE=<REPLACE_WITH_STAGING_WEB_URL>

# CORS: Staging frontend domains
ALLOW_ORIGIN=<REPLACE_WITH_STAGING_WEB_URL>

# ----------------------------------------------------------------------------
# FRONTEND (Next.js)
# Remote logging endpoint (frontend)
NEXT_PUBLIC_LOG_ENDPOINT=https://staging.api.meepleai.com/api/v1/logs

# ----------------------------------------------------------------------------
# Staging: Production build, but staging API
NODE_ENV=production
NEXT_PUBLIC_API_BASE=<REPLACE_WITH_STAGING_API_URL>
NEXT_PUBLIC_TENANT_ID=staging

# Sentry (Error Tracking - recommended for staging)
NEXT_PUBLIC_SENTRY_DSN=<REPLACE_WITH_SENTRY_DSN>
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
SENTRY_ORG=<REPLACE_WITH_SENTRY_ORG>
SENTRY_PROJECT=<REPLACE_WITH_SENTRY_PROJECT>
SENTRY_AUTH_TOKEN=<REPLACE_WITH_SENTRY_AUTH_TOKEN>

# Resilience: Production-like settings
NEXT_PUBLIC_RETRY_ENABLED=true
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=3
NEXT_PUBLIC_RETRY_BASE_DELAY=1000
NEXT_PUBLIC_RETRY_MAX_DELAY=10000
NEXT_PUBLIC_CIRCUIT_BREAKER_ENABLED=true
NEXT_PUBLIC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
NEXT_PUBLIC_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
NEXT_PUBLIC_CIRCUIT_BREAKER_TIMEOUT=60000

# ----------------------------------------------------------------------------
# AI/ML SERVICES
# ----------------------------------------------------------------------------
# Staging: Mix of local and cloud services for testing

# Embedding Provider
# Option 1: Local Ollama (cost-effective for staging)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# Option 2: OpenAI (if testing cloud embeddings)
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=<REPLACE_WITH_OPENAI_STAGING_KEY>
# EMBEDDING_MODEL=text-embedding-3-small

# OpenRouter (for LLM - use budget-friendly models in staging)
OPENROUTER_API_KEY=<REPLACE_WITH_OPENROUTER_STAGING_KEY>
# Staging: Use free or cheap models
# - meta-llama/llama-3.3-70b-instruct:free
# - anthropic/claude-3.5-haiku (cost-effective)

# Local Embedding Service
LOCAL_EMBEDDING_URL=http://embedding-service:8000
EMBEDDING_FALLBACK_ENABLED=true

# ----------------------------------------------------------------------------
# PDF PROCESSING SERVICES
# ----------------------------------------------------------------------------
# Staging: Production-like quality, moderate performance

# Unstructured Service (Stage 1)
UNSTRUCTURED_STRATEGY=fast
LANGUAGE=ita
MAX_FILE_SIZE=104857600
TIMEOUT=35
QUALITY_THRESHOLD=0.80
MIN_CHARS_PER_PAGE=500

# SmolDocling Service (Stage 2)
# Staging: CPU or GPU depending on infrastructure
DEVICE=cpu
MODEL_NAME=docling-project/SmolDocling-256M-preview
TORCH_DTYPE=bfloat16
IMAGE_DPI=300
MAX_PAGES_PER_REQUEST=20
ENABLE_MODEL_WARMUP=true

# If GPU available in staging:
# DEVICE=cuda
# TORCH_DTYPE=bfloat16

# ----------------------------------------------------------------------------
# WORKFLOW AUTOMATION (n8n)
# ----------------------------------------------------------------------------
# Staging: Production-like configuration
N8N_HOST=<REPLACE_WITH_STAGING_N8N_HOST>
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=<REPLACE_WITH_STAGING_N8N_WEBHOOK_URL>

# Database
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=<REPLACE_WITH_DB_HOST>
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=meepleai_staging
DB_POSTGRESDB_USER=meepleai_stg
DB_POSTGRESDB_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# Basic Auth (stronger than dev)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin_staging
N8N_BASIC_AUTH_PASSWORD=<REPLACE_WITH_N8N_PASSWORD>

# Encryption Key (CRITICAL: generate unique key for staging)
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=<REPLACE_WITH_N8N_ENCRYPTION_KEY>

# MeepleAI API URL
MEEPLEAI_API_URL=<REPLACE_WITH_STAGING_API_URL>

# Service Account Session
N8N_SERVICE_SESSION=<REPLACE_WITH_SERVICE_SESSION_TOKEN>

# Logging
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console,file

# ----------------------------------------------------------------------------
# OBSERVABILITY (Logging, Metrics, Tracing)
# ----------------------------------------------------------------------------
# Staging: Full observability stack (production-like)

# Seq (Log Aggregation)
SEQ_URL=<REPLACE_WITH_SEQ_URL>
ACCEPT_EULA=Y
SEQ_API_KEY=<REPLACE_WITH_SEQ_API_KEY>
SEQ_FIRSTRUN_ADMINPASSWORDHASH=<REPLACE_WITH_SEQ_PASSWORD_HASH>
SEQ_CACHE_SYSTEMRAMTARGET=0.5

# Prometheus (Metrics)
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=25GB

# Grafana (Dashboards)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<REPLACE_WITH_GRAFANA_PASSWORD>
GF_SERVER_ROOT_URL=<REPLACE_WITH_GRAFANA_URL>
GF_USERS_ALLOW_SIGN_UP=false

# Jaeger (Tracing)
COLLECTOR_OTLP_ENABLED=true
# Staging: Use persistent storage
SPAN_STORAGE_TYPE=elasticsearch
# If using Elasticsearch:
# SPAN_STORAGE_ES_SERVER_URLS=<REPLACE_WITH_ELASTICSEARCH_URL>
# SPAN_STORAGE_ES_USERNAME=<REPLACE_WITH_ES_USERNAME>
# SPAN_STORAGE_ES_PASSWORD=<REPLACE_WITH_ES_PASSWORD>

# Alertmanager (Alerts - enabled but less aggressive than prod)
ALERTMANAGER_ENABLED=true

# ----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ----------------------------------------------------------------------------
# Staging: Production-like security with test accounts

# Bootstrap Admin (for testing)
INITIAL_ADMIN_EMAIL=admin@staging.meepleai.dev
INITIAL_ADMIN_PASSWORD=<REPLACE_WITH_ADMIN_PASSWORD>
INITIAL_ADMIN_DISPLAY_NAME=Staging Administrator

# OAuth Providers (REAL staging apps required)
# Create staging OAuth apps in provider consoles
GOOGLE_OAUTH_CLIENT_ID=<REPLACE_WITH_GOOGLE_STAGING_CLIENT_ID>
GOOGLE_OAUTH_CLIENT_SECRET=<REPLACE_WITH_GOOGLE_STAGING_SECRET>

DISCORD_OAUTH_CLIENT_ID=<REPLACE_WITH_DISCORD_STAGING_CLIENT_ID>
DISCORD_OAUTH_CLIENT_SECRET=<REPLACE_WITH_DISCORD_STAGING_SECRET>

GITHUB_OAUTH_CLIENT_ID=<REPLACE_WITH_GITHUB_STAGING_CLIENT_ID>
GITHUB_OAUTH_CLIENT_SECRET=<REPLACE_WITH_GITHUB_STAGING_SECRET>

# OAuth Callback URL
OAUTH_CALLBACK_BASE_URL=<REPLACE_WITH_STAGING_API_URL>

# Session Configuration (production-like)
SESSION_EXPIRATION_DAYS=30
INACTIVITY_TIMEOUT_DAYS=30
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict

# ----------------------------------------------------------------------------
# EMAIL & ALERTING
# ----------------------------------------------------------------------------
# Staging: Email enabled for testing, alerts to staging channels

ALERTING_ENABLED=true
ALERTING_THROTTLE_MINUTES=60

# Email Configuration
ALERTING_EMAIL_ENABLED=true
SMTP_HOST=<REPLACE_WITH_SMTP_HOST>
SMTP_PORT=587
SMTP_USERNAME=<REPLACE_WITH_SMTP_USERNAME>
SMTP_PASSWORD=<REPLACE_WITH_SMTP_PASSWORD>
SMTP_USE_TLS=true
ALERTING_EMAIL_FROM=alerts@staging.meepleai.dev
ALERTING_EMAIL_TO=["qa-team@meepleai.dev","devops@meepleai.dev"]

# Slack (optional - staging channel)
ALERTING_SLACK_ENABLED=true
SLACK_WEBHOOK_URL=<REPLACE_WITH_SLACK_STAGING_WEBHOOK>
SLACK_CHANNEL=#alerts-staging

# PagerDuty (optional - low priority integration)
ALERTING_PAGERDUTY_ENABLED=false
# PAGERDUTY_INTEGRATION_KEY=<REPLACE_WITH_PAGERDUTY_STAGING_KEY>

# Gmail App Password (alternative to SMTP)
# GMAIL_APP_PASSWORD=<REPLACE_WITH_GMAIL_APP_PASSWORD>

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
# Staging: All features enabled for QA testing
FEATURE_PROMPT_DATABASE=true
FEATURE_STREAMING_RESPONSES=true
FEATURE_SETUP_GUIDE_GENERATION=true
FEATURE_CHAT_EXPORT=true
FEATURE_MESSAGE_EDIT_DELETE=true
FEATURE_PDF_UPLOAD=true

# Experimental features (test here before prod)
FEATURE_EXPERIMENTAL_RAG_V2=true
FEATURE_BETA_UI_COMPONENTS=true

# ----------------------------------------------------------------------------
# PERFORMANCE TUNING
# ----------------------------------------------------------------------------
# Staging: Production-like performance settings

# Cache Optimization
CACHE_OPTIMIZATION_ENABLED=true
CACHE_WARMING_ENABLED=true
CACHE_WARMING_STARTUP_DELAY_MINUTES=5
CACHE_WARMING_INTERVAL_HOURS=12

# Follow-up Questions
FOLLOWUP_QUESTIONS_ENABLED=true
FOLLOWUP_QUESTIONS_MAX_PER_RESPONSE=5
FOLLOWUP_QUESTIONS_TIMEOUT_MS=10000

# Quality Evaluation (enabled for testing)
QUALITY_EVALUATION_ENABLED=true
QUALITY_EVALUATION_INTERVAL_DAYS=7
RAG_EVALUATION_ENABLED=true
RAG_DATASET_PATH=/app/datasets/rag/evaluation.json

# Hybrid Search Configuration
HYBRID_SEARCH_VECTOR_WEIGHT=0.7
HYBRID_SEARCH_KEYWORD_WEIGHT=0.3
HYBRID_SEARCH_RRF_CONSTANT=60

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
# Staging: Production-like but more lenient for testing
RATELIMIT_ADMIN_MAX_TOKENS=1000
RATELIMIT_ADMIN_REFILL_RATE=10.0
RATELIMIT_EDITOR_MAX_TOKENS=500
RATELIMIT_EDITOR_REFILL_RATE=5.0
RATELIMIT_USER_MAX_TOKENS=150
RATELIMIT_USER_REFILL_RATE=1.5
RATELIMIT_ANONYMOUS_MAX_TOKENS=100
RATELIMIT_ANONYMOUS_REFILL_RATE=1.0

# ----------------------------------------------------------------------------
# LOGGING LEVELS
# ----------------------------------------------------------------------------
# Staging: Balanced logging (info + warnings)
LOG_LEVEL=Information
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT=Warning
LOGGING__LOGLEVEL__MICROSOFT_ASPNETCORE=Warning
LOGGING__LOGLEVEL__MICROSOFT_ENTITYFRAMEWORKCORE=Warning

# Structured Logging
ENABLE_STRUCTURED_LOGGING=true
ENABLE_METRICS=true
ENABLE_DISTRIBUTED_TRACING=true

# ----------------------------------------------------------------------------
# DOCKER CONFIGURATION
# ----------------------------------------------------------------------------
# Staging: Moderate resource allocation
COMPOSE_PROJECT_NAME=meepleai-staging

# Resource Limits (adjust based on staging infrastructure)
POSTGRES_MAX_CONNECTIONS=100
REDIS_MAX_MEMORY=2gb

# API Resources
API_CPU_LIMIT=2
API_MEMORY_LIMIT=4g
API_CPU_RESERVATION=1
API_MEMORY_RESERVATION=2g

# Web Resources
WEB_CPU_LIMIT=1
WEB_MEMORY_LIMIT=2g
WEB_CPU_RESERVATION=0.5
WEB_MEMORY_RESERVATION=1g

# ----------------------------------------------------------------------------
# BACKUP & DISASTER RECOVERY
# ----------------------------------------------------------------------------
# Staging: Regular backups for testing recovery procedures
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_PATH=/backups/staging

# ----------------------------------------------------------------------------
# MONITORING & HEALTH CHECKS
# ----------------------------------------------------------------------------
# Staging: Aggressive health checks
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=30s

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. Purpose of Staging Environment:
#    - QA testing before production deployment
#    - Demo environment for stakeholders
#    - Performance testing with production-like data
#    - Security testing and penetration testing
#    - Integration testing with third-party services
#    - Training environment for users
#
# 2. Key Differences from Development:
#    - HTTPS/SSL enabled
#    - Real OAuth providers (staging apps)
#    - Production-like database and caching
#    - Full observability stack
#    - Email and alerting enabled
#    - Stronger security settings
#    - Better error handling (no detailed errors)
#
# 3. Key Differences from Production:
#    - More lenient rate limits
#    - More verbose logging (Information vs Warning)
#    - Shorter data retention (30d vs 90d)
#    - Test credentials allowed
#    - Some experimental features enabled
#    - Less aggressive health checks
#
# 4. Security Considerations:
#    - Use strong passwords (16+ characters)
#    - Rotate credentials regularly (quarterly)
#    - Keep staging data separate from production
#    - Use staging-specific OAuth apps
#    - Monitor access logs
#    - Never use production secrets in staging
#
# 5. Data Management:
#    - Use anonymized production data copies
#    - Reset database periodically (weekly/monthly)
#    - Clear sensitive data after testing
#    - Separate vector database collections
#
# 6. Quick Start:
#    cp .env.staging.example .env.staging
#    # Replace all <REPLACE_*> placeholders
#    docker compose -f compose.staging.yml up -d
#
# 7. Troubleshooting:
#    - Check health: curl https://staging.meepleai.dev/health
#    - View logs: docker compose -f compose.staging.yml logs -f api
#    - Metrics: https://staging.meepleai.dev/metrics
#    - See: docs/05-operations/runbooks/general-troubleshooting.md
# ============================================================================

{
  "info": {
    "_postman_id": "d2d8df68-4b3a-4c3f-9d3b-meepleai-api",
    "name": "MeepleAI API",
    "description": "Collection per testare gli endpoint principali dell'API MeepleAI in locale. Usa l'ambiente `Local Development` fornito nella cartella `postman/` per risolvere la variabile `{{baseUrl}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"tester+{{$timestamp}}@meepleai.dev\",\n  \"password\": \"P@ssword123!\",\n  \"displayName\": \"API Tester {{$randomInt}}\",\n  \"role\": \"User\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "description": "Crea un nuovo utente locale ed esegue automaticamente il login tramite cookie di sessione."
      }
    },
    {
      "name": "Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  if (json && json.user) {",
              "    pm.environment.set('userId', json.user.id || '');",
              "    pm.environment.set('authEmail', json.user.email || '');",
              "  }",
              "  pm.environment.set('lastResponseTime', new Date().toISOString());",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"P@ssword123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Esegue il login e salva `userId`/`authEmail` nell'ambiente. Il cookie `meepleai_session` viene salvato automaticamente dal cookie jar di Postman."
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "profile"
          ]
        },
        "description": "Richiede il profilo dell'utente autenticato; necessita della sessione ottenuta con Register o Login."
      }
    },
    {
      "name": "Ask Question (RAG)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gameId\": \"{{testGameId}}\",\n  \"query\": \"How many cards do I draw at the beginning of the game?\",\n  \"searchMode\": \"Hybrid\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/agents/qa",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "agents",
            "qa"
          ]
        },
        "description": "Esegue una domanda RAG per un gioco già presente nel DB. Imposta `{{testGameId}}` nell'ambiente con l'ID del gioco su cui vuoi fare query."
      }
    }
  ]
}

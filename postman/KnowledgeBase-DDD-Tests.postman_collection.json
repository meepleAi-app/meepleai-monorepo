            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{testGameId}}\",\n  \"query\": \"What are the different phases of the game and what actions can you take in each phase?\",\n  \"language\": \"en\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/knowledge-base/ask",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "knowledge-base", "ask"]
            },
            "description": "Test complex question requiring multiple sources.\nShould demonstrate RRF fusion and quality tracking."
          },
          "response": []
        },
        {
          "name": "Ask - With Cache Bypass",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Q&A successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Save response time for comparison",
                  "pm.collectionVariables.set('lastResponseTime', pm.response.responseTime);",
                  "console.log('Response time (cache bypass):', pm.response.responseTime, 'ms');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{testGameId}}\",\n  \"query\": \"How many points do you need to win?\",\n  \"language\": \"en\",\n  \"bypassCache\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/knowledge-base/ask",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "knowledge-base", "ask"]
            },
            "description": "Test cache bypass functionality.\nShould always generate fresh response."
          },
          "response": []
        },
        {
          "name": "Ask - Confidence Score Validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Q&A successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Overall confidence is weighted average (70/30)', function() {",
                  "    const response = pm.response.json();",
                  "    const searchConf = response.searchConfidence;",
                  "    const llmConf = response.llmConfidence;",
                  "    const overallConf = response.overallConfidence;",
                  "    ",
                  "    // Calculate expected: 70% search + 30% LLM",
                  "    const expected = (searchConf * 0.7) + (llmConf * 0.3);",
                  "    const tolerance = 0.01;",
                  "    ",
                  "    pm.expect(overallConf).to.be.closeTo(expected, tolerance);",
                  "    console.log('Search:', searchConf, '| LLM:', llmConf, '| Overall:', overallConf);",
                  "    console.log('Expected overall:', expected.toFixed(2));",
                  "});",
                  "",
                  "pm.test('Low quality detection works', function() {",
                  "    const response = pm.response.json();",
                  "    // If overall confidence < 0.5, should be marked low quality",
                  "    if (response.overallConfidence < 0.5) {",
                  "        pm.expect(response.isLowQuality).to.be.true;",
                  "    } else if (response.overallConfidence >= 0.5) {",
                  "        pm.expect(response.isLowQuality).to.be.false;",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{testGameId}}\",\n  \"query\": \"What are the rules?\",\n  \"language\": \"en\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/knowledge-base/ask",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "knowledge-base", "ask"]
            },
            "description": "Test QualityTrackingDomainService confidence calculation.\nVerifies 70/30 weighting formula."
          },
          "response": []
        },

        {
          "name": "Create Game (Admin/Editor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Created game is returned', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.title).to.eql('Test Game');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Game\",\n  \"publisher\": \"Test Publisher\",\n  \"yearPublished\": 2024,\n  \"minPlayers\": 2,\n  \"maxPlayers\": 4,\n  \"minPlayTimeMinutes\": 30,\n  \"maxPlayTimeMinutes\": 60\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/games",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "games"]
            },
            "description": "Create a new game. Requires Admin or Editor role.\n\n**Command**: CreateGameCommand\n**Handler**: CreateGameCommandHandler\n**Context**: GameManagement\n**Events**: GameCreated (Domain Event)"
          },
          "response": []
        }
      ],
      "description": "Game catalog operations"

{
  "name": "@meepleai/web",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev -p 3000",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start -p 3000",
    "test": "jest --passWithNoTests",
    "posttest": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "posttest:coverage": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:a11y": "jest --testPathPatterns=\"(a11y|accessibility)\"",
    "audit:a11y": "tsx scripts/run-accessibility-audit.ts",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "lint:fix": "node ./node_modules/next/dist/bin/next lint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tiptap/extension-character-count": "^3.10.1",
    "@tiptap/extension-placeholder": "^3.10.1",
    "@tiptap/react": "^3.10.1",
    "@tiptap/starter-kit": "^3.10.1",
    "@types/diff": "^8.0.0",
    "@types/prismjs": "^1.26.5",
    "chess.js": "^1.4.0",
    "d3": "^7.9.0",
    "diff": "^8.0.2",
    "framer-motion": "^12.23.24",
    "next": "15.5.6",
    "pdfjs-dist": "^5.4.394",
    "prismjs": "^1.30.0",
    "qrcode.react": "^4.2.0",
    "react": "18.3.1",
    "react-chessboard": "^4.6.0",
    "react-chrono": "^3.0.0",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^10.0.0",
    "react-pdf": "^10.2.0",
    "react-window": "^2.2.2",
    "recharts": "^3.2.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@axe-core/react": "^4.11.0",
    "@next/swc-linux-x64-gnu": "^16.0.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "24.9.2",
    "@types/qrcode.react": "^3.0.0",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "@types/react-window": "^2.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "9.39.0",
    "eslint-config-next": "16.0.1",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}

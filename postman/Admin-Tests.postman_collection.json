{
  "info": {
    "_postman_id": "admin-tests-v1",
    "name": "MeepleAI Admin Tests",
    "description": "Administrative operations testing - requires Admin role.\n\n**Test Groups:**\n1. User Management (5 tests)\n2. System Configuration (3 tests)\n3. Analytics & Reporting (4 tests)\n\n**Auth Required**: Admin credentials\n**Duration**: ~1 minute",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "{{baseUrl}}",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "{{adminEmail}}",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "{{adminPassword}}",
      "type": "secret"
    },
    {
      "key": "testUserId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{adminToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-login as admin if no token",
          "const adminToken = pm.collectionVariables.get('adminToken');",
          "",
          "if (!adminToken) {",
          "    console.log('No admin token found, will login in first request');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Admin Authentication",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Admin login successful', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User has Admin role', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user.role).to.equal('Admin');",
                  "});",
                  "",
                  "pm.test('Admin session token extracted', () => {",
                  "    pm.expect(pm.cookies.has('meepleai_session')).to.be.true;",
                  "    console.log('✅ Admin authenticated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "1. User Management",
      "description": "Admin-only user management operations",
      "item": [
        {
          "name": "1.1 List All Users (Paginated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Users array returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.users).to.be.an('array');",
                  "    pm.expect(json.pagination).to.exist;",
                  "});",
                  "",
                  "pm.test('Pagination metadata present', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.pagination.page).to.be.a('number');",
                  "    pm.expect(json.pagination.pageSize).to.be.a('number');",
                  "    pm.expect(json.pagination.totalCount).to.be.a('number');",
                  "});",
                  "",
                  "// Save first user ID for subsequent tests",
                  "pm.test('Extract test user ID', () => {",
                  "    const json = pm.response.json();",
                  "    if (json.users.length > 0) {",
                  "        // Find non-admin user",
                  "        const testUser = json.users.find(u => u.role === 'User');",
                  "        if (testUser) {",
                  "            pm.collectionVariables.set('testUserId', testUser.id);",
                  "        }",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/users?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "pageSize", "value": "20"}
              ]
            }
          }
        },
        {
          "name": "1.2 Get User by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const userId = pm.collectionVariables.get('testUserId');",
                  "if (!userId) {",
                  "    console.log('SKIP: No testUserId available');",
                  "    pm.execution.skipRequest();",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('User details returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user.id).to.equal(pm.collectionVariables.get('testUserId'));",
                  "    pm.expect(json.user.email).to.exist;",
                  "    pm.expect(json.user.createdAt).to.exist;",
                  "});",
                  "",
                  "pm.test('Activity metrics present', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.activity).to.exist;",
                  "    pm.expect(json.activity.lastLogin).to.exist;",
                  "    pm.expect(json.activity.totalQueries).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{testUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{testUserId}}"]
            }
          }
        },
        {
          "name": "1.3 Suspend User Account",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const userId = pm.collectionVariables.get('testUserId');",
                  "if (!userId) pm.execution.skipRequest();"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - User suspended', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Account status changed to suspended', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user.accountStatus).to.equal('Suspended');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Automated test suspension\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{testUserId}}/suspend",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{testUserId}}", "suspend"]
            }
          }
        },
        {
          "name": "1.4 Reactivate User Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - User reactivated', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Account status back to active', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user.accountStatus).to.equal('Active');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{testUserId}}/reactivate",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{testUserId}}", "reactivate"]
            }
          }
        }
      ]
    },
    {
      "name": "2. System Configuration",
      "item": [
        {
          "name": "2.1 Get System Configuration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Configuration sections present', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.config.featureFlags).to.exist;",
                  "    pm.expect(json.config.rateLimits).to.exist;",
                  "    pm.expect(json.config.pdfProcessing).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/config",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "config"]
            }
          }
        },
        {
          "name": "2.2 View Audit Logs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Audit log entries returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.logs).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Log entries have required fields', () => {",
                  "    const json = pm.response.json();",
                  "    if (json.logs.length > 0) {",
                  "        const log = json.logs[0];",
                  "        pm.expect(log.timestamp).to.exist;",
                  "        pm.expect(log.action).to.exist;",
                  "        pm.expect(log.userId).to.exist;",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/audit-logs?hours=24&action=all",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "audit-logs"],
              "query": [
                {"key": "hours", "value": "24"},
                {"key": "action", "value": "all"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Analytics & Reporting",
      "item": [
        {
          "name": "3.1 Get User Statistics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('User statistics returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.stats.totalUsers).to.be.a('number');",
                  "    pm.expect(json.stats.activeUsers).to.be.a('number');",
                  "    pm.expect(json.stats.newRegistrations).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Tier breakdown present', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.stats.tierBreakdown).to.exist;",
                  "    pm.expect(json.stats.tierBreakdown.free).to.be.a('number');",
                  "    pm.expect(json.stats.tierBreakdown.normal).to.be.a('number');",
                  "    pm.expect(json.stats.tierBreakdown.premium).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/analytics/users?period=30d",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "analytics", "users"],
              "query": [{"key": "period", "value": "30d"}]
            }
          }
        },
        {
          "name": "3.2 Get PDF Processing Metrics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Processing metrics present', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.metrics.totalProcessed).to.be.a('number');",
                  "    pm.expect(json.metrics.averageProcessingTime).to.be.a('number');",
                  "    pm.expect(json.metrics.failureRate).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Processing time within acceptable range', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.metrics.averageProcessingTime).to.be.below(180);  // < 3 minutes",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/analytics/pdf-processing",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "analytics", "pdf-processing"]
            }
          }
        },
        {
          "name": "3.3 Get RAG Query Analytics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('RAG metrics returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.metrics.totalQueries).to.be.a('number');",
                  "    pm.expect(json.metrics.averageConfidence).to.be.a('number');",
                  "    pm.expect(json.metrics.averageResponseTime).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Average confidence above threshold', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.metrics.averageConfidence).to.be.above(0.70);  // Target: >70%",
                  "});",
                  "",
                  "pm.test('Top games by query volume listed', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.topGames).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/analytics/rag-queries?period=7d",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "analytics", "rag-queries"],
              "query": [{"key": "period", "value": "7d"}]
            }
          }
        },
        {
          "name": "3.4 Export Monthly Report (CSV)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Content-Type is CSV', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv');",
                  "});",
                  "",
                  "pm.test('CSV content returned', () => {",
                  "    const csv = pm.response.text();",
                  "    pm.expect(csv).to.include('User ID,Email,Tier,Queries,PDFs');  // CSV header",
                  "    pm.expect(csv.split('\\n').length).to.be.above(1);  // At least header + 1 row",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/reports/monthly?format=csv&month=2026-01",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reports", "monthly"],
              "query": [
                {"key": "format", "value": "csv"},
                {"key": "month", "value": "2026-01"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "9. Cleanup",
      "item": [
        {
          "name": "Logout Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "console.log('✅ Admin tests completed');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    }
  ]
}

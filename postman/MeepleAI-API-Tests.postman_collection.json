          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"not-a-valid-guid\",\n  \"query\": \"test query\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/knowledge-base/search",
              "host": ["{{baseUrl}}"],
              "path": ["knowledge-base", "search"]

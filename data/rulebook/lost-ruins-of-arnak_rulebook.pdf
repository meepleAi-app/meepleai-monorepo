<script>
document.addEventListener('DOMContentLoaded', () => {
    // Najdeme element inputu
    const filterInput = document.querySelector('.js-filter-input');

    // Ověříme, zda input existuje, abychom předešli chybám
    if (!filterInput) {
        console.warn('Element .js-filter-input nebyl nalezen.');
        return;
    }

    // Funkce, která nastaví hodnotu inputu znovu po 2 sekundách
    const resetInputValue = () => {
        const currentValue = filterInput.value;
        setTimeout(() => {
            filterInput.value = currentValue;
            console.log(`Value reset: ${currentValue}`); // Debugging log
        }, 2000);
    };

    // Sledujeme změny v inputu
    filterInput.addEventListener('input', resetInputValue);
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function() {
// Vybrání potřebných elementů
const headerDetail = document.querySelector('.js-header-detail');
const content = document.getElementById('content');
const navHandler = document.querySelector('.js-nav-detail-handler');
const headerNav = document.querySelector('.js-header-nav');
const menuLinks = headerNav ? headerNav.querySelectorAll('.menu__link') : []; // Vybrání všech odkazů v menu

// Funkce pro kontrolu pozice
function toggleHeaderDetail() {
    const contentRect = content.getBoundingClientRect();

    // Zkontrolujeme, jestli horní hrana viewportu se dotýká horní hrany contentu
    if (contentRect.top <= 0 && contentRect.bottom > 0) {
        headerDetail.classList.add('is--visible');
    } else {
        headerDetail.classList.remove('is--visible');
    }
}

// Přidání listeneru na scroll událost
window.addEventListener('scroll', toggleHeaderDetail);

// Inicializace při načtení stránky
toggleHeaderDetail();

// Přidání listeneru na kliknutí pro toggle třídy is--open
if (navHandler && headerNav) {
    navHandler.addEventListener('click', () => {
        headerNav.classList.toggle('is--open');
    });
}

// Přidání listenerů na odkazy v menu
menuLinks.forEach(link => {
    link.addEventListener('click', () => {
        headerNav.classList.toggle('is--open');
    });
});

});
</script>


<script>
document.addEventListener('DOMContentLoaded', () => {
  // Otevření modalů
  document.querySelectorAll('.js-modal-handler').forEach((handler) => {
    handler.addEventListener('click', (e) => {
      e.preventDefault();
      const targetModal = document.getElementById(handler.getAttribute('data-target'));
      if (targetModal) {
        targetModal.classList.add('is--open');
        document.body.classList.add('is-modal-open');
      }
    });
  });

  // Zavření modalů přes tlačítko
  document.querySelectorAll('.js-modal-close').forEach((closeButton) => {
    closeButton.addEventListener('click', (e) => {
      e.preventDefault();
      const targetModal = document.getElementById(closeButton.getAttribute('data-target'));
      if (targetModal) {
        targetModal.classList.remove('is--open');
        document.body.classList.remove('is-modal-open');
      }
    });
  });

  // Zavření modalů kliknutím na overlay (ignoruje modal__inner)
  document.querySelectorAll('.overlay').forEach((overlay) => {
    overlay.addEventListener('click', (e) => {
      if (!e.target.closest('.modal__inner')) {
        overlay.classList.remove('is--open');
        document.body.classList.remove('is-modal-open');
      }
    });
  });

  // Zabránění zavření při kliknutí na obsah modal__inner
  document.querySelectorAll('.modal__inner').forEach((modalInner) => {
    modalInner.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  });
});


</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const newsSection = document.getElementById("news");
    const newsLink = document.getElementById("news-link");

    if (newsSection && newsSection.querySelector(".w-dyn-empty")) {
        newsSection.style.display = "none";
        if (newsLink) {
            newsLink.style.display = "none";
        }
    }
});
</script>


<script>
document.addEventListener("DOMContentLoaded", function () {
    const appRules = document.getElementById("app-rules");
    const rulesTitle = document.getElementById("rules-title");

    if (appRules && rulesTitle) {
        const checkForDiv = () => {
            if (!appRules.querySelector("div")) {
                rulesTitle.style.display = "none";
            } else {
                rulesTitle.style.display = "block";
            }
        };

        // Spustíme kontrolu opakovaně po dobu 5 sekund, protože obsah může být načítán dynamicky
        let attempts = 10;
        const interval = setInterval(() => {
            checkForDiv();
            if (--attempts === 0) clearInterval(interval);
        }, 500);

        // První kontrola ihned
        checkForDiv();
    }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const videos = document.getElementById("videos");
    const videosLink = document.getElementById("videos-link");
    const videosHr = document.getElementById("videos-hr");

    if (videos && videos.querySelector(".w-dyn-empty")) {
        videos.style.display = "none";
        if (videosLink) {
            videosLink.style.display = "none";
            videosHr.style.display = "none";            
        }
    }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
	const awardsDiv = document.getElementById("award");
  const awardsLink = document.getElementById("awards-link");
	const awardsApp = document.getElementById("app-awards");
  const awardsHr = document.getElementById("awards-hr");
  const awardsGrid = awardsApp.querySelector('div');
if (awardsDiv) {
    const checkForDivAwards = () => {
        if (!awardsGrid.querySelector("div")) {
            awardsDiv.style.display = "none";
            awardsLink.style.display = "none";
            awardsApp.style.display = "none";
            awardsHr.style.display = "none";
        } else {
            awardsDiv.style.display = "";
            awardsLink.style.display = "";
            awardsApp.style.display = "";
            awardsHr.style.display = "";
        }
    };

    let attempts = 10;
    const interval = setInterval(() => {
        checkForDivAwards();
        if (--attempts === 0) clearInterval(interval);
    }, 500);

    checkForDivAwards();
}  
});
</script></head><body><div class="page-wrapper"><div class="global-styles w-embed"><style>

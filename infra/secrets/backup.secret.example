# infra/secrets/backup.secret.example
# Backup configuration — copy to backup.secret and fill values
# Generated automatically by: make secrets-setup

# =============================================================================
# R2/S3 BACKUP STORAGE
# =============================================================================
# Can use same R2 account as storage.secret with a DIFFERENT bucket
# Create a dedicated "meepleai-backups" bucket in R2 dashboard

# Enable R2/S3 upload (set to "true" to activate cloud backup)
S3_BACKUP_ENABLED=false

# R2/S3 credentials (can be same as storage.secret or separate)
S3_BACKUP_ACCESS_KEY=change_me
S3_BACKUP_SECRET_KEY=change_me
S3_BACKUP_BUCKET_NAME=meepleai-backups
S3_BACKUP_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# =============================================================================
# BACKUP POLICY
# =============================================================================

# Days to keep local + R2 backups before auto-deletion
BACKUP_RETENTION_DAYS=7

# =============================================================================
# NOTIFICATIONS (optional)
# =============================================================================

# Webhook URL for backup success/failure notifications
# Supports Slack, Discord, n8n webhook, or any JSON-accepting endpoint
# Format: {"text": "[OK/FAIL] MeepleAI Backup: message"}
BACKUP_WEBHOOK_URL=

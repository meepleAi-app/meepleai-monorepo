# Development environment for MeepleAI API.
# Copy to infra/env/api.env.dev and adjust secrets for your local machine.
POSTGRES_USER=meeple
POSTGRES_PASSWORD=meeplepass
POSTGRES_DB=meepleai

# REQUIRED: Database connection string (application will fail to start if not configured)
# Generate secure password: openssl rand -base64 32
CONNECTIONSTRINGS__POSTGRES=Host=postgres;Port=5432;Database=meepleai;Username=meeple;Password=meeplepass

# Embedding Provider Configuration
# Options: "ollama" (local, free) or "openai" (cloud, paid)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# OpenAI API Key (only required if EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here

# OpenRouter API Key (required for LLM chat completions)
OPENROUTER_API_KEY=insert_OPENROUTER_API_KEY

JWT_ISSUER=http://localhost:8080
ALLOW_ORIGIN=http://localhost:3000
N8N_ENCRYPTION_KEY=generate-a-strong-32-byte-secret

# OPS-01: Seq log aggregation URL (default: http://seq:5341)
SEQ_URL=http://seq:5341

# Bootstrap: Initial admin user configuration
# These credentials will be used to create the first admin user on startup (if no admin exists)
# IMPORTANT: Change these values in production and store them securely (Kubernetes secrets, Azure Key Vault, etc.)
# Password requirements: minimum 8 characters, at least one uppercase letter, one digit
# Example: openssl rand -base64 16
INITIAL_ADMIN_EMAIL=admin@meepleai.dev
INITIAL_ADMIN_PASSWORD=Admin123!ChangeMe
INITIAL_ADMIN_DISPLAY_NAME=System Administrator

{
  "name": "@meepleai/web",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev -p 3000",
    "dev:visual-docs": "cross-env NODE_OPTIONS=\"--max-old-space-size=16384\" node ./node_modules/next/dist/bin/next dev -p 3000",
    "build": "node ./node_modules/next/dist/bin/next build",
    "build:analyze": "cross-env ANALYZE=true node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start -p 3000",
    "generate:api": "tsx scripts/generate-api-client.ts",
    "cleanup:testhost": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup/cleanup-test-processes.ps1 -TestHostOnly', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "cleanup:all": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "cleanup:dry-run": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup/cleanup-test-processes.ps1 -DryRun -Verbose', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:performance": "vitest run -t \"Performance\"",
    "test:jest": "jest --passWithNoTests",
    "posttest:jest": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:jest:watch": "jest --watch",
    "test:jest:coverage": "jest --coverage",
    "posttest:coverage": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:coverage": "dotenv -e .env.test -- playwright test --project=desktop-chrome --project=mobile-chrome --project=tablet-chrome",
    "test:e2e:coverage:report": "open coverage-e2e/html/index.html || start coverage-e2e/html/index.html || xdg-open coverage-e2e/html/index.html",
    "test:e2e:visual": "dotenv -e .env.test -- playwright test e2e/visual --project=desktop-chrome",
    "test:e2e:visual:update": "dotenv -e .env.test -- playwright test e2e/visual --project=desktop-chrome --update-snapshots",
    "test:e2e:visual:ui": "dotenv -e .env.test -- playwright test e2e/visual --project=desktop-chrome --ui",
    "test:e2e:visual:all": "dotenv -e .env.test -- playwright test e2e/visual",
    "test:e2e:visual:admin": "dotenv -e .env.test -- playwright test e2e/visual/admin-dashboard-visual.spec.ts --project=desktop-chrome",
    "test:e2e:visual:admin:update": "dotenv -e .env.test -- playwright test e2e/visual/admin-dashboard-visual.spec.ts --project=desktop-chrome --update-snapshots",
    "test:e2e:visual:admin:ui": "dotenv -e .env.test -- playwright test e2e/visual/admin-dashboard-visual.spec.ts --project=desktop-chrome --ui",
    "test:e2e:admin-setup": "pwsh e2e/admin-first-time-setup/run-with-docker.ps1",
    "test:e2e:admin-setup:ui": "pwsh e2e/admin-first-time-setup/run-with-docker.ps1 -UIMode",
    "test:e2e:admin-setup:quick": "pwsh e2e/admin-first-time-setup/run-with-docker.ps1 -TestFile 01-infra-bootstrap",
    "test:e2e:shard1": "dotenv -e .env.test -- playwright test --shard=1/4",
    "test:e2e:shard2": "dotenv -e .env.test -- playwright test --shard=2/4",
    "test:e2e:shard3": "dotenv -e .env.test -- playwright test --shard=3/4",
    "test:e2e:shard4": "dotenv -e .env.test -- playwright test --shard=4/4",
    "test:e2e:parallel": "node scripts/run-parallel-e2e.js",
    "test:a11y": "vitest run -t \"(a11y|accessibility)\"",
    "test:a11y:jest": "jest --testPathPatterns=\"(a11y|accessibility)\"",
    "test:a11y:e2e": "dotenv -e .env.test -- playwright test e2e/accessibility.spec.ts --project=desktop-chrome --workers=1",
    "test:a11y:e2e:errors": "dotenv -e .env.test -- cross-env FORCE_PRODUCTION_SERVER=true playwright test e2e/accessibility.spec.ts --grep '@error-state' --project=desktop-chrome --workers=1",
    "audit:a11y": "tsx scripts/run-accessibility-audit.ts",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "lint:fix": "pnpm exec eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test:e2e:groups": "dotenv -e .env.test -- playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "chromatic:ci": "chromatic --exit-zero-on-changes --exit-once-uploaded",
    "test:visual": "chromatic --exit-zero-on-changes",
    "test:visual:ci": "chromatic --exit-zero-on-changes --exit-once-uploaded",
    "test:visual:debug": "chromatic --debug",
    "test:visual-docs": "dotenv -e .env.test -- playwright test --config=playwright.visual-docs.config.ts",
    "test:visual-docs:ui": "dotenv -e .env.test -- playwright test --config=playwright.visual-docs.config.ts --ui",
    "test:visual-docs:admin": "dotenv -e .env.test -- playwright test --config=playwright.visual-docs.config.ts e2e/visual-docs/admin-flows",
    "test:visual-docs:editor": "dotenv -e .env.test -- playwright test --config=playwright.visual-docs.config.ts e2e/visual-docs/editor-flows",
    "test:visual-docs:user": "dotenv -e .env.test -- playwright test --config=playwright.visual-docs.config.ts e2e/visual-docs/user-flows",
    "docs:generate-index": "tsx e2e/visual-docs/generate-index.ts",
    "docs:generate-screenshots": "pnpm test:visual-docs && pnpm docs:generate-index",
    "docs:generate-screenshots:batch": "pnpm test:visual-docs:admin && pnpm test:visual-docs:editor && pnpm test:visual-docs:user && pnpm docs:generate-index",
    "test:admin-dashboard": "vitest --config vitest.admin.config.ts run",
    "test:generate-mock-pdfs": "node e2e/scripts/generate-mock-pdfs.js",
    "test:generate-mock-pdfs:all": "node e2e/scripts/generate-mock-pdfs.js --all",
    "scraper:game": "pnpm --dir ../../tools/game-scraper run scraper:game --",
    "scraper:plays": "pnpm --dir ../../tools/game-scraper run scraper:plays --",
    "scraper:qa": "pnpm --dir ../../tools/game-scraper run scraper:qa --",
    "prepare": "cd ../.. && husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'files=\"$@\"; files_filtered=$(echo \"$files\" | tr \" \" \"\\n\" | grep -v \"__tests__\" | tr \"\\n\" \" \"); [ -n \"$files_filtered\" ] && pnpm exec eslint --max-warnings=0 --fix $files_filtered || true' --",
      "pnpm exec prettier --write"
    ],
    "*.{js,jsx}": [
      "bash -c 'files=\"$@\"; files_filtered=$(echo \"$files\" | tr \" \" \"\\n\" | grep -v \"__tests__\" | tr \"\\n\" \" \"); [ -n \"$files_filtered\" ] && pnpm exec eslint --max-warnings=0 --fix $files_filtered || true' --",
      "pnpm exec prettier --write"
    ]
  },

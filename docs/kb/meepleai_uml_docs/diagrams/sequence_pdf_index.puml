@startuml
title PDF Ingestion & Indexing [Partially inferred]

actor Admin
boundary Api as "PdfEndpoints"  ' [Inference] nome modulo
control PdfSvc as "PdfProcessingService"  ' [Inference]
database Db as "PostgreSQL (EF Core)"
cloud Qdrant as "Vector DB"  ' [Inference]

Admin -> Api : POST /pdf/upload [Inference]
(file, gameId)
Api -> PdfSvc : ExtractMetadata/Text(file)
Chunk(text)
PdfSvc -> Db : INSERT PdfDocumentEntity
INSERT TextChunkEntity[*]
PdfSvc -> Qdrant : Upsert Vectors (chunks) [Inference]
Api --> Admin : 202 Accepted / 200 OK (processing status)

@enduml

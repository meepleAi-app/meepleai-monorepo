{
  "info": {
    "_postman_id": "game-management-collection",
    "name": "MeepleAI - Game Management",
    "description": "GameManagement bounded context endpoints for MeepleAI API.\n\n**Includes**:\n- Game catalog management\n- Game sessions (start, pause, resume, complete)\n- Player management\n- Session statistics\n\n**Architecture**: CQRS/MediatR with GameManagement bounded context\n\n**Base URL**: `{{base_url}}/api/v1`\n\n**Version**: 1.0.0\n**Last Updated**: 2025-11-20",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Game Catalog",
      "item": [
        {
          "name": "Get All Games",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Games array is returned', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    ",
                  "    if (jsonData.length > 0) {",
                  "        pm.expect(jsonData[0].id).to.exist;",
                  "        pm.expect(jsonData[0].title).to.exist;",
                  "        ",
                  "        // Save first game ID for later use",
                  "        pm.environment.set('game_id', jsonData[0].id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/games",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "games"]
            },
            "description": "Get all games in the catalog. Requires authentication.\n\n**Query**: GetAllGamesQuery\n**Handler**: GetAllGamesQueryHandler\n**Context**: GameManagement"
          },
          "response": []
        },
        {

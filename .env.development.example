# ============================================================================
# MeepleAI - Development Environment Configuration
# ============================================================================
#
# ENVIRONMENT: Development (Local)
# PURPOSE: Local development with Docker Compose
# LAST UPDATED: 2025-11-22
#
# USAGE:
#   1. Copy this file to .env.development
#   2. Adjust values for your local machine
#   3. Use with: docker compose --env-file .env.development up
#
# SECURITY: Safe for local development, NOT for production
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT IDENTIFICATION
# ----------------------------------------------------------------------------
ENVIRONMENT=development
DEPLOY_ENVIRONMENT=dev

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# ----------------------------------------------------------------------------
# Development: Local PostgreSQL in Docker, simple credentials
POSTGRES_USER=meeple
POSTGRES_PASSWORD=meeplepass
POSTGRES_DB=meepleai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Connection String (auto-built, override if needed)
# DEV: No SSL required, simple pooling
ConnectionStrings__Postgres=Host=postgres;Database=meepleai;Username=meeple;Password=meeplepass;Pooling=true;Minimum Pool Size=2;Maximum Pool Size=20

# ----------------------------------------------------------------------------
# CACHE CONFIGURATION (Redis)
# ----------------------------------------------------------------------------
# Development: Local Redis without password
REDIS_URL=redis:6379
REDIS_PASSWORD=
# Disable L2 cache in development (faster startup, simpler debugging)
HYBRIDCACHE_ENABLE_L2=false

# ----------------------------------------------------------------------------
# VECTOR DATABASE (Qdrant)
# ----------------------------------------------------------------------------
# Development: Local Qdrant, no authentication
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ----------------------------------------------------------------------------
# API BACKEND (ASP.NET Core)
# ----------------------------------------------------------------------------
# Development: HTTP only, detailed logging
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
# Development: Enable detailed errors, Swagger UI, sensitive data logging
ASPNETCORE_DETAILEDERRORS=true

# JWT Configuration
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=http://localhost:3000

# CORS: Allow local frontend
ALLOW_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# FRONTEND (Next.js)
# Remote logging endpoint (frontend)
NEXT_PUBLIC_LOG_ENDPOINT=http://localhost:8080/api/v1/logs

# ----------------------------------------------------------------------------
# Development: Point to local API
NODE_ENV=development
NEXT_PUBLIC_API_BASE=http://localhost:8081
NEXT_PUBLIC_TENANT_ID=dev

# Development: Disable Sentry (no error tracking needed locally)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Resilience: More lenient for local development
NEXT_PUBLIC_RETRY_ENABLED=true
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=2
NEXT_PUBLIC_RETRY_BASE_DELAY=500
NEXT_PUBLIC_RETRY_MAX_DELAY=5000
NEXT_PUBLIC_CIRCUIT_BREAKER_ENABLED=false

# ----------------------------------------------------------------------------
# AI/ML SERVICES
# ----------------------------------------------------------------------------
# Development: Use local Ollama (free, no API keys needed)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# OpenRouter (optional, for testing LLM features)
# Get free tier key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-dev-key-here
# For development, you can use free models:
# - meta-llama/llama-3.3-70b-instruct:free
# - google/gemini-flash-1.5-8b:free

# OpenAI (optional, only if testing OpenAI embeddings)
# OPENAI_API_KEY=sk-proj-your-dev-key-here

# Local Embedding Service
LOCAL_EMBEDDING_URL=http://embedding-service:8000
EMBEDDING_FALLBACK_ENABLED=true

# ----------------------------------------------------------------------------
# PDF PROCESSING SERVICES
# ----------------------------------------------------------------------------
# Development: Fast settings, CPU-only (no GPU required)

# Unstructured Service (Stage 1)
UNSTRUCTURED_STRATEGY=fast
LANGUAGE=ita
MAX_FILE_SIZE=52428800
TIMEOUT=30
QUALITY_THRESHOLD=0.75
MIN_CHARS_PER_PAGE=400

# SmolDocling Service (Stage 2)
DEVICE=cpu
MODEL_NAME=docling-project/SmolDocling-256M-preview
TORCH_DTYPE=float32
IMAGE_DPI=150
MAX_PAGES_PER_REQUEST=10
ENABLE_MODEL_WARMUP=false

# ----------------------------------------------------------------------------
# WORKFLOW AUTOMATION (n8n)
# ----------------------------------------------------------------------------
# Development: Simple basic auth, local database
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Database (shared with main app)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=meepleai
DB_POSTGRESDB_USER=meeple
DB_POSTGRESDB_PASSWORD=meeplepass

# Basic Auth (simple credentials for dev)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# Encryption Key (generate with: openssl rand -hex 32)
# Development: Fixed key for convenience (NEVER use in prod!)
N8N_ENCRYPTION_KEY=dev1234567890abcdef1234567890abcdef1234567890abcdef1234567890ab

# MeepleAI API URL (for workflows)
MEEPLEAI_API_URL=http://api:8080

# Logging
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console

# ----------------------------------------------------------------------------
# OBSERVABILITY (Logging, Metrics, Tracing)
# ----------------------------------------------------------------------------
# Development: Verbose logging, local services

# Seq (Log Aggregation)
SEQ_URL=http://seq:5341
ACCEPT_EULA=Y
# Development: No password required
SEQ_FIRSTRUN_ADMINPASSWORDHASH=

# Prometheus (Metrics)
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_RETENTION_SIZE=10GB

# Grafana (Dashboards)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SERVER_ROOT_URL=http://localhost:3001
GF_USERS_ALLOW_SIGN_UP=false

# Jaeger (Tracing)
COLLECTOR_OTLP_ENABLED=true
SPAN_STORAGE_TYPE=badger
BADGER_EPHEMERAL=true

# Alertmanager (Alerts - disabled in dev)
ALERTMANAGER_ENABLED=false

# ----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ----------------------------------------------------------------------------
# Development: Simple admin credentials for bootstrap
INITIAL_ADMIN_EMAIL=admin@meepleai.dev
INITIAL_ADMIN_PASSWORD=Demo123!
INITIAL_ADMIN_DISPLAY_NAME=Local Admin

# OAuth Providers (MOCK - for testing UI only)
# For real OAuth testing, create dev apps in provider consoles
GOOGLE_OAUTH_CLIENT_ID=mock-google-dev-client-id
GOOGLE_OAUTH_CLIENT_SECRET=mock-google-dev-secret

DISCORD_OAUTH_CLIENT_ID=mock-discord-dev-client-id
DISCORD_OAUTH_CLIENT_SECRET=mock-discord-dev-secret

GITHUB_OAUTH_CLIENT_ID=mock-github-dev-client-id
GITHUB_OAUTH_CLIENT_SECRET=mock-github-dev-secret

# Session Configuration
SESSION_EXPIRATION_DAYS=30
INACTIVITY_TIMEOUT_DAYS=7

# ----------------------------------------------------------------------------
# EMAIL & ALERTING
# ----------------------------------------------------------------------------
# Development: Email disabled (use console logging instead)
ALERTING_ENABLED=false
ALERTING_EMAIL_ENABLED=false
ALERTING_SLACK_ENABLED=false
ALERTING_PAGERDUTY_ENABLED=false

# SMTP (only if testing email features locally)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-dev-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ALERTING_EMAIL_FROM=dev@meepleai.dev
# ALERTING_EMAIL_TO=["developer@example.com"]

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
# Development: All features enabled for testing
FEATURE_PROMPT_DATABASE=true
FEATURE_STREAMING_RESPONSES=true
FEATURE_SETUP_GUIDE_GENERATION=true
FEATURE_CHAT_EXPORT=true
FEATURE_MESSAGE_EDIT_DELETE=true
FEATURE_PDF_UPLOAD=true

# ----------------------------------------------------------------------------
# PERFORMANCE TUNING
# ----------------------------------------------------------------------------
# Development: Faster startup, less caching, simpler configs

# Cache Optimization (disabled for faster iteration)
CACHE_OPTIMIZATION_ENABLED=false
CACHE_WARMING_ENABLED=false

# Follow-up Questions
FOLLOWUP_QUESTIONS_ENABLED=true
FOLLOWUP_QUESTIONS_MAX_PER_RESPONSE=3
FOLLOWUP_QUESTIONS_TIMEOUT_MS=5000

# Quality Evaluation (disabled in dev)
QUALITY_EVALUATION_ENABLED=false
RAG_EVALUATION_ENABLED=false

# ----------------------------------------------------------------------------
# DEVELOPMENT TOOLS
# ----------------------------------------------------------------------------
# Enable hot reload, file watching, etc.
DOTNET_USE_POLLING_FILE_WATCHER=true
DOTNET_WATCH_SUPPRESS_LAUNCH_BROWSER=true

# Next.js Development
NEXT_TELEMETRY_DISABLED=1

# ----------------------------------------------------------------------------
# LOGGING LEVELS
# ----------------------------------------------------------------------------
# Development: Verbose logging for debugging
LOG_LEVEL=Debug
LOGGING__LOGLEVEL__DEFAULT=Debug
LOGGING__LOGLEVEL__MICROSOFT=Information
LOGGING__LOGLEVEL__MICROSOFT_ASPNETCORE=Warning
LOGGING__LOGLEVEL__MICROSOFT_ENTITYFRAMEWORKCORE=Information

# Structured Logging
ENABLE_STRUCTURED_LOGGING=true
ENABLE_METRICS=true

# ----------------------------------------------------------------------------
# DOCKER CONFIGURATION
# ----------------------------------------------------------------------------
# Development: Minimal resource limits for laptop/desktop
COMPOSE_PROJECT_NAME=meepleai-dev

# Resource limits (adjust based on your machine)
# Comment out if you have limited RAM
# POSTGRES_MAX_CONNECTIONS=50
# REDIS_MAX_MEMORY=512mb

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. This configuration optimizes for developer experience:
#    - Fast startup times (no L2 cache, no warmup)
#    - Verbose logging (easier debugging)
#    - Simple credentials (no complex secrets management)
#    - HTTP only (no SSL overhead)
#    - Local services (no cloud dependencies)
#
# 2. NOT SUITABLE FOR PRODUCTION:
#    - Weak passwords
#    - No SSL/TLS
#    - Verbose logging (performance impact)
#    - Disabled security features
#    - Mock OAuth credentials
#
# 3. For testing production-like features:
#    - Use staging environment (.env.staging)
#    - Or override specific variables in .env.development.local
#
# 4. Quick Start:
#    cp .env.development.example .env.development
#    docker compose --env-file .env.development up -d
#
# 5. Troubleshooting:
#    - Check logs: docker compose logs -f api
#    - Health check: curl http://localhost:8080/health
#    - See: docs/05-operations/runbooks/general-troubleshooting.md
# ============================================================================

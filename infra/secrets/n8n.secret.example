# N8N Workflow Automation Credentials
# OPTIONAL - Info logged if missing (n8n disabled)
# Copy this file to infra/secrets/n8n.secret and fill in values

# Encryption key for n8n credential storage (generate with: openssl rand -base64 32)
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here

# Basic authentication password for n8n web UI
N8N_BASIC_AUTH_PASSWORD=your_n8n_basic_auth_password_here

# Logging
LOG_LEVEL=INFO

# File Processing
MAX_FILE_SIZE=52428800  # 50MB
MAX_PAGES_PER_REQUEST=20  # Prevent excessive processing
TIMEOUT=60  # seconds (longer than Unstructured due to VLM)

# Temp directories
TEMP_DIR=/tmp/pdf-processing
MODEL_CACHE_DIR=/root/.cache/huggingface

# SmolDocling Configuration
DEVICE=cuda  # or cpu
MODEL_NAME=docling-project/SmolDocling-256M-preview
MAX_NEW_TOKENS=2048
TORCH_DTYPE=bfloat16  # or float16, float32

# PDF to Image Conversion
IMAGE_DPI=300  # Higher DPI = better quality but slower
IMAGE_FORMAT=PNG  # or JPEG

# Quality Thresholds
QUALITY_THRESHOLD=0.70  # Lower than Unstructured (Stage 2 fallback)
MIN_CHARS_PER_PAGE=300  # VLM may extract less text due to layout focus

# Server Configuration
HOST=0.0.0.0
PORT=8002
WORKERS=1  # VLM models: 1 worker, scale horizontally instead

# Observability
ENABLE_METRICS=true
ENABLE_STRUCTURED_LOGGING=true

sk><g mask="url(#a)"><path fill-rule="evenodd" clip-rule="evenodd" d="M15.136.462 26.994 13.37H1.166L15.136.462Z" fill="#FB2942"/></g></g><g opacity=".85"><mask id="b" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="1" y="3" width="28" height="13"><path d="M28.078 3.188H1.166v12.349h26.912V3.188Z" fill="#fff"/></mask><g mask="url(#b)"><path fill-rule="evenodd" clip-rule="evenodd" d="m21.912 3.185 6.166 12.349-26.912-2.166L21.912 3.185Z" fill="#FB2942"/></g></g><g opacity=".9"><mask id="c" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="8" width="27" height="8"><path d="M26.994 8.001H0v7.431h26.994V8.001Z" fill="#fff"/></mask><g mask="url(#c)"><path fill-rule="evenodd" clip-rule="evenodd" d="m4.125 8.001 22.87 5.343L0 15.432l4.125-7.431Z" fill="#FB2942"/></g></g></svg></div></a></div></div></div></div></div><div id="complaint" class="overlay"><div class="modal"><div class="modal__inner modal__inner--complaint"><div class="modal__close w-embed"><button class="button button--plain js-modal-close" type="button" data-target="complaint">
<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
  <path d="M15.6575 15.6568L4.34375 4.34314" stroke="white" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>

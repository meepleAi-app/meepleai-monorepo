{
  "info": {
    "_postman_id": "health-check-collection",
    "name": "MeepleAI - Health Check",
    "description": "Health check and readiness endpoints for MeepleAI API.\n\n**Purpose**: Verify API is running and all dependencies (PostgreSQL, Redis, Qdrant) are accessible.\n\n**Base URL**: `{{base_url}}/health`\n\n**Version**: 1.0.0\n**Last Updated**: 2025-11-20",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has healthy status', function() {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql('Healthy');",
              "});",
              "",
              "pm.test('Response time is acceptable', function() {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Health check endpoint. Verifies API is running and all dependencies (PostgreSQL, Redis, Qdrant) are accessible.\n\n**No authentication required.**"
      },
      "response": []
    }
  ]
}

                  "",
                  "pm.test('Answer is comprehensive', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.answer.length).to.be.above(50);",
                  "});",
                  "",
                  "pm.test('Multiple sources cited', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.sources.length).to.be.above(1);",
                  "});"
                ],

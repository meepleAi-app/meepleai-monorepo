              "raw": "{{baseUrl}}/api/{{apiVersion}}/knowledge-base/ask",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "knowledge-base", "ask"]
            },
            "description": "Test full RAG pipeline via AskQuestionQueryHandler.\nFlow: Search → Build prompt → LLM → Quality tracking"
          },
          "response": []
        },
        {
          "name": "Ask - Complex Multi-Part Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Q&A successful', function() {",
                  "    pm.response.to.have.status(200);",

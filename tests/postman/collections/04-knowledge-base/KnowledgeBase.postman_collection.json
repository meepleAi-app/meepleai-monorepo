        {
          "name": "Ask - Confidence Score Validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Overall confidence is weighted average (70/30)', function() {",
                  "    const response = pm.response.json();",
                  "    const searchConf = response.searchConfidence;",
                  "    const llmConf = response.llmConfidence;",
                  "    const overallConf = response.overallConfidence;",
                  "    ",
                  "    // Calculate expected: 70% search + 30% LLM",
                  "    const expected = (searchConf * 0.7) + (llmConf * 0.3);",
                  "    const tolerance = 0.01;",
                  "    ",
                  "    pm.expect(overallConf).to.be.closeTo(expected, tolerance);",
                  "    console.log('Search:', searchConf, '| LLM:', llmConf, '| Overall:', overallConf);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{game_id}}\",\n  \"query\": \"What are the rules?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/agents/qa",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents", "qa"]
            },
            "description": "Test QualityTrackingDomainService confidence calculation.\n\nVerifies 70/30 weighting formula (ADR-005: Cosine Similarity Consensus)."
          },
          "response": []
        }
      ],
      "description": "Q&A agent with RAG pipeline and quality tracking"

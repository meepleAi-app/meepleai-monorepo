    {
      "name": "4. KnowledgeBase (Optional)",
      "description": "RAG search and Q&A - requires game with indexed content. Tests skip gracefully if no game available.",
      "item": [
        {
          "name": "Search - Requires Game",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Skip if no game ID available (CI without seed data)",
                  "const testGameId = pm.collectionVariables.get('testGameId');",
                  "if (!testGameId) {",
                  "    console.log('SKIP: No testGameId - KnowledgeBase search requires game data');",
                  "    pm.execution.skipRequest();",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Accept both 200 (success) and 400 (no indexed content)",
                  "pm.test('Status code is 200 or 400', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Search results returned', function() {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json.success).to.be.true;",
                  "        pm.expect(json.results).to.be.an('array');",
                  "    });",
                  "} else {",
                  "    pm.test('Error message for missing content', function() {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json.error).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{testGameId}}\",\n  \"query\": \"test query\",\n  \"topK\": 5,\n  \"minScore\": 0.5,\n  \"searchMode\": \"hybrid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/knowledge-base/search",
              "host": ["{{baseUrl}}"],
              "path": ["knowledge-base", "search"]
            }
          }
        },
        {
          "name": "Search - Empty Query (400)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const testGameId = pm.collectionVariables.get('testGameId');",
                  "if (!testGameId) {",
                  "    console.log('SKIP: No testGameId');",
                  "    pm.execution.skipRequest();",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 for empty query', function() {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message is returned', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{testGameId}}\",\n  \"query\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/knowledge-base/search",
              "host": ["{{baseUrl}}"],
              "path": ["knowledge-base", "search"]
            }
          }
        },
        {
          "name": "Search - Invalid Game ID (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 for invalid game ID', function() {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message is returned', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.exist;",

{
  "info": {
    "_postman_id": "administration-collection",
    "name": "MeepleAI - Administration",
    "description": "Administration bounded context endpoints for MeepleAI API.\n\n**Includes**:\n- User management and search\n- AI request logs\n- System alerts\n- Audit logs\n- Analytics\n\n**Architecture**: CQRS/MediatR with Administration bounded context\n\n**Base URL**: `{{base_url}}/api/v1`\n\n**Authorization**: Most endpoints require Admin role\n\n**Version**: 1.0.0\n**Last Updated**: 2025-11-20",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Logs & Monitoring",
      "item": [
        {
          "name": "Get Logs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Logs array is returned', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/logs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "logs"]
            },
            "description": "Get AI request logs (last 100 entries). Requires Admin role.\n\n**Query**: GetLogsQuery\n**Handler**: GetLogsQueryHandler\n**Context**: Administration"
          },
          "response": []
        }
      ],
      "description": "System logs and monitoring"
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Search Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Users array is returned', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Max 10 results returned', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.length).to.be.at.most(10);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users/search?query=demo",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "demo"
                }
              ]
            },
            "description": "Search users by display name or email. Max 10 results. Requires authentication.\n\n**Query**: SearchUsersQuery\n**Handler**: SearchUsersQueryHandler\n**Context**: Administration"
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User data is returned', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.email).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}"]
            },
            "description": "Get user details by ID. Requires Admin role.\n\n**Query**: GetUserByIdQuery\n**Handler**: GetUserByIdQueryHandler\n**Context**: Administration"
          },
          "response": []
        }
      ],
      "description": "User administration and management"
    }
  ]
}

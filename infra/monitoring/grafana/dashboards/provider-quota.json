{
  "title": "LLM Provider Quota (G4)",
  "uid": "provider-quota-985",
  "tags": ["meepleai", "llm", "provider", "quota"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Remaining USD per provider",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "meepleai_provider_quota_remaining_usd",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Used USD per provider",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "meepleai_provider_quota_used_usd",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 2 }
      },
      "options": {
        "colorMode": "value",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Used USD over time (per provider)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "meepleai_provider_quota_used_usd",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Remaining/limit ratio (alert threshold view)",
      "description": "Recording rule meepleai:provider:quota_remaining_ratio. Alerts fire below 0.20 (warn) and 0.05 (critical). Providers without enforced limit do not appear here.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "meepleai:provider:quota_remaining_ratio",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "thresholdsStyle": { "mode": "line+area" }
          }
        }
      }
    }
  ]
}

# Logging
LOG_LEVEL=INFO

# File Processing
MAX_FILE_SIZE=52428800  # 50MB
TIMEOUT=30
TEMP_DIR=/tmp/pdf-extraction

# Unstructured Configuration
UNSTRUCTURED_STRATEGY=fast  # or hi_res
LANGUAGE=ita

# Chunking Configuration
CHUNK_MAX_CHARACTERS=2000
CHUNK_OVERLAP=200

# Quality Thresholds
QUALITY_THRESHOLD=0.80
MIN_CHARS_PER_PAGE=500

# Server Configuration
HOST=0.0.0.0
PORT=8001
WORKERS=4

# Observability
ENABLE_METRICS=true
ENABLE_STRUCTURED_LOGGING=true

graph TB
    subgraph SGC["🌐 SharedGameCatalog Context"]
        SharedGame[SharedGame Aggregate]
        ShareReq[ShareRequest Workflow]
        DeleteReq[DeleteRequest Workflow]
        BadgeSystem[Badge System]
        FaqMgmt[FAQ Management]
    end

    subgraph GM["🎮 GameManagement Context"]
        PrivateGame[Private Games]
    end

    subgraph UL["📚 UserLibrary Context"]
        Library[User Library]
    end

    subgraph DocProc["📄 DocumentProcessing Context"]
        PdfProc[PDF Processing]
    end

    subgraph KB["🧠 KnowledgeBase Context"]
        RAG[RAG System]
        QuickQGen[Quick Question Gen]
    end

    subgraph UN["🔔 UserNotifications Context"]
        Notif[Notification System]
    end

    subgraph Admin["📊 Administration Context"]
        Audit[Audit Logging]
    end

    subgraph External["🌍 External APIs"]
        BGG[BoardGameGeek API]
    end

    %% Event-Driven Communication - Outbound
    ShareReq -->|ShareRequestCreatedEvent| Notif
    ShareReq -->|ShareRequestApprovedEvent| Notif
    DeleteReq -->|DeleteRequestCreatedEvent| Audit
    SharedGame -->|GamePublishedEvent| Notif
    SharedGame -->|GamePublishedEvent| Admin
    BadgeSystem -->|BadgeEarnedEvent| Notif
    SharedGame -->|GameSoftDeletedEvent| KB

    %% Direct Dependencies
    ShareReq -.->|Reference private game| PrivateGame
    SharedGame -.->|Reference PDFs| PdfProc
    SharedGame -.->|Import BGG metadata| BGG
    Library -.->|Reference shared games| SharedGame

    %% AI Integration
    QuickQGen -.->|Generate Q&A from PDF| RAG
    SharedGame -.->|Document approved for RAG| PdfProc

    %% Styling
    classDef sgcStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef gmStyle fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    classDef ulStyle fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef docStyle fill:#e3f2fd,stroke:#2196f3,stroke-width:2px
    classDef kbStyle fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef unStyle fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    classDef adminStyle fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef extStyle fill:#fafafa,stroke:#757575,stroke-width:2px

    class SharedGame,ShareReq,DeleteReq,BadgeSystem,FaqMgmt sgcStyle
    class PrivateGame gmStyle
    class Library ulStyle
    class PdfProc docStyle
    class RAG,QuickQGen kbStyle
    class Notif unStyle
    class Audit adminStyle
    class BGG extStyle

<audio class="audio js-mission-audio" src="https://old.czechgames.com/files/other-mp3/space-alert-2-jp/easy-mission-03.mp3" controls="true" style="width: 100%;"></audio></div></div></div></div></div></div><h3 id="rules-title" class="h5 title margin--bottom-2">Choose your preferred language</h3><div class="w-layout-grid grid grid--flex grid--gap-h-small grid--gap-v-small margin--bottom-3 margin--bottom-5-lg"><div class="cell cell--shrink"><a data-lang="en" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c6576ea005cf43fac3630_flag-united-states.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">English</div></a></div><div class="cell cell--shrink"><a data-lang="cz" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c65d7666abcf80ebc1ac4_flag-czech-republic.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">Czech</div></a></div><div class="cell cell--shrink"><a data-lang="de" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c663651832883bf447c98_flag-german.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">German</div></a></div><div class="cell cell--shrink"><a data-lang="fr" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c65d77b1da823118df976_flag-france.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">France</div></a></div><div class="cell cell--shrink"><a data-lang="it" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c65d77e56661d83bfe764_flag-italy.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">Italian</div></a></div><div class="cell cell--shrink"><a data-lang="nl" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c674e0308a2cae994599f_flag-netherlands.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">Netherlands</div></a></div><div class="cell cell--shrink"><a data-lang="jp" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c6576f497a96a410b045f_flag-korea.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">Korean</div></a></div><div class="cell cell--shrink"><a data-lang="es" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c6576f2a7284d61529fbd_flag-spain.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">Spanish</div></a></div><div class="cell cell--shrink"><a data-lang="pl" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c6636ce35b60123fe3280_flag-polish.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">Polish</div></a></div><div class="cell cell--shrink"><a data-lang="pt" href="#" class="file file--lang radius radius--small js-mission-lang w-inline-block"><img src="https://cdn.prod.website-files.com/67d17a45b4e1484b40ea8857/681c65d7255d99be8a036f0f_flag-portugal.svg" loading="lazy" width="40" height="40" alt=""/><div class="text text--default text-weight-bold color--black">Portugese</div></a></div></div><div class="w-layout-grid grid grid--flex"><div class="cell cell--shrink"><a href="#" data-target="mission-generator" style="background-color:hsla(145.99999999999997, 46.88%, 25.10%, 1.00)" class="button js-modal-handler is--disabled js-mission-button w-button">Start Mission Generator</a></div></div><div class="w-embed w-script"><style>
.file--lang.is--active,
.button--choice.is--active {
	background-color: hsla(145.99999999999997, 46.88%, 25.10%, 1.00) !important;
  border-color:  hsla(145.99999999999997, 46.88%, 25.10%, 1.00) !important;
  
  .icon,
  .text {
  	color: #ffffff !important;
  }
}
</style>

<script>
const missionLangs = document.querySelectorAll('.js-mission-lang');
const missionFiles = document.querySelectorAll('.js-mission-file');
const missionName = document.querySelector('.js-mission-name');
const audioSection = document.querySelector('.js-mission-audio-section');
const audioElement = document.querySelector('.js-mission-audio');
const audioButton = document.querySelector('.js-mission-button');
const audioStopButton = document.querySelector('.js-mission-audio-stop');

let selectedLang = '';
let selectedFile = '';

function stopAudio() {
  if (audioElement) {
    audioElement.pause();
    audioElement.currentTime = 0;
  }
}

// Kliknutí na tlačítko pro zavření modalu
if (audioStopButton) {
  audioStopButton.addEventListener('click', () => {
    stopAudio();
  });
}

// Kliknutí mimo modal (na overlay)
document.querySelectorAll('.overlay').forEach((overlay) => {
  overlay.addEventListener('click', (e) => {
    if (!e.target.closest('.modal__inner')) {
      overlay.classList.remove('is--open');
      document.body.classList.remove('is-modal-open');

      stopAudio();
    }
  });
});

// jazyk
missionLangs.forEach(link => {
  link.addEventListener('click', e => {
    e.preventDefault();
    missionLangs.forEach(el => el.classList.remove('is--active'));
    link.classList.add('is--active');

    selectedLang = link.dataset.lang;
    console.log('Zvolený jazyk:', selectedLang);

    // Povolit tlačítko
    if (audioButton) {
      audioButton.classList.remove('is--disabled');
    }
  });
});

// soubor & výsledky
missionFiles.forEach(link => {
  link.addEventListener('click', e => {
    e.preventDefault();
    missionFiles.forEach(el => el.classList.remove('is--active'));
    link.classList.add('is--active');

    let originalFile = link.dataset.file;

    // Pokud jde o výsledek, uprav číslo na náhodné 01–11
    if (link.classList.contains('js-mission-file-result')) {
      originalFile = originalFile.replace(/-(\d+)\.mp3$/, () => {
        const randomNumber = Math.floor(Math.random() * 5) + 1;
        return `-${randomNumber.toString().padStart(2, '0')}.mp3`;
      });
    }

    selectedFile = originalFile;

    // Zobraz název
    if (missionName) {
      missionName.innerHTML = selectedFile;
    }

    // Zobraz audio sekci
    if (audioSection) {
      audioSection.classList.remove('hide');
    }

    // Vygeneruj URL a přehraj
    if (selectedLang && selectedFile && audioElement) {
      const url = `https://filemanager.czechgames.com/assets/audios/space-alert/space-alert-${selectedLang}/${selectedFile}`;
      console.log('Final URL:', url);

      audioElement.src = url;
      audioElement.load();
      audioElement.play();
    }
  });
});
</script></div></div></div><div class="hr w-embed"><hr style="margin: 0 auto; border: 0.0625rem solid #F2F2F2;" /></div><div id="related-games" class="article__section"><h2 style="color:hsla(145.99999999999997, 46.88%, 25.10%, 1.00)" class="h2 title title--upper margin--bottom-3 margin--bottom-4-lg">Related games &amp; expansions</h2><div class="w-dyn-list"><div role="list" class="grid grid--flex grid--gap-h-small grid--gap-v-small w-dyn-items"><div role="listitem" class="cell cell--12 cell--6-md cell--4-lg w-dyn-item"><a style="background-color:#3dd39b" href="/games/lost-ruins-of-arnak-adventure-chest" class="card card--game margin--bottom-1 w-inline-block"><div class="w-embed"><div class="card__background" style="background: radial-gradient(126.33% 94.75% at 50% 22.5%, #3dd39b 0%, hsla(157.55725190839695, 73.31%, 34.07%, 1.00) 100%), #16140E;"></div></div><div class="card__body text--center flex flex--column height--100"><div class="w-layout-grid grid grid--flex grid--justify margin--bottom-1 margin--bottom-2-lg"><div class="cell cell--shrink"><div class="badge badge--white badge--category"><div class="badge__icon w-condition-invisible w-embed"><svg class="icon" width="12" height="13" viewBox="0 0 12 13" fill="none" xmlns="http://www.w3.org/2000/svg">

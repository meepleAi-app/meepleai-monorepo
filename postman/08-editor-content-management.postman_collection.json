    {
      "name": "State Templates",
      "item": [
        {
          "name": "Generate State Template (AI)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/state-template/generate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "state-template", "generate"]
            },
            "description": "Generate state template using AI from game rules"
          }
        },
        {
          "name": "Get Active State Template",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/state-template",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "state-template"]
            },
            "description": "Get the currently active state template"
          }
        },
        {
          "name": "List Template Versions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.versions && jsonData.versions.length > 0) {",
                  "        pm.collectionVariables.set('templateId', jsonData.versions[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/shared-games/{{gameId}}/state-template/versions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "shared-games", "{{gameId}}", "state-template", "versions"]
            },
            "description": "List all state template versions"
          }
        },
        {
          "name": "Update State Template",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerState\": {\n    \"resources\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"brick\": { \"type\": \"number\", \"default\": 0, \"min\": 0 },\n        \"wood\": { \"type\": \"number\", \"default\": 0, \"min\": 0 },\n        \"wheat\": { \"type\": \"number\", \"default\": 0, \"min\": 0 }\n      }\n    },\n    \"score\": { \"type\": \"number\", \"default\": 0 },\n    \"settlements\": { \"type\": \"number\", \"default\": 0, \"max\": 5 }\n  },\n  \"sharedState\": {\n    \"currentTurn\": { \"type\": \"number\", \"default\": 1 },\n    \"phase\": { \"type\": \"string\", \"enum\": [\"setup\", \"main\", \"end\"] }\n  }\n}"
            },

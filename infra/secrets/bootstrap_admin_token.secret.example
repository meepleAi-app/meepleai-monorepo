# Bootstrap-admin token (C5)
#
# Single-use token that elevates the *first* /auth/register call to Admin.
# Copy this file to infra/secrets/bootstrap_admin_token.secret and fill in
# the value. The token is read by the API as Authentication:BootstrapAdminToken
# (env var alias: AUTHENTICATION__BOOTSTRAPADMINTOKEN).
#
# Generate a high-entropy value:
#   openssl rand -base64 48
#
# Operational rotation (REQUIRED post-bootstrap):
#   1. After the first admin successfully registers, the SystemConfiguration
#      flag BootstrapAdminCreated is set to true. Subsequent valid-token
#      registrations fall back to Role.User even with the right token.
#   2. Defense-in-depth: rotate the env var to an empty string (or leave
#      this secret file blank) immediately after onboarding so a stolen
#      token cannot be replayed if the flag is ever cleared by a manual op.
#
# Constant-time comparison (CryptographicOperations.FixedTimeEquals) makes
# remote timing attacks impractical, but token rotation remains the primary
# defence against credential exposure.

AUTHENTICATION__BOOTSTRAPADMINTOKEN=replace_with_openssl_rand_base64_48_value

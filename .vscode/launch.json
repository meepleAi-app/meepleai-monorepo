{
  "version": "0.2.0",
  "configurations": [
    // .NET API Backend
    {
      "name": ".NET API: Launch",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/apps/api/src/Api/bin/Debug/net9.0/MeepleAI.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/api/src/Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:8080"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/apps/api/src/Api/Views"
      }
    },
    {
      "name": ".NET API: Attach",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    },
    
    // Next.js Frontend
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Next.js: debug full stack",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    
    // Python Services
    {
      "name": "Python: Embedding Service",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/apps/embedding-service",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/apps/embedding-service"
      }
    },
    {
      "name": "Python: Unstructured Service",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8001"],
      "cwd": "${workspaceFolder}/apps/unstructured-service",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/apps/unstructured-service"
      }
    },

    // E2E Tests
    {
      "name": "Playwright: Debug E2E Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/apps/web/node_modules/.bin/playwright",
      "args": ["test", "--debug"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal"
    },

    // Full Stack (API + Frontend)
    {
      "name": "Full Stack: API + Frontend",
      "type": "compound",
      "configurations": [".NET API: Launch", "Next.js: debug server-side"],
      "presentation": {
        "hidden": false,
        "group": "full-stack",
        "order": 1
      }
    },
    {
      "name": "Full Stack: Complete System",
      "type": "compound",
      "configurations": [
        ".NET API: Launch",
        "Next.js: debug server-side",
        "Python: Embedding Service"
      ],
      "presentation": {
        "hidden": false,
        "group": "full-stack",
        "order": 2
      }
    }
  ]
}
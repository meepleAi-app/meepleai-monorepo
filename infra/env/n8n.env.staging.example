# n8n Workflow Automation - Staging
# Production-like configuration for testing workflows
#
# USAGE:
#   cp n8n.env.staging.example n8n.env.staging
#   vim n8n.env.staging  # Replace <REPLACE_*>

# Server Configuration
GENERIC_TIMEZONE=Europe/Rome
N8N_HOST=<REPLACE_WITH_STAGING_N8N_HOST>
# Example: workflows-staging.meepleai.dev
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=<REPLACE_WITH_STAGING_N8N_WEBHOOK_URL>
# Example: https://workflows-staging.meepleai.dev/

# Execution Settings
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
EXECUTIONS_TIMEOUT=1800
EXECUTIONS_TIMEOUT_MAX=3600

# Database (shared with main app)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=meepleai_staging
DB_POSTGRESDB_USER=meepleai_stg
# DB_POSTGRESDB_PASSWORD from Docker Secret

# MeepleAI API Integration
MEEPLEAI_API_URL=<REPLACE_WITH_STAGING_API_URL>
# Example: https://staging-api.meepleai.dev

# Service Account Session Token
# Generate with: pwsh tools/setup-n8n-service-account.ps1 --environment staging
N8N_SERVICE_SESSION=<REPLACE_WITH_SERVICE_SESSION_TOKEN>

# Basic Auth
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin_staging
# N8N_BASIC_AUTH_PASSWORD from Docker Secret

# Encryption Key
# ⚠️  CRITICAL: Generate unique key for staging
# Generate with: openssl rand -hex 32
# N8N_ENCRYPTION_KEY from Docker Secret

# Logging
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console,file

# Editor
N8N_EDITOR_BASE_URL=<REPLACE_WITH_STAGING_N8N_WEBHOOK_URL>

# ============================================================================
# SECRETS (DO NOT set here - use Docker Secrets)
# ============================================================================
# DB_POSTGRESDB_PASSWORD_FILE=/run/secrets/postgres-password
# N8N_BASIC_AUTH_PASSWORD_FILE=/run/secrets/n8n-basic-auth-password
# N8N_ENCRYPTION_KEY_FILE=/run/secrets/n8n-encryption-key
#
# See: infra/secrets/staging/

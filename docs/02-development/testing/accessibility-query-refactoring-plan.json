  "team_guidelines": {
    "query_priority_order": [
      "1. getByRole (preferred for interactive elements)",
      "2. getByLabelText (preferred for form inputs)",
      "3. getByText (for non-interactive text content)",
      "4. getByDisplayValue (for form fields with values)",
      "5. getByAltText (for images)",
      "6. getByTitle (for title attributes)",
      "7. getByTestId (last resort, document why needed)"
    ],
    "when_to_use_testid": [
      "Complex SVG/canvas elements without semantic meaning",
      "Performance-critical virtualized components",

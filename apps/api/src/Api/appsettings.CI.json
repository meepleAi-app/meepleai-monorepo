{
  "ConnectionStrings": {
    "Comment": "SEC-I1: Test-only credentials for CI ephemeral containers. Not a production secret. Override via CONNECTIONSTRINGS__POSTGRES env var.",
    "Postgres": "Host=localhost;Port=5432;Database=meepleai_test;Username=postgres;Password=testpass123"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Features": {
    "PromptDatabase": false
  },
  "TestEndpoints": {
    "Enabled": true,
    "MaxErrorCount": 1000,
    "MaxDurationSeconds": 300
  },
  "HealthChecks": {
    "Postgres": {
      "Enabled": false
    },
    "Qdrant": {
      "Enabled": false
    },
    "Redis": {
      "Enabled": false
    },
    "N8n": {
      "Enabled": false
    }
  },
  "RateLimit": {
    "Comment": "Issue #2286: Disable rate limiting for K6 performance tests",
    "User": {
      "MaxTokens": 999999,
      "RefillRate": 10000.0
    },
    "Anonymous": {
      "MaxTokens": 999999,
      "RefillRate": 10000.0
    }
  }
}

# ============================================================================
# MeepleAI - Production Environment Configuration
# ============================================================================
#
# ENVIRONMENT: Production (Live)
# PURPOSE: Production deployment for end users
# LAST UPDATED: 2025-11-22
#
# ⚠️  CRITICAL SECURITY WARNING ⚠️
#   - NEVER commit this file with real values
#   - Use Docker Secrets or secret management service (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault)
#   - Rotate all secrets regularly (90 days recommended)
#   - Audit access to production credentials
#   - Monitor for unauthorized access
#
# USAGE:
#   1. Copy this file to .env.production (NEVER commit!)
#   2. Replace ALL <REPLACE_*> placeholders with actual production values
#   3. Store in secure secret management system
#   4. Use Docker Secrets for sensitive values
#   5. Deploy with: docker compose -f compose.prod.yml up -d
#
# SECURITY: PRODUCTION CREDENTIALS - HIGHEST SECURITY LEVEL
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT IDENTIFICATION
# ----------------------------------------------------------------------------
ENVIRONMENT=production
DEPLOY_ENVIRONMENT=prod

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# ----------------------------------------------------------------------------
# Production: Managed database service recommended (AWS RDS, Azure Database, etc.)
POSTGRES_USER=<REPLACE_WITH_PROD_DB_USER>
# CRITICAL: Use Docker Secret, NOT environment variable
# POSTGRES_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
POSTGRES_DB=meepleai_production
POSTGRES_HOST=<REPLACE_WITH_PROD_DB_HOST>
POSTGRES_PORT=5432

# Connection String
# PRODUCTION: SSL REQUIRED, connection pooling, timeouts
# ⚠️  Use Docker Secret for password via Password_File parameter
ConnectionStrings__Postgres=Host=<REPLACE_WITH_PROD_DB_HOST>;Database=meepleai_production;Username=<REPLACE_WITH_PROD_DB_USER>;Password_File=/run/secrets/postgres-password;SSL Mode=Require;Trust Server Certificate=false;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=100;Connection Idle Lifetime=300;Command Timeout=30;Keepalive=30

# Backup Configuration
POSTGRES_BACKUP_ENABLED=true
POSTGRES_BACKUP_SCHEDULE=0 3 * * *
POSTGRES_BACKUP_RETENTION_DAYS=30

# ----------------------------------------------------------------------------
# CACHE CONFIGURATION (Redis)
# ----------------------------------------------------------------------------
# Production: Managed Redis (AWS ElastiCache, Azure Cache for Redis)
REDIS_URL=<REPLACE_WITH_PROD_REDIS_HOST>:6380
# ⚠️  Production: SSL enabled, password via Docker Secret
# REDIS_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
REDIS_CONFIGURATION=<REPLACE_WITH_PROD_REDIS_HOST>:6380,password=<FROM_SECRET>,ssl=true,connectTimeout=5000,connectRetry=3,abortConnect=false,syncTimeout=5000

# Enable L2 cache (MANDATORY in production)
HYBRIDCACHE_ENABLE_L2=true
HYBRIDCACHE_DEFAULT_EXPIRATION=24:00:00
HYBRIDCACHE_MAX_PAYLOAD_BYTES=10485760
HYBRIDCACHE_L2_TIMEOUT=00:00:02

# ----------------------------------------------------------------------------
# VECTOR DATABASE (Qdrant)
# ----------------------------------------------------------------------------
# Production: Qdrant Cloud recommended for managed service
QDRANT_URL=<REPLACE_WITH_PROD_QDRANT_URL>
# If using Qdrant Cloud (RECOMMENDED):
# QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
# ⚠️  Use Docker Secret for API key
# QDRANT_API_KEY=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# Collection name
QDRANT_COLLECTION_NAME=meepleai_rules_production

# Backup
QDRANT_BACKUP_ENABLED=true
QDRANT_BACKUP_SCHEDULE=0 4 * * *

# ----------------------------------------------------------------------------
# API BACKEND (ASP.NET Core)
# ----------------------------------------------------------------------------
# Production: HTTPS ONLY, strict security
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://+:8080;http://+:8081
ASPNETCORE_HTTPS_PORT=443
# Production: Disable detailed errors (security)
ASPNETCORE_DETAILEDERRORS=false

# SSL Certificate (if using HTTPS directly, not behind load balancer)
# Recommended: Use load balancer/reverse proxy for SSL termination
# ASPNETCORE_Kestrel__Certificates__Default__Path=/etc/ssl/certs/meepleai.pfx
# ASPNETCORE_Kestrel__Certificates__Default__Password_File=/run/secrets/ssl-cert-password

# JWT Configuration
JWT_ISSUER=<REPLACE_WITH_PROD_API_URL>
JWT_AUDIENCE=<REPLACE_WITH_PROD_WEB_URL>

# CORS: PRODUCTION DOMAINS ONLY (NO WILDCARDS)
ALLOW_ORIGIN=<REPLACE_WITH_PROD_WEB_URL>
# Multiple origins (if needed):
# ALLOWED_ORIGINS=https://app.meepleai.dev,https://www.meepleai.dev

# ----------------------------------------------------------------------------
# FRONTEND (Next.js)
# ----------------------------------------------------------------------------
# Production: Optimized build
NODE_ENV=production
NEXT_PUBLIC_API_BASE=<REPLACE_WITH_PROD_API_URL>
NEXT_PUBLIC_TENANT_ID=production

# Sentry (Error Tracking - MANDATORY for production)
NEXT_PUBLIC_SENTRY_DSN=<REPLACE_WITH_SENTRY_DSN>
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
SENTRY_ORG=<REPLACE_WITH_SENTRY_ORG>
SENTRY_PROJECT=<REPLACE_WITH_SENTRY_PROJECT>
# ⚠️  Use Docker Secret
# SENTRY_AUTH_TOKEN=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# Resilience: Production-optimized
NEXT_PUBLIC_RETRY_ENABLED=true
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=3
NEXT_PUBLIC_RETRY_BASE_DELAY=1000
NEXT_PUBLIC_RETRY_MAX_DELAY=10000
NEXT_PUBLIC_CIRCUIT_BREAKER_ENABLED=true
NEXT_PUBLIC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
NEXT_PUBLIC_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
NEXT_PUBLIC_CIRCUIT_BREAKER_TIMEOUT=60000

# Performance
NEXT_PUBLIC_REQUEST_DEDUP_ENABLED=true
NEXT_PUBLIC_REQUEST_DEDUP_TTL=100

# ----------------------------------------------------------------------------
# AI/ML SERVICES
# ----------------------------------------------------------------------------
# Production: Cloud services for reliability and scalability

# Embedding Provider
# RECOMMENDED: Use OpenAI for production (better reliability)
EMBEDDING_PROVIDER=openai
# ⚠️  Use Docker Secret
# OPENAI_API_KEY=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
EMBEDDING_MODEL=text-embedding-3-small

# Alternative: Ollama (if self-hosted with HA setup)
# EMBEDDING_PROVIDER=ollama
# OLLAMA_URL=http://ollama-ha.internal:11434
# EMBEDDING_MODEL=nomic-embed-text

# OpenRouter (LLM - MANDATORY for chat)
# ⚠️  Use Docker Secret
# OPENROUTER_API_KEY=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
# Monitor usage: https://openrouter.ai/activity

# Fallback Configuration
LOCAL_EMBEDDING_URL=http://embedding-service:8000
EMBEDDING_FALLBACK_ENABLED=true

# AI Provider Configuration (BGAI-021)
AI_PREFERRED_PROVIDER=OpenRouter
AI_PROVIDERS__OLLAMA__ENABLED=true
AI_PROVIDERS__OLLAMA__BASEURL=http://ollama:11434
AI_PROVIDERS__OPENROUTER__ENABLED=true
AI_PROVIDERS__OPENROUTER__BASEURL=https://openrouter.ai/api/v1
AI_FALLBACK_CHAIN=OpenRouter,Ollama

# Circuit Breaker for AI calls
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_OPEN_DURATION_SECONDS=30
AI_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# LLM Routing (User-tier based)
LLM_ROUTING_ANONYMOUS_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_ROUTING_USER_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_ROUTING_EDITOR_MODEL=anthropic/claude-3.5-haiku
LLM_ROUTING_ADMIN_MODEL=anthropic/claude-3.5-sonnet
LLM_ROUTING_PREMIUM_MODEL=anthropic/claude-3.5-sonnet

# ----------------------------------------------------------------------------
# PDF PROCESSING SERVICES
# ----------------------------------------------------------------------------
# Production: High quality, GPU-accelerated

# Unstructured Service (Stage 1)
UNSTRUCTURED_STRATEGY=hi_res
LANGUAGE=ita
MAX_FILE_SIZE=104857600
TIMEOUT=35
QUALITY_THRESHOLD=0.80
MIN_CHARS_PER_PAGE=500

# SmolDocling Service (Stage 2)
# Production: GPU RECOMMENDED for performance
DEVICE=cuda
MODEL_NAME=docling-project/SmolDocling-256M-preview
TORCH_DTYPE=bfloat16
IMAGE_DPI=300
MAX_PAGES_PER_REQUEST=20
ENABLE_MODEL_WARMUP=true

# Resource limits
PDF_PROCESSING_MAX_CONCURRENT=5
PDF_PROCESSING_QUEUE_SIZE=100

# ----------------------------------------------------------------------------
# WORKFLOW AUTOMATION (n8n)
# ----------------------------------------------------------------------------
# Production: Secure, highly available
N8N_HOST=<REPLACE_WITH_PROD_N8N_HOST>
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=<REPLACE_WITH_PROD_N8N_WEBHOOK_URL>

# Database
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=<REPLACE_WITH_PROD_DB_HOST>
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=meepleai_production
DB_POSTGRESDB_USER=<REPLACE_WITH_PROD_DB_USER>
# ⚠️  Use Docker Secret
# DB_POSTGRESDB_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# Basic Auth (STRONG password required)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=<REPLACE_WITH_N8N_USER>
# ⚠️  Use Docker Secret
# N8N_BASIC_AUTH_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# Encryption Key (CRITICAL: backup securely!)
# Generate with: openssl rand -hex 32
# ⚠️  NEVER LOSE THIS KEY - credentials will be irrecoverable
# ⚠️  Use Docker Secret
# N8N_ENCRYPTION_KEY=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# MeepleAI API URL
MEEPLEAI_API_URL=<REPLACE_WITH_PROD_API_URL>

# Service Account Session
# ⚠️  Use Docker Secret
# N8N_SERVICE_SESSION=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# Logging
N8N_LOG_LEVEL=warn
N8N_LOG_OUTPUT=file

# Execution Settings
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200

# ----------------------------------------------------------------------------
# OBSERVABILITY (Logging, Metrics, Tracing)
# ----------------------------------------------------------------------------
# Production: Full observability, long retention

# Seq (Log Aggregation)
SEQ_URL=<REPLACE_WITH_PROD_SEQ_URL>
ACCEPT_EULA=Y
# ⚠️  Use Docker Secret
# SEQ_API_KEY=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
# SEQ_FIRSTRUN_ADMINPASSWORDHASH=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
SEQ_CACHE_SYSTEMRAMTARGET=0.5

# Prometheus (Metrics)
PROMETHEUS_RETENTION_TIME=90d
PROMETHEUS_RETENTION_SIZE=50GB
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# Grafana (Dashboards)
GF_SECURITY_ADMIN_USER=<REPLACE_WITH_GRAFANA_USER>
# ⚠️  Use Docker Secret
# GF_SECURITY_ADMIN_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
GF_SERVER_ROOT_URL=<REPLACE_WITH_GRAFANA_URL>
GF_USERS_ALLOW_SIGN_UP=false
GF_AUTH_ANONYMOUS_ENABLED=false
GF_SECURITY_COOKIE_SECURE=true
GF_SECURITY_COOKIE_SAMESITE=strict

# Grafana SMTP (for alerts)
GF_SMTP_ENABLED=true
GF_SMTP_HOST=<REPLACE_WITH_SMTP_HOST>:587
GF_SMTP_USER=<REPLACE_WITH_SMTP_USER>
# ⚠️  Use Docker Secret
# GF_SMTP_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
GF_SMTP_FROM_ADDRESS=grafana@meepleai.dev
GF_SMTP_FROM_NAME=MeepleAI Monitoring

# Jaeger (Tracing)
COLLECTOR_OTLP_ENABLED=true
# Production: Use Elasticsearch for persistent storage
SPAN_STORAGE_TYPE=elasticsearch
SPAN_STORAGE_ES_SERVER_URLS=<REPLACE_WITH_ELASTICSEARCH_URL>
SPAN_STORAGE_ES_USERNAME=<REPLACE_WITH_ES_USERNAME>
# ⚠️  Use Docker Secret
# SPAN_STORAGE_ES_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
SPAN_STORAGE_ES_INDEX_PREFIX=jaeger-prod
SPAN_STORAGE_ES_TLS_ENABLED=true

# Sampling (reduce cost in production)
JAEGER_SAMPLER_TYPE=probabilistic
JAEGER_SAMPLER_PARAM=0.1

# Alertmanager (Alerts - MANDATORY)
ALERTMANAGER_ENABLED=true

# ----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ----------------------------------------------------------------------------
# Production: Maximum security

# Bootstrap Admin (disable after initial setup)
INITIAL_ADMIN_EMAIL=<REPLACE_WITH_ADMIN_EMAIL>
# ⚠️  Use Docker Secret
# INITIAL_ADMIN_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
INITIAL_ADMIN_DISPLAY_NAME=System Administrator

# OAuth Providers (PRODUCTION apps - separate from staging)
# ⚠️  Create production OAuth apps in provider consoles
GOOGLE_OAUTH_CLIENT_ID=<REPLACE_WITH_GOOGLE_PROD_CLIENT_ID>
# ⚠️  Use Docker Secret
# GOOGLE_OAUTH_CLIENT_SECRET=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

DISCORD_OAUTH_CLIENT_ID=<REPLACE_WITH_DISCORD_PROD_CLIENT_ID>
# ⚠️  Use Docker Secret
# DISCORD_OAUTH_CLIENT_SECRET=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

GITHUB_OAUTH_CLIENT_ID=<REPLACE_WITH_GITHUB_PROD_CLIENT_ID>
# ⚠️  Use Docker Secret
# GITHUB_OAUTH_CLIENT_SECRET=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# OAuth Callback URL
OAUTH_CALLBACK_BASE_URL=<REPLACE_WITH_PROD_API_URL>

# Session Configuration
SESSION_EXPIRATION_DAYS=30
INACTIVITY_TIMEOUT_DAYS=30
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict
SESSION_COOKIE_HTTPONLY=true

# Security Headers (CRITICAL)
SECURITY_HEADERS_ENABLE_CSP=true
SECURITY_HEADERS_ENABLE_HSTS=true
SECURITY_HEADERS_ENABLE_X_FRAME_OPTIONS=true
SECURITY_HEADERS_ENABLE_X_CONTENT_TYPE_OPTIONS=true
SECURITY_HEADERS_HSTS_MAX_AGE=31536000
SECURITY_HEADERS_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HEADERS_HSTS_PRELOAD=true

# ----------------------------------------------------------------------------
# EMAIL & ALERTING
# ----------------------------------------------------------------------------
# Production: Multiple alert channels, SLA monitoring

ALERTING_ENABLED=true
ALERTING_THROTTLE_MINUTES=60

# Email Configuration (MANDATORY)
ALERTING_EMAIL_ENABLED=true
SMTP_HOST=<REPLACE_WITH_SMTP_HOST>
SMTP_PORT=587
SMTP_USERNAME=<REPLACE_WITH_SMTP_USERNAME>
# ⚠️  Use Docker Secret (Gmail App Password or SMTP password)
# SMTP_PASSWORD=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
SMTP_USE_TLS=true
ALERTING_EMAIL_FROM=alerts@meepleai.dev
ALERTING_EMAIL_TO=["ops@meepleai.dev","oncall@meepleai.dev"]

# Slack (RECOMMENDED)
ALERTING_SLACK_ENABLED=true
# ⚠️  Use Docker Secret
# SLACK_WEBHOOK_URL=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>
SLACK_CHANNEL=#alerts-production

# PagerDuty (RECOMMENDED for critical alerts)
ALERTING_PAGERDUTY_ENABLED=true
# ⚠️  Use Docker Secret
# PAGERDUTY_INTEGRATION_KEY=<DO_NOT_SET_HERE_USE_DOCKER_SECRET>

# Alert Levels
ALERT_CRITICAL_CHANNELS=pagerduty,slack,email
ALERT_WARNING_CHANNELS=slack,email
ALERT_INFO_CHANNELS=slack

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
# Production: Stable features only
FEATURE_PROMPT_DATABASE=false
FEATURE_STREAMING_RESPONSES=true
FEATURE_SETUP_GUIDE_GENERATION=true
FEATURE_CHAT_EXPORT=true
FEATURE_MESSAGE_EDIT_DELETE=true
FEATURE_PDF_UPLOAD=true

# Experimental features (DISABLED in production)
FEATURE_EXPERIMENTAL_RAG_V2=false
FEATURE_BETA_UI_COMPONENTS=false

# ----------------------------------------------------------------------------
# PERFORMANCE TUNING
# ----------------------------------------------------------------------------
# Production: Maximum performance and caching

# Cache Optimization (MANDATORY)
CACHE_OPTIMIZATION_ENABLED=true
CACHE_WARMING_ENABLED=true
CACHE_WARMING_STARTUP_DELAY_MINUTES=2
CACHE_WARMING_INTERVAL_HOURS=6
CACHE_WARMING_TOP_QUERIES_COUNT=100
CACHE_HOT_QUERY_THRESHOLD=10
CACHE_WARM_QUERY_THRESHOLD=3
CACHE_HOT_QUERY_TTL_HOURS=24
CACHE_WARM_QUERY_TTL_HOURS=6
CACHE_COLD_QUERY_TTL_HOURS=1

# Follow-up Questions
FOLLOWUP_QUESTIONS_ENABLED=true
FOLLOWUP_QUESTIONS_MAX_PER_RESPONSE=5
FOLLOWUP_QUESTIONS_TIMEOUT_MS=10000
FOLLOWUP_QUESTIONS_CACHE_VERSION=2

# Quality Evaluation
QUALITY_EVALUATION_ENABLED=true
QUALITY_EVALUATION_INTERVAL_DAYS=7
QUALITY_EVALUATION_REPORT_WINDOW_DAYS=7
RAG_EVALUATION_ENABLED=true
RAG_DATASET_PATH=/app/datasets/rag/evaluation.json
QUALITY_MIN_OVERALL_CONFIDENCE=0.70
QUALITY_MIN_RAG_CONFIDENCE=0.70
QUALITY_MAX_LOW_QUALITY_PERCENTAGE=10.0

# Hybrid Search Configuration (ADR-001)
HYBRID_SEARCH_VECTOR_WEIGHT=0.7
HYBRID_SEARCH_KEYWORD_WEIGHT=0.3
HYBRID_SEARCH_RRF_CONSTANT=60

# BGG Integration
BGG_BASE_URL=https://boardgamegeek.com/xmlapi2
BGG_CACHE_TTL_DAYS=7
BGG_MAX_REQUESTS_PER_SECOND=2.0
BGG_RETRY_COUNT=3
BGG_TIMEOUT_SECONDS=30

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
# Production: Strict rate limits to prevent abuse
RATELIMIT_ADMIN_MAX_TOKENS=1000
RATELIMIT_ADMIN_REFILL_RATE=10.0
RATELIMIT_EDITOR_MAX_TOKENS=500
RATELIMIT_EDITOR_REFILL_RATE=5.0
RATELIMIT_USER_MAX_TOKENS=100
RATELIMIT_USER_REFILL_RATE=1.0
RATELIMIT_ANONYMOUS_MAX_TOKENS=60
RATELIMIT_ANONYMOUS_REFILL_RATE=1.0
RATELIMIT_OAUTH_MAX_TOKENS=10
RATELIMIT_OAUTH_REFILL_RATE=0.16667

# ----------------------------------------------------------------------------
# LOGGING LEVELS
# ----------------------------------------------------------------------------
# Production: Minimal logging (performance)
LOG_LEVEL=Warning
LOGGING__LOGLEVEL__DEFAULT=Warning
LOGGING__LOGLEVEL__MICROSOFT=Warning
LOGGING__LOGLEVEL__MICROSOFT_ASPNETCORE=Warning
LOGGING__LOGLEVEL__MICROSOFT_ENTITYFRAMEWORKCORE=Error

# Structured Logging
ENABLE_STRUCTURED_LOGGING=true
ENABLE_METRICS=true
ENABLE_DISTRIBUTED_TRACING=true

# Log Sampling (reduce volume)
LOG_SAMPLING_ENABLED=true
LOG_SAMPLING_RATE=0.1

# ----------------------------------------------------------------------------
# DOCKER CONFIGURATION
# ----------------------------------------------------------------------------
# Production: High availability, resource optimization
COMPOSE_PROJECT_NAME=meepleai-production

# Resource Limits (adjust based on infrastructure)
POSTGRES_MAX_CONNECTIONS=200
REDIS_MAX_MEMORY=8gb

# API Resources
API_CPU_LIMIT=4
API_MEMORY_LIMIT=8g
API_CPU_RESERVATION=2
API_MEMORY_RESERVATION=4g
API_REPLICAS=3

# Web Resources
WEB_CPU_LIMIT=2
WEB_MEMORY_LIMIT=4g
WEB_CPU_RESERVATION=1
WEB_MEMORY_RESERVATION=2g
WEB_REPLICAS=2

# ----------------------------------------------------------------------------
# BACKUP & DISASTER RECOVERY
# ----------------------------------------------------------------------------
# Production: Comprehensive backup strategy
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_TYPE=s3
BACKUP_S3_BUCKET=<REPLACE_WITH_S3_BUCKET>
BACKUP_S3_REGION=<REPLACE_WITH_AWS_REGION>
# ⚠️  Use IAM role or Docker Secret
# BACKUP_AWS_ACCESS_KEY_ID=<DO_NOT_SET_HERE_USE_IAM_ROLE>
# BACKUP_AWS_SECRET_ACCESS_KEY=<DO_NOT_SET_HERE_USE_IAM_ROLE>

# Point-in-time Recovery
POSTGRES_WAL_ARCHIVING_ENABLED=true
POSTGRES_PITR_ENABLED=true

# ----------------------------------------------------------------------------
# MONITORING & HEALTH CHECKS
# ----------------------------------------------------------------------------
# Production: Aggressive monitoring
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=10
HEALTHCHECK_START_PERIOD=30s

# SLA Monitoring
SLA_TARGET_UPTIME=99.5
SLA_TARGET_RESPONSE_TIME_MS=200
SLA_TARGET_ERROR_RATE=0.01

# Auto-scaling (if using orchestrator like Kubernetes)
AUTOSCALE_ENABLED=true
AUTOSCALE_MIN_REPLICAS=2
AUTOSCALE_MAX_REPLICAS=10
AUTOSCALE_TARGET_CPU=70
AUTOSCALE_TARGET_MEMORY=80

# ----------------------------------------------------------------------------
# COMPLIANCE & AUDIT
# ----------------------------------------------------------------------------
# Production: GDPR, audit logging
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=365
GDPR_ANONYMIZATION_ENABLED=true

AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_SENSITIVE_DATA=false

# ----------------------------------------------------------------------------
# DOCKER SECRETS (MANDATORY)
# ----------------------------------------------------------------------------
# Production: ALL sensitive data via Docker Secrets
#
# Required Secrets (create in infra/secrets/prod/):
# - postgres-password.txt
# - redis-password.txt
# - openrouter-api-key.txt
# - openai-api-key.txt (if using OpenAI)
# - n8n-encryption-key.txt
# - n8n-basic-auth-password.txt
# - initial-admin-password.txt
# - grafana-admin-password.txt
# - seq-api-key.txt
# - gmail-app-password.txt (or SMTP password)
# - google-oauth-secret.txt
# - discord-oauth-secret.txt
# - github-oauth-secret.txt
# - slack-webhook-url.txt
# - pagerduty-integration-key.txt
# - sentry-auth-token.txt
# - elasticsearch-password.txt
# - ssl-cert-password.txt (if applicable)
#
# Initialize with:
#   cd infra/secrets
#   ./init-secrets.sh --environment production
#
# Rotate quarterly:
#   ./rotate-secret.sh postgres-password --environment production

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. Production Checklist:
#    ✅ All secrets via Docker Secrets or secret manager
#    ✅ HTTPS/SSL enabled everywhere
#    ✅ Database backups automated (daily, 30d retention)
#    ✅ Monitoring and alerting configured (Grafana, Seq, PagerDuty)
#    ✅ Rate limiting enabled
#    ✅ CORS restricted to production domains
#    ✅ Detailed errors disabled
#    ✅ Sentry error tracking enabled
#    ✅ OAuth production apps configured
#    ✅ Strong passwords (16+ characters)
#    ✅ Resource limits set
#    ✅ Auto-scaling configured (if applicable)
#    ✅ SLA targets defined
#    ✅ Disaster recovery tested
#
# 2. Never in Production:
#    ❌ Default passwords (admin/admin)
#    ❌ HTTP-only connections
#    ❌ Detailed error messages
#    ❌ Development/staging credentials
#    ❌ CORS wildcards (*)
#    ❌ Disabled security headers
#    ❌ Verbose logging (Debug/Trace)
#    ❌ Mock OAuth credentials
#    ❌ Unencrypted secrets
#
# 3. Deployment:
#    docker compose -f compose.prod.yml up -d
#    docker compose -f compose.prod.yml exec api dotnet ef database update
#    curl https://api.meepleai.dev/health

              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get All Games",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Games array is returned', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "    ",
                  "    // Store first game ID if available for subsequent tests",
                  "    if (json.length > 0) {",
                  "        pm.collectionVariables.set('testGameId', json[0].id);",
                  "        console.log('Found existing game:', json[0].id);",
                  "    } else {",
                  "        console.log('No games found in database');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/games",
              "host": ["{{baseUrl}}"],
              "path": ["games"]
            }
          }
        },
        {
          "name": "Get Game by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Skip if no game ID available",
                  "const testGameId = pm.collectionVariables.get('testGameId');",
                  "if (!testGameId) {",
                  "    console.log('SKIP: No testGameId available');",
                  "    pm.execution.skipRequest();",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Game data is returned', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.equal(pm.collectionVariables.get('testGameId'));",
                  "    pm.expect(json.title).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/games/{{testGameId}}",
              "host": ["{{baseUrl}}"],
              "path": ["games", "{{testGameId}}"]
            }
          }
        },
        {
          "name": "Get Game - Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 for non-existent game', function() {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/games/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["games", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]

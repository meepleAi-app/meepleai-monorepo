{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Circuit Breaker State by Provider",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "meepleai_llm_circuit_breaker_state",
          "legendFormat": "{{ provider }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "CLOSED", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "OPEN", "color": "red" } }, "type": "value" },
            { "options": { "2": { "text": "HALF-OPEN", "color": "yellow" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "OpenRouter Balance (USD)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "meepleai_openrouter_balance_usd",
          "legendFormat": "Balance"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "max": 75,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "RPM Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "meepleai_openrouter_rpm_utilization",
          "legendFormat": "RPM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "title": "LLM Requests/sec by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(meepleai_llm_requests_total[5m])",
          "legendFormat": "{{ provider }} / {{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "LLM Latency P95 by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(meepleai_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 {{ provider }}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(meepleai_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "P50 {{ provider }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "LLM Cost (USD/hour) by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(meepleai_llm_cost_usd_total[1h]) * 3600",
          "legendFormat": "{{ provider }} / {{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "title": "LLM Error Rate by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "rate(meepleai_llm_requests_total{status=\"error\"}[5m]) / rate(meepleai_llm_requests_total[5m])",
          "legendFormat": "{{ provider }} error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["llm", "operational", "meepleai", "issue-5480"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "title": "LLM Operational Maturity",
  "uid": "llm-operational-maturity",
  "version": 1
}

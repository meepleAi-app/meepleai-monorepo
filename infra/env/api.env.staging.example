# API Environment - Staging
# Production-like configuration for QA testing and demos
#
# USAGE:
#   cp api.env.staging.example api.env.staging
#   vim api.env.staging  # Replace <REPLACE_*>
#
# Docker Compose: docker compose -f docker-compose.yml -f compose.staging.yml up

# PostgreSQL Connection
# Note: Password comes from Docker Secret (POSTGRES_PASSWORD_FILE)
POSTGRES_USER=meepleai_stg
POSTGRES_DB=meepleai_staging

# Embedding Provider
# Options: "ollama" (cost-effective) or "openai" (reliable)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# JWT Configuration
JWT_ISSUER=<REPLACE_WITH_STAGING_API_URL>
# Example: https://staging-api.meepleai.dev

# CORS
ALLOW_ORIGIN=<REPLACE_WITH_STAGING_WEB_URL>
# Example: https://staging.meepleai.dev

# Seq Logging
SEQ_URL=<REPLACE_WITH_SEQ_URL>
# Docker: http://seq:5341
# Cloud: https://logs-staging.meepleai.dev

# Bootstrap Admin (for initial setup)
INITIAL_ADMIN_EMAIL=admin@staging.meepleai.dev
INITIAL_ADMIN_DISPLAY_NAME=Staging Administrator
# Password from Docker Secret: /run/secrets/initial-admin-password

# n8n Integration (optional, if using n8n in staging)
N8N_ENCRYPTION_KEY_FILE=/run/secrets/n8n-encryption-key

# ============================================================================
# SECRETS (DO NOT set here - use Docker Secrets)
# ============================================================================
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres-password
# OPENROUTER_API_KEY_FILE=/run/secrets/openrouter-api-key
# INITIAL_ADMIN_PASSWORD_FILE=/run/secrets/initial-admin-password

# See: infra/secrets/staging/

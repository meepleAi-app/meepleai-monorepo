@startuml
title Explain flow (/agents/explain)

actor User
boundary Api as "AiEndpoints"
control Rag as "IRagService"
control Chat as "ChatService"

User -> Api : POST /agents/explain\n(gameId, topic, chatId?)
Api -> Api : validate session & gameId
Api -> Chat : AddMessageAsync(chatId, userId, "user", "Explain: {topic}") [optional]
Api -> Rag : ExplainAsync(gameId, topic, language=null)
Rag --> Api : ExplainResponse(script, outline, tokens, confidence)
Api -> Chat : AddMessageAsync(chatId, userId, "assistant", script, meta) [optional]
Api --> User : 200 OK (script + outline + metrics)

@enduml

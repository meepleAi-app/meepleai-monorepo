# API Environment - Production
# ⚠️  CRITICAL: Use Docker Secrets for all sensitive data
#
# USAGE:
#   cp api.env.prod.example api.env.prod
#   vim api.env.prod  # Replace <REPLACE_*>
#   ⚠️  Store in secure secret manager (AWS Secrets Manager, Azure Key Vault)
#
# Docker Compose: docker compose -f docker-compose.yml -f compose.prod.yml up

# PostgreSQL Connection
# Note: Password comes from Docker Secret (POSTGRES_PASSWORD_FILE)
POSTGRES_USER=<REPLACE_WITH_PROD_DB_USER>
POSTGRES_DB=meepleai_production

# Embedding Provider
# RECOMMENDED: openai for production (better reliability)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Alternative: ollama if self-hosted with HA
# EMBEDDING_PROVIDER=ollama
# OLLAMA_URL=http://ollama-ha.internal:11434

# JWT Configuration
JWT_ISSUER=<REPLACE_WITH_PROD_API_URL>
# Example: https://api.meepleai.dev

# CORS (PRODUCTION DOMAINS ONLY - NO WILDCARDS)
ALLOW_ORIGIN=<REPLACE_WITH_PROD_WEB_URL>
# Example: https://app.meepleai.dev
# Multiple: https://app.meepleai.dev,https://www.meepleai.dev

# Seq Logging
SEQ_URL=<REPLACE_WITH_PROD_SEQ_URL>
# Cloud: https://logs.meepleai.dev
# Self-hosted: http://seq:5341

# Bootstrap Admin (disable after initial setup)
INITIAL_ADMIN_EMAIL=<REPLACE_WITH_ADMIN_EMAIL>
INITIAL_ADMIN_DISPLAY_NAME=System Administrator
# Password from Docker Secret: /run/secrets/initial-admin-password

# n8n Integration
N8N_ENCRYPTION_KEY_FILE=/run/secrets/n8n-encryption-key

# AI Provider Configuration
AI_PREFERRED_PROVIDER=OpenRouter
AI_FALLBACK_CHAIN=OpenRouter,Ollama

# LLM Routing (user-tier based cost optimization)
LLM_ROUTING_ANONYMOUS_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_ROUTING_USER_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_ROUTING_EDITOR_MODEL=anthropic/claude-3.5-haiku
LLM_ROUTING_ADMIN_MODEL=anthropic/claude-3.5-sonnet
LLM_ROUTING_PREMIUM_MODEL=anthropic/claude-3.5-sonnet

# Rate Limiting (strict in production)
RATELIMIT_ANONYMOUS_MAX_TOKENS=60
RATELIMIT_ANONYMOUS_REFILL_RATE=1.0
RATELIMIT_USER_MAX_TOKENS=100
RATELIMIT_USER_REFILL_RATE=1.0
RATELIMIT_ADMIN_MAX_TOKENS=1000
RATELIMIT_ADMIN_REFILL_RATE=10.0

# ============================================================================
# SECRETS (MANDATORY - use Docker Secrets)
# ============================================================================
# NEVER set these here - use /run/secrets/
#
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres-password
# OPENROUTER_API_KEY_FILE=/run/secrets/openrouter-api-key
# OPENAI_API_KEY_FILE=/run/secrets/openai-api-key
# INITIAL_ADMIN_PASSWORD_FILE=/run/secrets/initial-admin-password
# N8N_ENCRYPTION_KEY_FILE=/run/secrets/n8n-encryption-key
#
# Initialize: cd infra/secrets && ./init-secrets.sh --environment prod
# Rotate: ./rotate-secret.sh postgres-password --environment prod
# Backup: gpg --encrypt prod/n8n-encryption-key.txt (CRITICAL!)
#
# See: infra/secrets/prod/

# MeepleAI Orchestration Service Configuration
# ISSUE-3495: LangGraph Orchestrator Environment Variables

# Service Configuration
LOG_LEVEL=INFO
PORT=8004

# Dependent Services
EMBEDDING_SERVICE_URL=http://embedding-service:8000
RERANKER_SERVICE_URL=http://reranker-service:8003
UNSTRUCTURED_SERVICE_URL=http://unstructured-service:8001
SMOLDOCLING_SERVICE_URL=http://smoldocling-service:8002

# Database
DATABASE_URL=postgresql://meepleai:meepleai@postgres:5432/meepleai

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# LLM Provider (OpenRouter recommended)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LangGraph Configuration
LANGGRAPH_TIMEOUT=30
MAX_WORKFLOW_DEPTH=10
ENABLE_CHECKPOINTING=true

# Monitoring
METRICS_ENABLED=true

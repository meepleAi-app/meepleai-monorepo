{
  "files.exclude": {
    "apps/web": true,
    "**/*.dll": true,
    "**/bin": true,
    "**/obj": true,
    "**/.next": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true
  },
  "search.exclude": {
    "apps/web": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/bin": true,
    "**/obj": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "terminal.integrated.cwd": "${workspaceFolder}/apps/api/src/Api",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.tabSize": 4
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "omnisharp.enableEditorConfigSupport": true,
  "omnisharp.enableRoslynAnalyzers": true,
  "omnisharp.organizeImportsOnFormat": true,
  "dotnet.defaultSolution": "apps/api/BoardGameAI.sln",
  "python.analysis.typeCheckingMode": "basic",
  "workbench.colorCustomizations": {
    "statusBar.background": "#4285f4",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#4285f4",
    "statusBar.debuggingBackground": "#1967d2"
  },
  "window.title": "Backend - ${rootName}${separator}${activeEditorShort}",
  "git.ignoreLimitWarning": true,
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/bin/**": true,
    "**/obj/**": true,
    "**/__pycache__/**": true
  }
}

</style></div><div class="w-embed"><style>
.list {
  position: relative;
  list-style: none;
  margin: 0;
  padding: 0;
}

.list > li {
	position: relative;
	color: var(--base-color-brand--primary-600);
	margin-bottom: 0;
}

.list--bullet > li {
	padding-left: 1.25rem;
}

.list--bullet > li::before {
	content: '';
  position: absolute;
  top: 0.875rem;
  left: 0.5rem;
  width: 0.25rem;
  height: 0.25rem;
	border-radius: 50%;
  background-color: var(--base-color-brand--primary-600);
}

.list--num {
	counter-reset: list;
}

.list--num > li {
	padding-left: 1.25rem;
}

.list--num > li + li {
	margin-top: 1.5rem;
}

.list--num > li::before {
	position: absolute;
  left: 0;
  counter-increment: list;
  content: counter(list) ".";
  font-weight: 700;
}

.list .list {
	margin-left: -1.5rem;
}

.list--inverse > li {
  color: var(--base-color-brand--primary-white);
}

.list--inverse.list--bullet > li::before {
  background-color: var(--base-color-brand--primary-white);
}

.list--gap li + li {
	margin-top: 1.5rem;
}

.list.list--bullet.text.text--default > li::before {
	top: 0.75rem;
}

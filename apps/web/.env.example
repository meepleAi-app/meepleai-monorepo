NEXT_PUBLIC_API_BASE=http://localhost:5080
NEXT_PUBLIC_DEMO_EMAIL=user@meepleai.dev

# Retry Policy Configuration (Issue #1453)
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=3
NEXT_PUBLIC_RETRY_BASE_DELAY=1000
NEXT_PUBLIC_RETRY_MAX_DELAY=10000
NEXT_PUBLIC_RETRY_ENABLED=true

# Circuit Breaker Configuration (Enhancement)
NEXT_PUBLIC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
NEXT_PUBLIC_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
NEXT_PUBLIC_CIRCUIT_BREAKER_TIMEOUT=60000
NEXT_PUBLIC_CIRCUIT_BREAKER_WINDOW_SIZE=60000
NEXT_PUBLIC_CIRCUIT_BREAKER_ENABLED=true
# Request Deduplication Cache (Issue #1454)
# Enable/disable request deduplication (default: true)
NEXT_PUBLIC_REQUEST_DEDUP_ENABLED=true
# Time-to-live for cached requests in milliseconds (default: 100)
NEXT_PUBLIC_REQUEST_DEDUP_TTL=100
# Maximum number of concurrent cached requests (default: 100)
NEXT_PUBLIC_REQUEST_DEDUP_MAX_SIZE=100
# Sentry Configuration (Issue #1433 - Structured Logging)
# Get your DSN from https://sentry.io/settings/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for uploading source maps (optional, only needed for production)
SENTRY_AUTH_TOKEN=

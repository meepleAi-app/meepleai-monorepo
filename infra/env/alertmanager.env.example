# Alertmanager Environment Variables
# Copy this file to alertmanager.env and configure
#
# SEC-708: Secrets are now managed via Docker Secrets (Phase 1)
# - Secrets stored in: infra/secrets/*.txt (gitignored)
# - Initialize secrets: tools/secrets/init-secrets.sh
#
# Migration: See docs/security/docker-secrets-migration.md

# Gmail App Password for email notifications
# IMPORTANT: Do NOT use your regular Gmail password!
# Follow these steps to create an App Password:
#
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create a new App Password for "Mail"
# 5. Copy the 16-character password (format: xxxx xxxx xxxx xxxx)
# 6. Store it in: infra/secrets/gmail-app-password.txt (no spaces)
#
# SEC-708: GMAIL_APP_PASSWORD is now in infra/secrets/gmail-app-password.txt (Docker Secret)

# Optional: Slack webhook URL for additional notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

    #region SearchAsync Tests

    [Fact]
    public async Task SearchAsync_WhenMatchingDocuments_ShouldReturnResults()
    {
        // Arrange
        var gameId = "test-game";
        var embedding = new float[768];
        var limit = 5;

        var mockResults = new List<ScoredPoint>
        {
            CreateScoredPoint(0.95f, "Test text 1", "pdf1", 1, 0),
            CreateScoredPoint(0.85f, "Test text 2", "pdf1", 2, 1)
        };

        _mockClient
            .Setup(x => x.SearchAsync(
                "meepleai_documents",
                It.IsAny<float[]>(),
                It.IsAny<Filter>(),
                (uint)limit,
                It.IsAny<CancellationToken>()))
            .ReturnsAsync(mockResults);

        // Act
        var result = await _service.SearchAsync(gameId, embedding, limit);

        // Assert
        Assert.True(result.Success);
        Assert.Null(result.ErrorMessage);
        Assert.Equal(2, result.Results.Count);
        Assert.Equal(0.95f, result.Results[0].Score);
        Assert.Equal("Test text 1", result.Results[0].Text);
        Assert.Equal(1, result.Results[0].Page);
    }


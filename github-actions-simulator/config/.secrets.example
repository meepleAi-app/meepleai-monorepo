# GitHub Actions Simulator - Secrets Configuration
# Copy this file to .secrets and fill in your actual values
# WARNING: Never commit .secrets to git!

# OpenRouter API Key (required for AI features)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Semgrep App Token (optional - only needed for Semgrep Cloud)
SEMGREP_APP_TOKEN=

# GitHub Token (optional - for private repos access)
GITHUB_TOKEN=

# Add any other secrets your workflows need here

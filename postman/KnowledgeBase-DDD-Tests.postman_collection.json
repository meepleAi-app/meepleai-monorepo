            "description": "Test validation: Invalid UUID format should return 400."
          },
          "response": []
        }
      ],
      "description": "Tests for /knowledge-base/search endpoint (SearchQueryHandler)"
    },
    {
      "name": "KnowledgeBase - Q&A",
      "item": [
        {
          "name": "Ask - Simple Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Q&A successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success flag', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Response has answer', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.answer).to.be.a('string');",
                  "    pm.expect(response.answer.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Response has sources', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.sources).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response has confidence scores', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.searchConfidence).to.be.a('number');",
                  "    pm.expect(response.llmConfidence).to.be.a('number');",
                  "    pm.expect(response.overallConfidence).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Confidence scores in valid range (0-1)', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.searchConfidence).to.be.within(0, 1);",
                  "    pm.expect(response.llmConfidence).to.be.within(0, 1);",
                  "    pm.expect(response.overallConfidence).to.be.within(0, 1);",
                  "});",
                  "",
                  "pm.test('Has quality flag', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.isLowQuality).to.be.a('boolean');",
                  "});",
                  "",
                  "pm.test('Has citations', function() {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.citations).to.be.an('array');",
                  "});",
                  "",
                  "// Log response for inspection",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('Answer:', response.answer.substring(0, 100) + '...');",
                  "    console.log('Search Confidence:', response.searchConfidence);",
                  "    console.log('LLM Confidence:', response.llmConfidence);",
                  "    console.log('Overall Confidence:', response.overallConfidence);",
                  "    console.log('Is Low Quality:', response.isLowQuality);",
                  "    console.log('Sources:', response.sources.length);",
                  "    console.log('Citations:', response.citations.length);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameId\": \"{{testGameId}}\",\n  \"query\": \"How do you win the game?\",\n  \"language\": \"en\",\n  \"bypassCache\": false\n}"

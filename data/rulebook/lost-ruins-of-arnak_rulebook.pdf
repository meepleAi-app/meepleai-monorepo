<script>
document.addEventListener("DOMContentLoaded", function() {
  const vendorCards = document.querySelectorAll('.js-vendor');
  const vendorUrls = document.querySelectorAll('.js-vendor-urls p');

  vendorCards.forEach((vendorCard, index) => {
    const vendorUrl = vendorUrls[index];
    if (vendorUrl && !vendorUrl.textContent.includes("DEFAULT")) {
      vendorCard.href = vendorUrl.textContent.trim();
    }
  });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const insertsCards = document.querySelectorAll('.js-insert');
  const insertsUrls = document.querySelectorAll('.js-insert-urls p');

  insertsCards.forEach((insertsCard, index) => {
    const insertUrl = insertsUrls[index];
    if (insertUrl && !insertUrl.textContent.includes("DEFAULT")) {
      insertsCard.href = insertUrl.textContent.trim();
    }
  });
});
</script>


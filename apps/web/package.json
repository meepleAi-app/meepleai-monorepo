{
  "name": "@meepleai/web",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev -p 3000",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start -p 3000",
    "generate:api": "tsx scripts/generate-api-client.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:jest": "jest --passWithNoTests",
    "posttest:jest": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:jest:watch": "jest --watch",
    "test:jest:coverage": "jest --coverage",
    "posttest:coverage": "node -e \"try { require('child_process').execSync('powershell.exe -ExecutionPolicy Bypass -File ../../tools/cleanup-test-processes.ps1', { stdio: 'inherit' }); } catch (e) { console.log('Cleanup skipped (Windows-only)'); }\"",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:a11y": "vitest run --grep=\"(a11y|accessibility)\"",
    "test:a11y:jest": "jest --testPathPatterns=\"(a11y|accessibility)\"",
    "audit:a11y": "tsx scripts/run-accessibility-audit.ts",
    "lint": "eslint . --max-warnings=300",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test:e2e:groups": "dotenv -e .env.test -- playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "chromatic:ci": "chromatic --exit-zero-on-changes --exit-once-uploaded",
    "prepare": "cd ../.. && husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ]
  },
  "dependencies": {

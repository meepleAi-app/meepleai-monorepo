# PostgreSQL Configuration (Local Development)
# Copy this file to .env and update with real values from infra/secrets/

# Database Connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meepleai
POSTGRES_USER=postgres
# Get password from: infra/secrets/postgres-password.txt
POSTGRES_PASSWORD=PLACEHOLDER-get-from-infra-secrets-postgres-password-txt

# Alternative: Use full connection string directly (overrides individual vars)
# ConnectionStrings__Postgres=Host=localhost;Database=meepleai;Username=postgres;Password=YOUR_PASSWORD_HERE;Pooling=true;Minimum Pool Size=2;Maximum Pool Size=20

# Redis Configuration
# Get password from: infra/secrets/redis-password.txt
REDIS_PASSWORD=PLACEHOLDER-get-from-infra-secrets-redis-password-txt
# Alternative: Full Redis URL (overrides REDIS_PASSWORD)
# REDIS_URL=localhost:6379,password=YOUR_PASSWORD_HERE,abortConnect=false

# LLM Service
OLLAMA_URL=http://localhost:11434

# AI API Keys (Optional - get from infra/secrets/)
# Get from: infra/secrets/openrouter-api-key.txt
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OAuth Provider Credentials (Optional - for social login)
# Get from: infra/secrets/google-oauth-client-id.txt
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Get from: infra/secrets/google-oauth-client-secret.txt
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-secret

# Get from: infra/secrets/discord-oauth-client-id.txt
# DISCORD_OAUTH_CLIENT_ID=your-application-id
# Get from: infra/secrets/discord-oauth-client-secret.txt
# DISCORD_OAUTH_CLIENT_SECRET=your-client-secret

# Get from: infra/secrets/github-oauth-client-id.txt
# GITHUB_OAUTH_CLIENT_ID=your-client-id
# Get from: infra/secrets/github-oauth-client-secret.txt
# GITHUB_OAUTH_CLIENT_SECRET=your-client-secret

# Initial Admin User (Optional - for bootstrapping)
INITIAL_ADMIN_EMAIL=admin@meepleai.dev
# Get from: infra/secrets/initial-admin-password.txt
# INITIAL_ADMIN_PASSWORD=ChangeThisPassword123!
INITIAL_ADMIN_DISPLAY_NAME=System Admin

# BoardGameGeek API (Optional - for game data scraping)
# Get from: infra/secrets/bgg-api-token.txt
# BGG_API_TOKEN=your-bgg-token

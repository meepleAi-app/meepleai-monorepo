#!/bin/sh
# Pre-commit hook for MeepleAI
# Runs checks based on current branch with progressive restrictions
# frontend-dev: FE lint + typecheck
# main-dev: FE + BE format + detect-secrets
# main: FE + BE + detect-secrets + semgrep

echo "🚀 Running pre-commit checks..."

# Get current branch name
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
echo "📌 Current branch: $CURRENT_BRANCH"

# ============================================
# Port Conflict Check (Issue #3797)
# ============================================

# Only run on Windows (skip on Linux/macOS)
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "win32" || -n "$WINDIR" ]]; then
  echo "🔍 Checking for port conflicts (Windows)..."

  # Check if cleanup script exists
  if [ -f "tools/cleanup/cleanup-dev-ports.ps1" ]; then
    # Run cleanup script in dry-run mode with 10s timeout to avoid hanging pre-commit
    PORT_CHECK_OUTPUT=$(timeout 10 pwsh -NoProfile -ExecutionPolicy Bypass -File tools/cleanup/cleanup-dev-ports.ps1 -DryRun 2>&1) || true

    if echo "$PORT_CHECK_OUTPUT" | grep -q "would be killed: [1-9]"; then
      echo ""
      echo "⚠️  Port conflicts detected! Zombie dev processes found."
      echo ""
      echo "Run this to cleanup before committing:"
      echo "  pwsh tools/cleanup/cleanup-dev-ports.ps1"
      echo ""
      # Warning only - don't block commit
    fi
  fi
else
  echo "ℹ️  Skipping port check (not Windows)"
fi

# Validate that apps/web directory exists
if [ ! -d "apps/web" ]; then
  echo "❌ Error: apps/web directory not found. Are you in the repository root?"
  exit 1
fi

# ============================================
# Frontend Checks (all branches)
# ============================================

# Run lint-staged for frontend
echo "🔍 Running frontend lint-staged..."
(cd apps/web && npx lint-staged) || {
  echo "❌ Lint-staged checks failed. Please fix the issues before committing."
  exit 1
}

# Run TypeScript type checking (frontend)
echo "📘 Running frontend TypeScript type check..."
(cd apps/web && pnpm typecheck) || {
  echo "❌ Frontend TypeScript errors found. Please fix them before committing."
  exit 1
}

# ============================================
# Backend Checks (main-dev and main only)
# ============================================

if [[ "$CURRENT_BRANCH" == "main-dev" || "$CURRENT_BRANCH" == "main" ]]; then
  # Check if any C# files are staged
  STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.cs$' || true)

  if [ -n "$STAGED_CS_FILES" ]; then
    echo "🔧 Running backend code formatting check..."

    # Validate that apps/api directory exists
    if [ -d "apps/api" ]; then
      # Run dotnet format to verify formatting (verify-only mode)
      (cd apps/api && dotnet format --verify-no-changes --verbosity quiet --severity error) || {
        echo ""
        echo "❌ Backend code formatting issues found."
        echo ""
        echo "Run the following command to fix formatting:"
        echo "  cd apps/api && dotnet format"
        echo ""
        exit 1
      }
      echo "✅ Backend formatting check passed!"
    else
      echo "⚠️  Warning: apps/api directory not found, skipping backend checks."
    fi
  else
    echo "ℹ️  No C# files staged, skipping backend formatting check."
  fi
else
  echo "ℹ️  On $CURRENT_BRANCH - skipping backend checks (run on main-dev/main only)"
fi

# ============================================
# Security Checks (main-dev and main)
# ============================================

if [[ "$CURRENT_BRANCH" == "main-dev" || "$CURRENT_BRANCH" == "main" ]]; then
  echo "🔐 Running detect-secrets check..."

  # Check if detect-secrets is available
  if command -v detect-secrets &> /dev/null; then
    # Get staged files
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

    if [ -n "$STAGED_FILES" ]; then
      # Run detect-secrets on staged files
      echo "$STAGED_FILES" | xargs detect-secrets scan --baseline .secrets.baseline 2>/dev/null || {
        echo ""
        echo "⚠️  Potential secrets detected! Review before committing."
        echo "   Run: detect-secrets scan --baseline .secrets.baseline"
        echo ""
        # Warning only, don't block
      }
      echo "✅ Secrets scan completed!"
    fi
  else
    echo "ℹ️  detect-secrets not installed, skipping secrets check"
    echo "   Install with: pip install detect-secrets"
  fi
fi

# ============================================
# Advanced Security (main only)
# ============================================

if [[ "$CURRENT_BRANCH" == "main" ]]; then
  echo "🛡️  Running semgrep security scan..."

  # Check if semgrep is available
  if command -v semgrep &> /dev/null; then
    # Get staged files
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

    if [ -n "$STAGED_FILES" ]; then
      # Run semgrep on staged files (quick scan)
      echo "$STAGED_FILES" | xargs semgrep --config .semgrep.yml --quiet 2>/dev/null || {
        echo ""
        echo "⚠️  Semgrep found potential security issues!"
        echo "   Run: semgrep --config .semgrep.yml"
        echo ""
        # Warning only on pre-commit, CI will enforce
      }
      echo "✅ Semgrep scan completed!"
    fi
  else
    echo "ℹ️  semgrep not installed, skipping security scan"
    echo "   Install with: pip install semgrep"
  fi
fi

echo ""
echo "✅ Pre-commit checks passed for $CURRENT_BRANCH!"

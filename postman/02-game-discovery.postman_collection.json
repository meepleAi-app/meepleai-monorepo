            "description": "Filter games by mechanics (comma-separated)"
          }
        },
        {
          "name": "Combined Filters",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shared-games?search=strategy&minPlayers=2&maxPlayers=4&minPlayTime=30&maxPlayTime=120&categories=strategy&sortBy=rating&sortOrder=desc&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "shared-games"],
              "query": [
                {
                  "key": "search",
                  "value": "strategy"
                },
                {
                  "key": "minPlayers",
                  "value": "2"
                },
                {
                  "key": "maxPlayers",
                  "value": "4"
                },
                {
                  "key": "minPlayTime",
                  "value": "30"
                },
                {
                  "key": "maxPlayTime",
                  "value": "120"
                },
                {
                  "key": "categories",
                  "value": "strategy"
                },
                {
                  "key": "sortBy",
                  "value": "rating"
                },
                {
                  "key": "sortOrder",
                  "value": "desc"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Apply multiple filters simultaneously"
          }
        }
      ]
    },
    {
      "name": "Filter Options",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shared-games/categories",

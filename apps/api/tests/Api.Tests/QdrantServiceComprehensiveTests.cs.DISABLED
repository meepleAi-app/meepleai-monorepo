    #region Concurrent Operations Tests

    [Fact]
    public async Task ConcurrentIndexing_WhenMultipleThreads_ShouldHandleCorrectly()
    {
        // Arrange
        var gameId = "test-game";
        var pdfId1 = "pdf-1";
        var pdfId2 = "pdf-2";
        var pdfId3 = "pdf-3";

        var chunks1 = new List<DocumentChunk>
        {
            new() { Text = "Chunk 1", Embedding = new float[768], Page = 1, CharStart = 0, CharEnd = 7 }
        };
        var chunks2 = new List<DocumentChunk>
        {
            new() { Text = "Chunk 2", Embedding = new float[768], Page = 2, CharStart = 0, CharEnd = 7 }
        };
        var chunks3 = new List<DocumentChunk>
        {
            new() { Text = "Chunk 3", Embedding = new float[768], Page = 3, CharStart = 0, CharEnd = 7 }
        };

        var upsertCount = 0;
        _mockClient
            .Setup(x => x.UpsertAsync(
                "meepleai_documents",
                It.IsAny<IReadOnlyList<PointStruct>>(),
                It.IsAny<CancellationToken>()))
            .Returns(() =>
            {
                Interlocked.Increment(ref upsertCount);
                return Task.CompletedTask;
            });

        // Act
        var tasks = new[]
        {
            _service.IndexDocumentChunksAsync(gameId, pdfId1, chunks1),
            _service.IndexDocumentChunksAsync(gameId, pdfId2, chunks2),
            _service.IndexDocumentChunksAsync(gameId, pdfId3, chunks3)
        };

        var results = await Task.WhenAll(tasks);

        // Assert
        Assert.Equal(3, upsertCount);
        Assert.All(results, r => Assert.True(r.Success));
    }

    [Fact]
    public async Task ConcurrentSearch_WhenMultipleThreads_ShouldHandleCorrectly()
    {
        // Arrange
        var gameId = "test-game";
        var embedding = new float[768];
        var limit = 5;

        var mockResults = new List<ScoredPoint>
        {
            CreateScoredPoint(0.90f, "Result", "pdf1", 1, 0)
        };

        var searchCount = 0;
        _mockClient
            .Setup(x => x.SearchAsync(
                "meepleai_documents",
                It.IsAny<float[]>(),
                It.IsAny<Filter>(),
                (uint)limit,
                It.IsAny<CancellationToken>()))
            .Returns(() =>
            {
                Interlocked.Increment(ref searchCount);
                return Task.FromResult((IReadOnlyList<ScoredPoint>)mockResults);
            });

        // Act
        var tasks = Enumerable.Range(0, 5)
            .Select(_ => _service.SearchAsync(gameId, embedding, limit))
            .ToArray();

        var results = await Task.WhenAll(tasks);

        // Assert
        Assert.Equal(5, searchCount);
        Assert.All(results, r => Assert.True(r.Success));
        Assert.All(results, r => Assert.Single(r.Results));
    }

    #endregion

    #region Helper Methods

    private static ScoredPoint CreateScoredPoint(float score, string text, string pdfId, int page, int chunkIndex)
    {
        var point = new ScoredPoint
        {
            Id = new PointId { Uuid = Guid.NewGuid().ToString() },
            Score = score,
            Payload =
            {
                ["text"] = text,
                ["pdf_id"] = pdfId,
                ["page"] = page,
                ["chunk_index"] = chunkIndex
            }
        };
        return point;
    }

    #endregion
}

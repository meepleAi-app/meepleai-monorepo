# Development environment variables for the Next.js web app
# Copy to .env.local and adjust values for your local setup

# API Base URL - points to backend running locally (Docker or `dotnet run`)
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Alpha Mode - enables Alpha Zero feature scope (build-time inlined)
NEXT_PUBLIC_ALPHA_MODE=true

# Mock Mode - serves mocked data when backend is unavailable
NEXT_PUBLIC_MOCK_MODE=true

# ─── Mechanic Extractor AI Validation (ADR-051 Sprint 1+2) ───────
# Admin-only dashboard for reviewing AI comprehension metrics against
# a curator-authored golden set, plus thresholds form, BGG paste
# importer and async mass-recalc. When unset or any value other than
# the literal string "true" (case-sensitive), the routes
# /admin/knowledge-base/mechanic-extractor/{dashboard,golden,review}
# return 404 and the embedded gates render nothing. Default-on in dev
# so the feature is exercised during local work; staging is gated
# explicitly via compose.staging.yml.
NEXT_PUBLIC_MECHANIC_VALIDATION_ENABLED=true
